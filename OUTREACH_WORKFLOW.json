      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "fileSelector": "outreach_contacts.csv",
        "options": {}
      },
      "id": "8a765c43-23b2-5432-cdef-678901bcdefg",
