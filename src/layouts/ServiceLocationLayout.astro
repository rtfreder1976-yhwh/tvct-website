  price,
  neighborhoods = [],
  faqs,
  localContext = [],
  neighborhoodsServed = [],
  whyChooseContent = [],
  serviceHighlights = [],
  countyName = "",
  realtorProgram,
} = Astro.props;

// Get service-specific testimonials
const serviceTestimonials = getTestimonialsByService(serviceSlug);

// Related services mapping - each service links to 2-3 related services
