import BaseLayout from "./BaseLayout.astro";
import SchemaMarkup from "../components/SchemaMarkup.astro";
import Icon from "../components/Icon.astro";
import BookingCTA from "../components/BookingCTA.astro";
import ProblemOptions from "../components/ProblemOptions.astro";
import StickyQuoteBar from "../components/StickyQuoteBar.astro";
import { getTestimonialsByService } from "../data/testimonials";

interface Props {
  title: string;
  description: string;
  service: string;
  serviceSlug: string;
  city: string;
  state: string;
  citySlug: string;
  serviceDescription: string;
  benefits: string[];
  includes: string[];
  price: string;
  neighborhoods?: string[];
  faqs: Array<{
    question: string;
    answer: string;
  }>;
  // NEW: Extended content props for better text-to-HTML ratio
  localContext?: string[]; // Array of paragraphs about local context
  neighborhoodsServed?: Array<{ name: string; zipCodes?: string[] }>; // Neighborhoods with zip codes
  whyChooseContent?: string[]; // Extended why choose us paragraphs
  serviceHighlights?: string[]; // Additional service highlights/features
  countyName?: string; // County name for local SEO
  // OPTIONAL: Realtor Program section — when set, renders a 2-column "For Realtors / For Their Clients" panel
  realtorProgram?: {
    intro?: string;
    realtorBenefits: string[];
    clientBenefits: string[];
    disclaimer?: string;
  };
}

