// Get related services for current service, default to common ones if not mapped
// Default uses only pages that exist in ALL locations (deep-cleaning and move-out-cleaning)
const relatedServices = relatedServicesMap[serviceSlug] || [
  {
    slug: "deep-cleaning",
    name: "Deep Cleaning",
    description: "Top-to-bottom cleaning",
  },
  {
    slug: "move-out-cleaning",
    name: "Move-Out Cleaning",
    description: "Moving services",
  },
];

// Generate canonical URL
const canonicalUrl = `https://thevalleycleanteam.com/locations/${citySlug}/${serviceSlug}`;

// Commercial/office services require on-site consultation, not instant online quotes
const isCommercial = ["commercial-cleaning", "office-cleaning", "dental-office-cleaning", "medical-office-cleaning"].includes(serviceSlug);

// Schema for Service with enhanced areaServed
const areaServedSchema =
  citySlug === "mountain-brook" && neighborhoods.length > 0
    ? [
        {
          "@type": "City",
          name: city,
          containedInPlace: { "@type": "State", name: state },
        },
        ...neighborhoods.map((neighborhood) => ({
          "@type": "Place",
          name: neighborhood,
          containedInPlace: {
            "@type": "City",
            name: city,
            containedInPlace: { "@type": "State", name: state },
          },
        })),
      ]
    : citySlug === "muscle-shoals"
      ? [
          {
            "@type": "City",
            name: "Muscle Shoals",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
          {
            "@type": "City",
            name: "Florence",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
          {
            "@type": "City",
            name: "Sheffield",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
          {
            "@type": "City",
            name: "Tuscumbia",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
          {
            "@type": "Place",
            name: "Walnut Street Historic District",
            containedInPlace: {
              "@type": "City",
              name: "Florence",
              containedInPlace: { "@type": "State", name: "Alabama" },
            },
          },
          {
            "@type": "Place",
            name: "Wilson Lake",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
          {
            "@type": "Place",
            name: "Shoals Creek",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
          {
            "@type": "Place",
            name: "Killen",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
        ]
      : {
          "@type": "City",
          name: city,
          containedInPlace: {
            "@type": "State",
            name: state,
          },
        };

// Schema for Service
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: service,
  provider: {
    "@type": "LocalBusiness",
    name: "The Valley Clean Team",
    telephone: "+1-256-826-1100",
    address: {
      "@type": "PostalAddress",
      addressLocality: city,
      addressRegion: state,
      addressCountry: "US",
    },
  },
  areaServed: areaServedSchema,
  description: serviceDescription,
  offers: {
    "@type": "Offer",
    priceSpecification: {
      "@type": "PriceSpecification",
      price: price.replace(/[^0-9]/g, ""),
      priceCurrency: "USD",
      unitText: "per service",
    },
  },
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

// ── Buyer-intent content (the "5 jobs") ───────────────────────────────────────
// Per-service framing so every combo page (1) names the exact buyer problem and
// (2) compares the real options, with a clean answer-first lead AI engines can
// cite (4). Cost/risk (3) and conversion (5) are handled by the price block + CTAs.
// Each page can override via props; otherwise we derive sensible defaults by slug.
type IntentOption = { label: string; detail: string; isUs?: boolean };
type ServiceIntent = {
  problem: string;
  options: IntentOption[];
};
const usOption = (detail: string): IntentOption => ({
  label: "The Valley Clean Team",
  detail,
  isUs: true,
});
const serviceIntentMap: Record<string, ServiceIntent> = {
  "move-out-cleaning": {
    problem:
      `You're moving out of a ${city} rental and your deposit is on the line. Landlords inspect the exact spots tenants miss — oven interiors, window tracks, cabinet shelves, bathroom grout — and deduct for every one. Clean it wrong and you lose hundreds.`,
    options: [
      { label: "Do it yourself", detail: "Free, but you clean what you see while the landlord inspects what you don't — the broiler drawer, fridge coils, caulk lines. The most-deducted areas are the easiest to miss." },
      { label: "A $19/hr gig cleaner", detail: "Cheap up front, but no checklist, no insurance, and no guarantee your deposit comes back. If they miss the inspection points, the cost lands on you." },
      usOption("Flat-rate move-out clean to a landlord's inspection checklist — inside appliances, tracks, grout, baseboards — with post-clean photos and a re-clean within 24 hours if anything's missed."),
    ],
  },
  "deep-cleaning": {
    problem:
      `Your ${city} home needs more than a surface wipe-down — built-up grime on baseboards, inside appliances, grout, and the spots a routine clean never reaches. The question is who actually cleans those, and what it really costs.`,
    options: [
      { label: "A standard/recurring clean", detail: "Maintains a home that's already clean — it won't cut through months of build-up in the oven, grout, and baseboards." },
      { label: "A cheap one-time clean", detail: "Advertised low, but 'deep clean' often means the same surface pass with a bigger price. Ask exactly what's included before you book." },
      usOption("A true top-to-bottom reset from a flat upfront price — baseboards, inside appliances, cabinet fronts, detailed kitchen and bath — with pet-safe products and a satisfaction guarantee."),
    ],
  },
  "recurring-maid-service": {
    problem:
      `You're tired of losing weekends to cleaning, but you've heard the horror stories — a different stranger every visit, no-shows, prices that creep up. You want consistency you can actually count on in ${city}.`,
    options: [
      { label: "Keep doing it yourself", detail: "Free, but it's the weekend time and mental load you never get back — and it never really stays done." },
      { label: "A rotating gig-app cleaner", detail: "A new face each visit who never learns your home, with no company insurance or accountability behind them." },
      usOption("The same background-checked team every visit, a flat quote that doesn't move, and no contract — cancel anytime. Weekly, bi-weekly, or monthly."),
    ],
  },
  "commercial-cleaning": {
    problem:
      `Your ${city} business can't run on a cleaner who flakes. A missed night means a bad first impression for clients or a compliance problem — and most 'commercial' cleaners are solo operators with no backup and no insurance.`,
    options: [
      { label: "An in-house or solo cleaner", detail: "Works until they're sick, quit, or no-show — then your facility goes uncleaned with no backup and the liability is yours." },
      { label: "The lowest bid", detail: "Cheapest per-visit, but turnover is high and quality slips fast once the contract is signed." },
      usOption("Insured, background-checked crews on a consistent schedule built around your hours, with a single point of contact and a free on-site assessment before any commitment."),
    ],
  },
  "airbnb-cleaning": {
    problem:
      `One bad turnover in ${city} — a missed stain, no fresh linens, a late finish — and you've got a 1-star review and a blocked calendar. You need a turnover that's guest-ready every single time, on a host's timeline.`,
    options: [
      { label: "Clean it yourself between guests", detail: "Doable until you scale — then back-to-back checkouts and a day job make same-day turnovers impossible." },
      { label: "A standard house cleaner", detail: "They'll clean, but they don't think like a host — linens, restocking, staging, and the checkout-to-check-in clock aren't their job." },
      usOption("Hospitality-standard turnovers timed to your booking calendar — fresh linens, restocked supplies, sanitized and staged — so every guest walks into a 5-star reset."),
    ],
  },
  "post-construction-cleaning": {
    problem:
      `After a renovation in ${city}, fine construction dust is in everything — vents, tracks, every surface — and it keeps resettling for days. Regular cleaning just spreads it around; this needs a specific process.`,
    options: [
      { label: "Clean it yourself", detail: "Without the right tools, dust resettles for a week and ends up in your HVAC. It's a job that fights back." },
      { label: "Your contractor's 'broom clean'", detail: "Gets the debris out, but leaves the fine dust film that makes a finished home feel unfinished." },
      usOption("A multi-stage dust-removal clean — top to bottom, vents and tracks included — that takes a job-site to move-in ready, with flexible scheduling around your timeline."),
    ],
  },
};
// Office/medical/dental/retail/restaurant/event/senior all map to the commercial framing
const intentAliases: Record<string, string> = {
  "office-cleaning": "commercial-cleaning",
  "medical-office-cleaning": "commercial-cleaning",
  "dental-office-cleaning": "commercial-cleaning",
  "retail-cleaning": "commercial-cleaning",
  "restaurant-cleaning": "commercial-cleaning",
  "event-cleaning": "commercial-cleaning",
  "weekly-cleaning": "recurring-maid-service",
  "biweekly-cleaning": "recurring-maid-service",
  "house-cleaning": "recurring-maid-service",
  "senior-cleaning": "recurring-maid-service",
};
const serviceIntent: ServiceIntent | undefined =
  serviceIntentMap[serviceSlug] ||
  serviceIntentMap[intentAliases[serviceSlug] || ""];

// Link to the city's "best cleaning company in {city}" comparison page where one
// exists (internal link: problem/compare block -> high-value best-of page).
const bestOfByCity: Record<string, string> = {
  huntsville: "/best-cleaning-company-huntsville-al",
  nashville: "/best-cleaning-company-nashville-tn",
  athens: "/best-cleaning-company-athens-al",
  florence: "/best-cleaning-company-florence-al",
  "muscle-shoals": "/best-cleaning-company-florence-al",
  "mountain-brook": "/best-cleaning-company-mountain-brook-al",
};
const compareHref = bestOfByCity[citySlug];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaType="local"
  city={city}
  state={state}
  serviceName={service}
  serviceDescription={serviceDescription}
  faqs={faqs}
>
  <!-- Page-level structured data: FAQ + Service (SchemaMarkup intentionally
       skips FAQPage so pages emit their own; these consts were previously
       defined but never rendered, leaving combo pages without FAQ/Service schema). -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- Hero Section -->
  <section class="pt-32 pb-20 px-6">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left Column -->
        <div class="text-center lg:text-left">
          <div
            class="inline-block bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 px-4 py-2 rounded-full mb-4"
          >
            <span class="text-[#FFA985] font-semibold">
              <Icon name="map-marker-alt" class="w-5 h-5 mr-2" />Serving {city}, {
                state
              }
            </span>
          </div>
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-[#333333]"
          >
            {service} in <span class="gold-gradient">{city}, {state}</span>
          </h1>
          <p class="text-xl text-gray-700 mb-6">{serviceDescription}</p>

          <div
            class="bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 rounded-xl p-6 mb-6"
          >
            {isCommercial ? (
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-gray-600 text-sm">Pricing</p>
                  <p class="text-4xl font-bold text-[#333333]">{price}</p>
                  <p class="text-xs text-gray-400 mt-1">Custom quoted after on-site walkthrough</p>
                </div>
                <div class="text-right">
                  <p class="text-green-600 font-semibold">
                    <Icon name="check-circle" class="w-5 h-5 mr-1" /> Free On-Site Assessment
                  </p>
                  <p class="text-green-600 font-semibold">
                    <Icon name="check-circle" class="w-5 h-5 mr-1" /> No Obligation
                  </p>
                </div>
              </div>
            ) : (
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-gray-600 text-sm">Base rate from</p>
                  <p class="text-4xl font-bold text-[#333333]">{price}</p>
                  <p class="text-xs text-gray-400 mt-1">Your exact price is custom quoted</p>
                </div>
                <div class="text-right">
                  <p class="text-green-600 font-semibold">
                    <Icon name="check-circle" class="w-5 h-5 mr-1" /> Free Exact Quote
                  </p>
                  <p class="text-green-600 font-semibold">
                    <Icon name="check-circle" class="w-5 h-5 mr-1" /> Same-Day Available
                  </p>
                </div>
              </div>
            )}
          </div>

          <!-- Urgency Badge -->
          <div
            class="inline-block bg-green-50 border border-green-200 px-4 py-2 rounded-lg mb-6"
          >
            <span class="text-green-700 font-semibold">
              <Icon
                name="calendar-check"
                class="w-5 h-5 text-green-600 mr-2"
              />Same-Week Availability
            </span>
          </div>

          <div
            class="flex flex-col sm:flex-row items-center lg:items-start space-y-3 sm:space-y-0 sm:space-x-4"
          >
            <a
              href="tel:2568261100"
              class="btn-primary px-8 py-4 rounded-full text-lg font-semibold shadow-lg hover:shadow-xl transition"
            >
              <Icon name="phone" class="w-5 h-5 mr-2" />Call Now: 256-826-1100
            </a>
            {isCommercial ? (
              <a
                href="/get-quote"
                class="px-8 py-4 rounded-full text-lg font-semibold border-2 border-[#FFA985] text-[#FFA985] hover:bg-[#FFA985] hover:text-white transition shadow-md"
              >
                <Icon name="building" class="w-5 h-5 mr-2" />Schedule a Walkthrough
              </a>
            ) : (
              <a
                href="/get-quote"
                class="px-8 py-4 rounded-full text-lg font-semibold border-2 border-[#FFA985] text-[#FFA985] hover:bg-[#FFA985] hover:text-white transition shadow-md"
              >
                <Icon name="calendar" class="w-5 h-5 mr-2" />See My Price
              </a>
            )}
          </div>
        </div>

        <!-- Right Column - Quote Form or Consultation CTA -->
        <div
          class="bg-white rounded-2xl p-8 shadow-2xl border-2 border-[#FFA985]/20"
        >
