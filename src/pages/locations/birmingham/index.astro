---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SchemaMarkup from "../../../components/SchemaMarkup.astro";
import Icon from "../../../components/Icon.astro";
import ProblemOptions from "../../../components/ProblemOptions.astro";
import { standaloneServiceIntent } from "../../../data/serviceIntent.ts";
import BookingCTA from "../../../components/BookingCTA.astro";

const city = "Birmingham";
const state = "Alabama";
const region = "Jefferson County";

// Geographic data (Birmingham metro center)
const geoData = {
  region: "US-AL",
  position: "33.5186;-86.8104",
  image:
    "https://storage.googleapis.com/msgsndr/iKQIBhpKVL2XVPgU7HMd/media/69208029f8fa3b30bb23e26e.webp",
};

// We serve the Birmingham area centered on Mountain Brook — honest coverage,
// not a metro-wide claim. These are the communities we actually clean.
const neighborhoods = [
  "Mountain Brook",
  "Crestline",
  "English Village",
  "Mountain Brook Village",
  "Cherokee Bend",
];

const faqs = [
  {
    question: "What parts of the Birmingham area do you serve?",
    answer:
      "We focus on the Birmingham area centered on Mountain Brook — including Crestline, English Village, Mountain Brook Village, and Cherokee Bend. If you're nearby and not sure whether we reach your street, just ask when you request a quote and we'll tell you honestly.",
  },
  {
    question: "How much does house cleaning cost in the Birmingham area?",
    answer:
      "Standard cleaning starts from $176, deep cleaning from $276, and move-in/move-out from $351 — quoted as a flat price upfront, not an hourly guess. Recurring weekly, bi-weekly, and monthly service comes with savings of up to 30%. The price you see is the price you pay.",
  },
  {
    question: "Do you clean historic and estate homes near Mountain Brook?",
    answer:
      "Yes. We care for the area's older and estate homes with pH-neutral products and gentle techniques that protect original hardwoods, leaded glass, and architectural detail. For Mountain Brook specifically, see our dedicated Mountain Brook page below.",
  },
  {
    question: "Are you insured and background-checked?",
    answer:
      "Yes — $2M insured, bonded, and every team member is background-checked. You get the same team every visit, post-clean photos, and a satisfaction guarantee. Veteran-owned and women-led.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<BaseLayout
  title="House Cleaning Birmingham AL | The Valley Clean Team"
  description="House cleaners serving the Birmingham, AL area — centered on Mountain Brook, Crestline & English Village. Flat pricing from $176, $2M insured, 146 5-star reviews. Free quote."
  canonicalUrl="https://thevalleycleanteam.com/locations/birmingham"
  ogImage={geoData.image}
  geoRegion={geoData.region}
  geoPlacename={`${city}, ${state}`}
  geoPosition={geoData.position}
>
  <SchemaMarkup type="local" city={city} state={state} neighborhoods={neighborhoods} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left">
          <div class="inline-block bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 px-4 py-2 rounded-full mb-4">
            <span class="text-[#FFA985] font-semibold">
              <Icon name="map-marker-alt" class="w-5 h-5 mr-2" />Serving the Birmingham Area
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-[#333333]">
            House Cleaning in the <span class="gold-gradient">Birmingham, Alabama</span> Area
          </h1>
          <p class="text-xl text-gray-700 mb-6">
            Trusted house cleaners for the Birmingham area — centered on Mountain
            Brook and the surrounding communities. Flat pricing quoted upfront, the
            same background-checked team every visit, and a 49-point checklist with
            post-clean photos.
          </p>
          <div class="flex flex-wrap gap-3 justify-center lg:justify-start mb-6">
            <div class="flex items-center bg-white px-4 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="medal" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">Veteran-Owned</span>
            </div>
            <div class="flex items-center bg-white px-4 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="shield-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">$2M Insured</span>
            </div>
            <div class="flex items-center bg-white px-4 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="star" class="w-5 h-5 text-[#FFA985] mr-2" fill="currentColor" />
              <span class="text-sm font-semibold text-gray-700">146 Reviews</span>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a href="#quote" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full shadow-lg hover:shadow-xl transition-all duration-200">
              <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
            </a>
            <a href="tel:+12568261100" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-[#333333] bg-white border-2 border-[#FFA985] rounded-full hover:bg-[#FFA985]/10 transition-all duration-200">
              <Icon name="phone" class="w-5 h-5 mr-2" />(256) 826-1100
            </a>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100" id="quote">
          <h2 class="text-2xl font-bold text-[#333333] mb-2 text-center">Get Your Free Quote</h2>
          <p class="text-gray-600 text-center mb-6">Birmingham-area cleaning, quoted in 60 seconds</p>
          <BookingCTA city="Birmingham" variant="card" />
        </div>
      </div>
    </div>
  </section>

  <!-- Honest coverage / Mountain Brook link -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold text-[#333333] mb-6">
        Where We Clean in the <span class="gold-gradient">Birmingham Area</span>
      </h2>
      <p class="text-lg text-gray-700 mb-6">
        We focus on the Birmingham area centered on Mountain Brook — Crestline,
        English Village, Mountain Brook Village, and Cherokee Bend. We'd rather tell
        you honestly where we reach than overpromise. If you're nearby, ask when you
        request a quote and we'll let you know.
      </p>
      <p class="text-lg text-gray-700">
        Live in Mountain Brook? We have a dedicated page with everything specific to
        your community —
        <a href="/locations/mountain-brook" class="text-[#FFA985] font-semibold underline">
          see our Mountain Brook house cleaning page
        </a>.
      </p>
    </div>
  </section>

  <!-- Buyer-intent problem + options -->
  <ProblemOptions
    heading="Choosing a house cleaner in the Birmingham area — your real options"
    problem={standaloneServiceIntent["neighborhood"].problem}
    options={standaloneServiceIntent["neighborhood"].options}
    ctaLabel="See your flat Birmingham-area price in 60 seconds"
    compareHref="/best-cleaning-company-mountain-brook-al"
    compareLabel="See how we compare to other Birmingham-area cleaners →"
  />

  <!-- FAQ -->
  <section class="py-16 px-6" id="faq">
    <div class="container mx-auto max-w-3xl">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Frequently Asked <span class="gold-gradient">Questions</span>
      </h2>
      <p class="text-center text-gray-600 mb-12">
        Common questions from Birmingham-area homeowners
      </p>
      <div class="space-y-4">
        {
          faqs.map((faq) => (
            <details class="bg-white rounded-xl shadow-md border border-gray-100 group">
              <summary class="p-6 cursor-pointer list-none flex justify-between items-center">
                <span class="font-semibold text-[#333333] pr-4">{faq.question}</span>
                <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform" />
              </summary>
              <div class="px-6 pb-6 text-gray-600">{faq.answer}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-gradient-to-r from-[#FFA985] to-[#FFC67D]">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready for a Spotless Home in the Birmingham Area?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Get your free quote in 60 seconds. We reply within 2 hours, and same-day
        service is often available.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#quote" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-[#FFA985] bg-white rounded-full shadow-lg hover:shadow-xl transition-all duration-200">
          <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
        </a>
        <a href="tel:+12568261100" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-full hover:bg-white/10 transition-all duration-200">
          <Icon name="phone" class="w-5 h-5 mr-2" />(256) 826-1100
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gold-gradient {
    background: linear-gradient(135deg, #ffa985 0%, #ffc67d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
