---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SchemaMarkup from "../../../components/SchemaMarkup.astro";
import Icon from "../../../components/Icon.astro";

const faqs = [
  {
    question:
      "What recurring cleaning frequencies do you offer in Mountain Brook?",
    answer:
      "We offer weekly, biweekly (every 2 weeks), and monthly recurring maid service in Mountain Brook. Weekly cleaning keeps your home in pristine condition with 20% savings. Biweekly is popular for maintaining a consistently clean home with 15% savings. Monthly works well for lighter maintenance with 10% savings.",
  },
  {
    question:
      "How much can I save with recurring maid service in Mountain Brook?",
    answer:
      "Mountain Brook clients save significantly with recurring service: Weekly cleaning saves 20%, biweekly saves 15%, and monthly saves 10% compared to one-time rates. For a home that costs $200 for one-time cleaning, weekly service might be just $160/visit.",
  },
  {
    question: "Do you have experience cleaning Mountain Brook luxury homes?",
    answer:
      "Absolutely. We've served Mountain Brook's finest homes for years - from historic Crestline estates to modern English Village properties. Our team understands fine finishes, antiques, hardwoods, and the attention to detail that luxury homes require.",
  },
  {
    question: "Is there a contract for recurring service?",
    answer:
      "No contracts ever. Cancel or pause anytime with 48 hours notice. We believe in earning your business every visit through exceptional quality, not locking you into agreements.",
  },
  {
    question: "Do I get the same cleaning team every time?",
    answer:
      "Yes! We assign a dedicated team to your Mountain Brook home. The same trusted professionals come each visit, learning your preferences and ensuring consistent results. Many clients consider their team an extension of their household staff.",
  },
  {
    question: "What products do you use in Mountain Brook homes?",
    answer:
      "We use premium, pH-neutral products safe for hardwoods, marble, granite, antiques, and fine finishes. We never use harsh chemicals. If you have specific product preferences or sensitivities, we're happy to accommodate.",
  },
  {
    question: "What Mountain Brook neighborhoods do you serve?",
    answer:
      "We serve all of Mountain Brook including Crestline, English Village, Mountain Brook Village, Cherokee Bend, Overton, Crestline Park, and surrounding Over the Mountain communities. We also serve Homewood and Vestavia Hills.",
  },
  {
    question: "How do I start recurring maid service?",
    answer:
      "Call 256-826-1100 or complete our online form. We'll discuss your home, preferences, and schedule. Most Mountain Brook clients start with a deep cleaning to establish a baseline, then begin their recurring schedule. We can often start within days.",
  },
  {
    question: "How do you handle cleaning around fine furnishings, antiques, and art?",
    answer:
      "With the care these pieces require. Our Mountain Brook team learns to identify furniture, surfaces, and objects that need specific handling — whether that means using the appropriate pH-neutral product for marble, keeping certain products away from antique finishes, or simply understanding which pieces require hand-dusting versus mechanical cleaning. We discuss these preferences during your initial consultation and document them in your client file.",
  },
  {
    question: "Can you clean for Mountain Brook charity events and entertaining?",
    answer:
      "Yes — pre-event and post-event cleaning is available for Mountain Brook clients hosting charity events, dinner parties, and social gatherings. Many of our recurring clients schedule supplemental cleaning around their entertaining calendar. Established recurring clients receive priority scheduling for event-specific requests. Let us know your social calendar when you start service and we'll build it into your schedule.",
  },
  {
    question: "Is recurring maid service a replacement for household staff?",
    answer:
      "For many Mountain Brook households, recurring maid service provides core cleaning functions previously handled by household staff — often at a more cost-effective rate for families who don't require full-time on-site help. Our dedicated team model creates the relationship continuity and home-specific knowledge that functions like household staff in practice. The difference is operational: our team brings everything needed, requires no HR management from you, and is covered under our $2M insurance.",
  },
  {
    question: "Do you serve Over the Mountain communities near Mountain Brook?",
    answer:
      "Yes — we serve all of Mountain Brook's neighboring Over the Mountain communities including Homewood, Vestavia Hills, Brookwood, and the broader residential areas of the Mountain Brook/Birmingham corridor. If you're uncertain whether your address falls within our service zone, call 256-826-1100 and we'll confirm immediately. Most Over the Mountain residential addresses are within our recurring service coverage.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
import BookingCTA from "../../../components/BookingCTA.astro";
