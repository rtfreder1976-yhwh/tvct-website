---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const city = "Huntsville";
const state = "Alabama";
const phone = "(256) 826-1100";

// Huntsville neighborhoods
const neighborhoods = [
  "Downtown Huntsville",
  "The Ledges",
  "Hampton Cove",
  "Madison",
  "Research Park",
  "Jones Valley",
  "Monte Sano",
  "Twickenham",
  "Big Cove",
  "Harvest",
  "Meridianville",
  "Owens Cross Roads",
  "Providence",
  "Cummings Research Park",
  "South Huntsville",
  "Five Points"
];

// What's included in deep cleaning
const includedServices = [
  "Remove cobwebs from all rooms",
  "Empty trash throughout",
  "Sweep/vacuum all floors (carpet + hard surfaces)",
  "Mop all hard surface floors",
  "Dust all shelves",
  "Dust blinds, windows, and window sills",
  "Wipe & clean all mirrors",
  "Wipe & clean all light switches",
  "Clean all glass surfaces",
  "Dust baseboards throughout",
  "Dust reachable ceiling fans & vents",
  "Dust furniture and lamps",
  "Inside/outside of microwave oven",
  "Clean kitchen backsplash",
  "Exterior of trash can",
  "Outside of stove hood",
  "Clean stovetop",
  "Wipe countertops",
  "Clean sink & chrome",
  "Exterior of cabinets & drawers",
  "Pantry floor & door",
  "Top of refrigerator",
  "Tables and chairs",
  "Outside of appliances",
  "Clean shower",
  "Clean tub",
  "Polish faucets",
  "Clean sinks",
  "Clean toilet and toilet area",
  "Clean bathroom counters",
  "Dust bathroom ledges",
  "Exterior of bathroom cabinets and drawers",
  "Dust bathroom doors & door frames",
  "Vacuum bathroom rugs",
  "Make beds (change linen if available)",
  "Vacuum bedroom rugs",
  "Exterior of bedroom cabinets and drawers",
  "Dust bedroom ledges",
  "Dust bedroom doors & door frames",
  "Dust and wipe outside of washer & dryer",
  "Clean laundry room sinks",
  "Vacuum laundry room rugs",
  "Laundry room countertops",
  "Dust laundry room ledges",
  "Dust laundry room doors & door frames",
  "Dust dining room ledges",
  "Dining room tables & chairs",
  "Dust dining room doors & door frames",
  "Dust living room ledges",
  "Exterior of living room cabinets & drawers",
  "Dust living room doors & door frames",
  "Dust office ledges",
  "Vacuum office rugs",
  "Exterior of office cabinets & drawers",
  "Dust office doors & door frames",
  "Wet wipe windows & blinds",
  "Hand detail baseboards",
];

// Process steps
const processSteps = [
  {
    step: "1",
    title: "Request Your Quote",
    description: "Tell us about your Huntsville home—square footage, number of rooms, and any specific concerns. We'll provide a detailed, no-obligation quote."
  },
  {
    step: "2",
    title: "Schedule Your Clean",
    description: "Pick a date and time that works for your schedule. We offer flexible availability including weekends for busy Rocket City professionals."
  },
  {
    step: "3",
    title: "Deep Clean Every Room",
    description: "Our trained team systematically cleans your entire home from ceiling to floor—reaching areas regular cleaning misses."
  },
  {
    step: "4",
    title: "Enjoy Your Spotless Home",
    description: "Walk into a fresh, sanitized home that looks and smells amazing. Many clients continue with recurring service to maintain that feeling."
  }
];

// FAQs
const faqs = [
  {
    question: "How much does deep cleaning cost in Huntsville?",
    answer: "Deep cleaning in Huntsville typically ranges from $225-$400 for average-sized homes (1,800-2,800 sq ft). Larger homes in The Ledges, Hampton Cove, or Monte Sano (3,500+ sq ft) may run $400-$550+. Pricing depends on square footage, number of rooms, home condition, and specific requests. Call (256) 826-1100 for a free, detailed quote."
  },
  {
    question: "What's included in a deep cleaning vs. regular cleaning?",
    answer: "Deep cleaning goes far beyond regular maintenance cleaning. We clean inside appliances (oven, refrigerator, microwave), detail baseboards, clean window sills and tracks, degrease kitchen surfaces, deep scrub tile grout, clean under and behind furniture, dust ceiling fans and light fixtures, and sanitize high-touch surfaces throughout your Huntsville home."
  },
  {
    question: "Do you serve Hampton Cove, The Ledges, and Madison?",
    answer: "Yes! We specialize in Huntsville's premier communities including Hampton Cove, The Ledges, Madison, Monte Sano, Jones Valley, and Providence. We understand the expectations of these luxury neighborhoods and deliver the premium service your home deserves."
  },
  {
    question: "How long does deep cleaning take in Huntsville?",
    answer: "Typical Huntsville homes (2,000-3,000 sq ft) take 4-6 hours for a thorough deep clean. Larger Hampton Cove or Ledges homes or those that haven't been professionally cleaned recently may take 6-8+ hours. We don't rush—we ensure every area meets our standards before leaving."
  },
  {
    question: "Do you offer deep cleaning for historic homes in Twickenham and Five Points?",
    answer: "Absolutely. Huntsville's historic districts feature beautiful antebellum and early 20th century architecture requiring specialized care. Our team uses gentle, pH-neutral products that clean effectively while protecting original hardwood floors, antique fixtures, and delicate architectural details."
  },
  {
    question: "Can you clean condos and apartments near Research Park?",
    answer: "Yes! We serve condos, apartments, and townhomes throughout Huntsville including Research Park, Cummings Research Park, Bridge Street, and Downtown. We carry $2M insurance and provide professional service for busy aerospace engineers and tech professionals. Your home receives premium care."
  },
  {
    question: "What Huntsville neighborhoods do you serve?",
    answer: "We serve all of Huntsville and Madison County including Downtown, The Ledges, Hampton Cove, Madison, Research Park, Jones Valley, Monte Sano, Twickenham, Big Cove, Harvest, Meridianville, Owens Cross Roads, Providence, South Huntsville, and Five Points."
  },
  {
    question: "Should I start with deep cleaning before recurring service?",
    answer: "We highly recommend it. A deep clean establishes a pristine baseline, then recurring service maintains that level. Think of it like detailing your car before regular washes. Most Huntsville clients start with deep cleaning, then transition to biweekly or weekly service."
  }
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Deep Cleaning Huntsville AL",
  "provider": {
    "@type": "LocalBusiness",
    "name": "The Valley Clean Team",
    "telephone": "+12568261100",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Huntsville",
      "addressRegion": "AL",
      "addressCountry": "US"
    }
  },
  "areaServed": neighborhoods.map(n => ({
    "@type": "Place",
    "name": `${n}, Huntsville, AL`
  })),
  "serviceType": "Deep Cleaning",
  "description": "Professional deep cleaning services in Huntsville, Alabama. Comprehensive top-to-bottom cleaning for homes throughout Madison County."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
import BookingCTA from "../../../components/BookingCTA.astro";
---

<BaseLayout
  title="Deep Cleaning Huntsville AL | Valley Clean Team"
  description="Professional deep cleaning in Huntsville, AL. Serving Hampton Cove, The Ledges, Madison, Monte Sano. Inside appliances, baseboards, grout. Call 256-826-1100"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />


  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-gray-50 to-white">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-green-50 border border-green-200 px-4 py-2 rounded-full mb-4">
            <span class="text-green-700 text-sm font-medium">
              <Icon name="sparkles" class="w-5 h-5 mr-2" />Top-to-Bottom Cleaning
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-[#333333] mb-6 leading-tight">
            Deep Cleaning Services in <span class="gold-gradient">Huntsville, Alabama</span>
          </h1>
          <p class="text-xl text-gray-700 mb-6">
            The Rocket City demands precision in everything—including your home's cleanliness. Our comprehensive deep cleaning service reaches every corner of your Huntsville home—inside appliances, behind furniture, and everywhere regular cleaning misses. Perfect for Hampton Cove estates, Ledges homes, and Research Park condos alike.
          </p>

          <!-- Trust Badges -->
          <div class="flex flex-wrap gap-3 mb-6">
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="medal" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">Veteran-Owned</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="shield-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">$2M Insured</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="star" class="w-5 h-5 text-[#FFA985] mr-2" fill="currentColor" />
              <span class="text-sm font-semibold text-gray-700">200+ 5-Star Reviews</span>
            </div>
          </div>

          <!-- Price -->
          <div class="bg-white rounded-xl p-4 shadow-md border border-gray-100 inline-block mb-6">
            <div class="flex items-center gap-4">
              <div>
                <span class="text-sm text-gray-600">Deep Cleaning From</span>
                <div class="text-3xl font-bold text-[#FFA985]">$250</div>
              </div>
              <div class="text-gray-300">|</div>
              <div>
                <span class="text-sm text-gray-600">Typical Huntsville Homes</span>
                <div class="text-lg font-semibold text-gray-700">$300-$425</div>
              </div>
              <div class="text-gray-300">|</div>
              <div>
                <span class="text-sm text-gray-600">Larger Homes</span>
                <div class="text-lg font-semibold text-gray-700">$425-$550+</div>
              </div>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#quote" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full shadow-lg hover:shadow-xl transition-all">
              <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
            </a>
            <a href="tel:+12568261100" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-[#333333] bg-white border-2 border-[#FFA985] rounded-full hover:bg-[#FFA985]/10 transition-all">
              <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
            </a>
          </div>
        </div>

        <!-- Quote Form -->
        <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
          <h2 class="text-2xl font-bold text-[#333333] mb-2 text-center">Get Your Free Quote</h2>
          <p class="text-gray-600 text-center mb-6">Huntsville's trusted deep cleaning professionals</p>
          <BookingCTA city="Huntsville" variant="card" />
        </div>
      </div>
    </div>
  </section>

  <!-- Why Huntsville Homes Need Deep Cleaning -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-[#333333] mb-8">
          Why Huntsville Homes Need <span class="gold-gradient">Professional Deep Cleaning</span>
        </h2>
        <div class="prose prose-lg max-w-none text-gray-700">
          <p class="mb-6">
            Huntsville's climate creates unique cleaning challenges. Alabama's hot, humid summers mean air conditioning runs constantly—and dust, pollen, and allergens circulate throughout your home. The Tennessee Valley's mix of clay soil and construction from the city's rapid growth tracks in on shoes and pets, settling on baseboards and accumulating in corners. Regular cleaning simply can't keep up.
          </p>
          <p class="mb-6">
            For Hampton Cove estates, Ledges homes, and Monte Sano properties, there's an additional factor: these premium properties feature high-end finishes, expansive floor plans, and architectural details that accumulate dust in hard-to-reach places. Vaulted ceilings, crown molding, built-in cabinetry, and professional-grade appliances all require thorough, careful cleaning that goes beyond surface maintenance.
          </p>
          <p>
            Whether you're preparing for the holidays, recovering from renovation, moving into a new home, or simply haven't had a professional clean in months, our deep cleaning service addresses every area of your Huntsville home. We clean inside appliances, behind furniture, and in corners and crevices that daily cleaning misses—leaving your home truly, comprehensively clean.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        What's Included in <span class="gold-gradient">Huntsville Deep Cleaning</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Comprehensive cleaning that goes far beyond regular maintenance
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {includedServices.map((service) => (
          <div class="flex items-center bg-white rounded-lg p-4 shadow-sm border border-gray-100">
            <Icon name="check-circle" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
            <span class="text-gray-700">{service}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Our <span class="gold-gradient">Deep Cleaning Process</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Systematic, thorough, and designed for Huntsville homes
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
        {processSteps.map((step) => (
          <div class="text-center">
            <div class="w-16 h-16 bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-bold">
              {step.step}
            </div>
            <h3 class="text-xl font-bold text-[#333333] mb-3">{step.title}</h3>
            <p class="text-gray-600">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Huntsville Neighborhoods -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Deep Cleaning Throughout <span class="gold-gradient">Huntsville</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Serving all of Madison County and Huntsville's most sought-after neighborhoods
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto mb-12">
        <!-- Premium Communities -->
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <h3 class="text-lg font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="home" class="w-5 h-5 text-[#FFA985] mr-2" />Premium Communities
          </h3>
          <ul class="space-y-2 text-gray-600">
            <li>• Hampton Cove</li>
            <li>• The Ledges</li>
            <li>• Monte Sano</li>
            <li>• Jones Valley</li>
            <li>• Providence</li>
            <li>• Big Cove</li>
          </ul>
        </div>

        <!-- Urban Huntsville -->
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <h3 class="text-lg font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="city" class="w-5 h-5 text-[#FFA985] mr-2" />Urban Huntsville
          </h3>
          <ul class="space-y-2 text-gray-600">
            <li>• Downtown Huntsville</li>
            <li>• Twickenham</li>
            <li>• Five Points</li>
            <li>• Research Park</li>
            <li>• Cummings Research Park</li>
            <li>• South Huntsville</li>
          </ul>
        </div>

        <!-- Greater Huntsville -->
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <h3 class="text-lg font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="map-marked-alt" class="w-5 h-5 text-[#FFA985] mr-2" />Greater Huntsville
          </h3>
          <ul class="space-y-2 text-gray-600">
            <li>• Madison</li>
            <li>• Harvest</li>
            <li>• Meridianville</li>
            <li>• Owens Cross Roads</li>
            <li>• Monrovia</li>
            <li>• New Market</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-12">
        Why Huntsville Families Choose <span class="gold-gradient">The Valley Clean Team</span>
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="rocket" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Rocket City Standards</h3>
          <p class="text-gray-600">We understand the expectations of Huntsville's aerospace engineers and tech professionals. Precision, attention to detail, and consistent results—exactly what you'd expect.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="landmark" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Historic Home Expertise</h3>
          <p class="text-gray-600">Huntsville's Twickenham and Old Town districts feature irreplaceable antebellum architecture. We use gentle products that clean effectively while preserving architectural details.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="building" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Condo & Apartment Ready</h3>
          <p class="text-gray-600">Research Park condos, Downtown apartments, and Bridge Street residences. We carry $2M insurance and provide professional service for busy Huntsville professionals.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="medal" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Veteran-Owned</h3>
          <p class="text-gray-600">Military precision, attention to detail, and values you can trust. We approach every Huntsville home with the same discipline and dedication—just like the Arsenal demands.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="shield-alt" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">$2M Insured</h3>
          <p class="text-gray-600">Fully bonded and insured for your complete peace of mind. Your Hampton Cove estate or Ledges home is protected throughout our service.</p>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="star" class="w-8 h-8 text-[#FFA985]" fill="currentColor" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Satisfaction Guaranteed</h3>
          <p class="text-gray-600">If you're not happy with any aspect of your deep clean, we'll come back and make it right. 200+ five-star reviews prove our commitment to quality.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Perfect For Section -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        When to Schedule <span class="gold-gradient">Deep Cleaning</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Deep cleaning is ideal for these situations
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="bg-white rounded-xl p-5 shadow-md border border-gray-100 text-center">
          <Icon name="calendar-alt" class="w-5 h-5 text-3xl text-[#FFA985] mb-3" />
          <h3 class="font-bold text-[#333333] mb-2">Seasonal Refresh</h3>
          <p class="text-gray-600 text-sm">Spring cleaning, holiday prep, or quarterly maintenance to keep your home at its best.</p>
        </div>

        <div class="bg-white rounded-xl p-5 shadow-md border border-gray-100 text-center">
          <Icon name="box" class="w-5 h-5 text-3xl text-[#FFA985] mb-3" />
          <h3 class="font-bold text-[#333333] mb-2">Moving In/Out</h3>
          <p class="text-gray-600 text-sm">Start fresh in your new Huntsville home or leave your old property spotless.</p>
        </div>

        <div class="bg-white rounded-xl p-5 shadow-md border border-gray-100 text-center">
          <Icon name="hammer" class="w-5 h-5 text-3xl text-[#FFA985] mb-3" />
          <h3 class="font-bold text-[#333333] mb-2">Post-Renovation</h3>
          <p class="text-gray-600 text-sm">Construction dust gets everywhere. We'll make your renovated home livable again.</p>
        </div>

        <div class="bg-white rounded-xl p-5 shadow-md border border-gray-100 text-center">
          <Icon name="sync-alt" class="w-5 h-5 text-3xl text-[#FFA985] mb-3" />
          <h3 class="font-bold text-[#333333] mb-2">Before Recurring</h3>
          <p class="text-gray-600 text-sm">Establish a pristine baseline before starting weekly or biweekly service.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Frequently Asked <span class="gold-gradient">Questions</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Common questions about deep cleaning in Huntsville
      </p>

      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <details class="bg-white rounded-xl shadow-md border border-gray-100 group">
            <summary class="p-6 cursor-pointer list-none flex justify-between items-center">
              <span class="font-semibold text-[#333333] pr-4">{faq.question}</span>
              <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform flex-shrink-0" />
            </summary>
            <div class="px-6 pb-6 text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

