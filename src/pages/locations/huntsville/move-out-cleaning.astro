---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const city = "Huntsville";
const state = "Alabama";
const phone = "(256) 826-1100";

// Huntsville neighborhoods
const neighborhoods = [
  "Downtown Huntsville",
  "The Ledges",
  "Hampton Cove",
  "Madison",
  "Research Park",
  "Jones Valley",
  "Monte Sano",
  "Twickenham",
  "Big Cove",
  "Harvest",
  "Meridianville",
  "Owens Cross Roads",
  "Providence",
  "South Huntsville",
  "Five Points"
];

// What's included
const includedServices = [
  "All surfaces dusted & wiped",
  "Ceiling fans & light fixtures",
  "Baseboards thoroughly cleaned",
  "Door frames & doors wiped",
  "Window sills & tracks detailed",
  "Switch plates & outlets cleaned",
  "Kitchen deep cleaned",
  "Inside oven cleaned",
  "Inside refrigerator cleaned",
  "Inside dishwasher & microwave",
  "All cabinets wiped inside & out",
  "Countertops sanitized",
  "Bathrooms deep scrubbed",
  "Tile & grout cleaned",
  "Toilets sanitized completely",
  "Mirrors & glass polished",
  "Floors vacuumed & mopped",
  "Closets cleaned out",
  "Garage swept (if applicable)"
];

// FAQs
const faqs = [
  {
    question: "How much does move-out cleaning cost in Huntsville?",
    answer: "Move-out cleaning in Huntsville typically ranges from $225-$375 for average homes (1,500-2,500 sq ft). Larger homes in Hampton Cove, The Ledges, or Monte Sano (3,000+ sq ft) may run $375-$550+. Pricing depends on square footage, home condition, and specific requirements. Call (256) 826-1100 for a free quote."
  },
  {
    question: "Will move-out cleaning help me get my deposit back?",
    answer: "That's our goal! Our thorough move-out cleaning addresses all the areas landlords and property managers check—inside appliances, baseboards, window tracks, cabinets, and detailed bathroom cleaning. We clean to the standard expected for deposit return inspections."
  },
  {
    question: "Do you clean apartments near Research Park and Redstone Arsenal?",
    answer: "Yes! We service apartments throughout Huntsville including Research Park, Cummings Research Park, near Redstone Arsenal, Bridge Street area, and Downtown. We understand apartment cleaning requirements and work within move-out timelines—especially important for military PCS moves and contractor relocations."
  },
  {
    question: "Can you clean large homes in Hampton Cove and The Ledges?",
    answer: "Absolutely! We regularly clean large estate homes in Hampton Cove, The Ledges, Monte Sano, and Jones Valley. Our team is experienced with high-end finishes, multiple bathrooms, large kitchens, and the attention to detail these premium properties require."
  },
  {
    question: "How far in advance should I schedule move-out cleaning?",
    answer: "We recommend booking 1-2 weeks before your move-out date, especially at month-end when demand is highest. For military PCS moves, book as soon as you have orders. We can sometimes accommodate last-minute requests, but advance booking guarantees your preferred date and time."
  },
  {
    question: "How long does move-out cleaning take?",
    answer: "Typical Huntsville apartments and smaller homes (under 2,000 sq ft) take 3-5 hours. Larger homes in Hampton Cove, The Ledges, or Madison (2,500-4,000 sq ft) take 5-8 hours. We provide time estimates with your quote and ensure thorough cleaning regardless of duration."
  },
  {
    question: "Do you work with Huntsville property management companies?",
    answer: "Yes! We work with property managers, landlords, and real estate agents throughout Huntsville and Madison County. We also have experience with military housing inspections and understand the higher standards required for clearing quarters. We can coordinate directly with property managers on scheduling and requirements."
  },
  {
    question: "What if the previous tenant left the home very dirty?",
    answer: "We can handle heavily soiled properties, though pricing may be adjusted for extreme conditions. Let us know the situation when requesting a quote, and we'll provide an accurate estimate. Before-and-after photos help us assess the scope and provide fair pricing."
  },
  {
    question: "Do you understand Redstone Arsenal military housing inspection standards?",
    answer: "Yes — as a veteran-owned company, we have direct familiarity with military housing inspection protocols. Redstone Arsenal BAH housing, post housing, and privatized military housing all have specific cleaning standards for clearing quarters. We clean to those standards: inside all appliances, window tracks, baseboards, bathroom tile and grout, cabinet interiors, and every area a housing inspector checks. Military families clearing quarters have consistently used our service for exactly this reason."
  },
  {
    question: "How does Huntsville's aerospace workforce affect demand for move-out cleaning?",
    answer: "Huntsville's defense and aerospace workforce is among the most mobile in the country — Redstone Arsenal PCS cycles, Boeing and Lockheed relocation packages, NASA Marshall center transfers, and the general professional mobility of a tech-heavy economy all create consistent move-out cleaning demand. We work with relocating contractors, military families, and aerospace professionals throughout Madison County on their move-out timelines. If you have PCS orders or a relocation timeline driving your move-out date, tell us when you call — we coordinate around those deadlines specifically."
  },
  {
    question: "Can you accommodate move-out cleaning for Research Park and Bridge Street area condos?",
    answer: "Yes — high-rise condos, mid-rise buildings, and condo communities throughout the Research Park, Bridge Street, and Downtown Huntsville corridors are served by our move-out cleaning service. These properties often have HOA cleaning standards in addition to lease cleaning requirements, and we understand both layers. Building access, elevator scheduling, and parking logistics for cleaning services in these buildings are details we navigate as standard procedure for urban Huntsville properties."
  },
  {
    question: "What's your satisfaction guarantee for Huntsville move-out cleaning?",
    answer: "If your property manager or housing inspector identifies any cleaning issue within our scope during their inspection, call us within 72 hours and we'll return to correct it at no charge. No forms, no complicated process. We stand behind our Huntsville move-out cleaning completely. Our goal is a passed inspection on the first walkthrough — and if something is found, we return and fix it. This guarantee is backed by our $2 million liability insurance and our years of serving Madison County renters and military families."
  }
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Move-Out Cleaning Huntsville AL",
  "provider": {
    "@type": "LocalBusiness",
    "name": "The Valley Clean Team",
    "telephone": "+12568261100",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Huntsville",
      "addressRegion": "AL",
      "addressCountry": "US"
    }
  },
  "areaServed": neighborhoods.map(n => ({
    "@type": "Place",
    "name": `${n}, Huntsville, AL`
  })),
  "serviceType": "Move-Out Cleaning",
  "description": "Professional move-out cleaning services in Huntsville, Alabama. Get your deposit back with thorough cleaning in Hampton Cove, The Ledges, Madison, and beyond."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
import BookingCTA from "../../../components/BookingCTA.astro";
