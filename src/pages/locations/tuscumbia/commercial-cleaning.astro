---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const city = "Tuscumbia";
const state = "Alabama";
const phone = "256-826-1100";

// Business areas
const businessAreas = [
  "Downtown Tuscumbia",
  "Main Street",
  "Highway 72",
  "Highway 43",
  "Spring Park Area",
  "Sheffield",
  "Muscle Shoals",
  "Florence",
  "Colbert Heights",
  "Cherokee"
];

// Industries served
const industries = [
  { name: "Medical & Dental Offices", icon: "stethoscope" },
  { name: "Professional Offices", icon: "briefcase" },
  { name: "Retail Stores", icon: "store" },
  { name: "Restaurants & Cafes", icon: "utensils" },
  { name: "Fitness Centers", icon: "dumbbell" },
  { name: "Hair & Beauty Salons", icon: "cut" },
  { name: "Churches", icon: "church" },
  { name: "Daycares", icon: "child" },
  { name: "Real Estate Offices", icon: "home" },
  { name: "Banks & Financial", icon: "university" },
  { name: "Manufacturing Offices", icon: "industry" },
  { name: "Warehouses", icon: "warehouse" }
];

// What's included
const includedServices = [
  "Reception & lobby areas",
  "All surfaces dusted & wiped",
  "Desks & workstations cleaned",
  "Conference rooms refreshed",
  "Break rooms & kitchenettes",
  "Restrooms deep sanitized",
  "Floors vacuumed & mopped",
  "Trash emptied & liners replaced",
  "Windows & glass cleaned",
  "High-touch disinfection",
  "Carpet spot cleaning",
  "Supply restocking"
];

// FAQs
const faqs = [
  {
    question: "How much does commercial cleaning cost in Tuscumbia?",
    answer: "Commercial cleaning pricing varies based on square footage, cleaning frequency, and specific requirements. Small offices may start around $150-$200 per visit, while larger spaces vary accordingly. We provide free on-site estimates. Call 256-826-1100 to discuss your needs."
  },
  {
    question: "What areas of the Shoals do you serve for commercial cleaning?",
    answer: "We serve businesses throughout the Quad Cities including Tuscumbia, Sheffield, Muscle Shoals, and Florence. Whether you're on Main Street in downtown Tuscumbia or in a commercial area along Highway 72, we can help."
  },
  {
    question: "Do you offer after-hours cleaning?",
    answer: "Yes! Most of our commercial clients prefer evening or early morning cleaning to avoid disrupting their business operations. We accommodate the schedule that works best for your business."
  },
  {
    question: "Do you clean medical and dental offices?",
    answer: "Yes, we serve medical and dental practices throughout the Shoals. We understand healthcare cleaning requirements and use EPA-registered disinfectants. We can work around patient schedules and maintain the high standards healthcare environments require."
  },
  {
    question: "Do you provide janitorial supplies?",
    answer: "We can provide all cleaning supplies and equipment, or work with supplies you provide. For restocking items like paper towels, toilet paper, and hand soap, we can either use what you provide or include supply management in your service."
  },
  {
    question: "Are you insured for commercial work?",
    answer: "Yes, we carry $2 million in liability insurance. We can provide certificates of insurance to property managers or landlords upon request."
  },
  {
    question: "How do you handle building access and security?",
    answer: "We establish secure access procedures with each client—whether that's key access, alarm codes, or coordination with building management. All our staff are background-checked and bonded."
  },
  {
    question: "Can you customize a cleaning plan for my business?",
    answer: "Absolutely! We understand every business has different needs. We'll do a walkthrough of your space and create a customized cleaning plan that addresses your priorities, schedule, and budget."
  },
  {
    question: "Do you serve businesses along the Helen Keller Festival corridor?",
    answer: "Yes. Downtown Tuscumbia businesses along Sixth Street and Spring Park see significant foot traffic during the Helen Keller Festival in June and other seasonal events. We offer pre-event deep commercial cleaning to ensure your storefront, restaurant, or office looks its best for increased visitor volume. Post-event restoration service is also available for businesses that host large crowds."
  },
  {
    question: "Can you clean manufacturing support offices and industrial facilities near Highway 72?",
    answer: "Absolutely. The Highway 72 corridor in Tuscumbia and the broader Colbert County industrial area includes manufacturing support offices, warehouses, and light industrial facilities. We provide commercial cleaning for office areas, breakrooms, restrooms, and common areas in industrial settings. Our team works around shift schedules and can access facilities during off-hours to avoid operational disruption."
  },
  {
    question: "How do you handle cleaning for churches in the Quad Cities?",
    answer: "Churches throughout Tuscumbia, Sheffield, Muscle Shoals, and Florence have unique scheduling needs—Sunday morning turnaround, midweek fellowship hall cleaning, holiday and special event preparation. We work around your worship schedule and can provide weekly or monthly service. Our team treats church facilities with the care and respect they deserve, including appropriate handling of sanctuary spaces and fellowship areas."
  },
  {
    question: "What's the difference between daily janitorial service and periodic deep commercial cleaning?",
    answer: "Daily or weekly janitorial service maintains baseline cleanliness—emptying trash, wiping surfaces, restocking supplies, and mopping floors. Periodic commercial deep cleaning addresses buildup that accumulates over weeks and months: grout lines in restrooms, breakroom appliance interiors, air vents and HVAC grilles, behind and under furniture, and high-touch surface biofilm that regular wiping misses. Most Shoals businesses use both: recurring janitorial for daily upkeep and quarterly deep cleaning to reset standards."
  }
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Commercial Cleaning Tuscumbia AL",
  "provider": {
    "@type": "LocalBusiness",
    "name": "The Valley Clean Team",
    "telephone": "+12568261100",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tuscumbia",
      "addressRegion": "AL",
      "addressCountry": "US"
    }
  },
  "areaServed": businessAreas.map(area => ({
    "@type": "Place",
    "name": `${area}, AL`
  })),
  "serviceType": "Commercial Cleaning",
  "description": "Professional commercial cleaning services in Tuscumbia, Alabama. Offices, medical facilities, retail throughout the Shoals."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
import BookingCTA from "../../../components/BookingCTA.astro";
---

<BaseLayout
  title="Commercial Cleaning Tuscumbia AL | Valley Clean Team"
  description="Professional commercial cleaning in Tuscumbia, Alabama. Offices, medical, retail. After-hours service. Veteran-owned, $2M insured. Call 256-826-1100"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-gray-50 to-white">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-blue-50 border border-blue-200 px-4 py-2 rounded-full mb-4">
            <span class="text-blue-700 text-sm font-medium">
              <Icon name="building" class="w-5 h-5 mr-2" />Business & Office Cleaning
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-[#333333] mb-6 leading-tight">
            Commercial Cleaning in <span class="gold-gradient">Tuscumbia, Alabama</span>
          </h1>
          <p class="text-xl text-gray-700 mb-6">
            Keep your Tuscumbia business spotless with professional commercial cleaning. From downtown offices to medical facilities throughout the Shoals, we deliver reliable cleaning that makes the right impression on employees and clients. After-hours service available.
          </p>
          
          <!-- Trust Badges -->
          <div class="flex flex-wrap gap-3 mb-6">
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="medal" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">Veteran-Owned</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="shield-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">$2M Insured</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="user-check" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">Background-Checked</span>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#quote" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full shadow-lg hover:shadow-xl transition-all">
              <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
            </a>
            <a href="tel:+12568261100" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-[#333333] bg-white border-2 border-[#FFA985] rounded-full hover:bg-[#FFA985]/10 transition-all">
              <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
            </a>
          </div>
        </div>

        <!-- Quote Form -->
        <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
          <h2 class="text-2xl font-bold text-[#333333] mb-2 text-center">Get Your Free Quote</h2>
          <p class="text-gray-600 text-center mb-6">Commercial cleaning for the Shoals</p>
          <BookingCTA city="Tuscumbia" variant="card" />
        </div>
      </div>
    </div>
  </section>

  <!-- Industries Served -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Industries We <span class="gold-gradient">Serve</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Professional cleaning for businesses of all types throughout the Shoals
      </p>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
        {industries.map((industry) => (
          <div class="bg-white rounded-xl p-4 shadow-md border border-gray-100 text-center">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mx-auto mb-3">
              <Icon name={industry.icon} class="w-6 h-6 text-[#FFA985]" />
            </div>
            <span class="text-gray-700 font-medium text-sm">{industry.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        What's Included in <span class="gold-gradient">Commercial Cleaning</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Comprehensive cleaning customized to your business
      </p>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {includedServices.map((service) => (
          <div class="flex items-center bg-white rounded-lg p-4 shadow-sm border border-gray-100">
            <Icon name="check-circle" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
            <span class="text-gray-700">{service}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-12">
        Why Shoals Businesses <span class="gold-gradient">Choose Us</span>
      </h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="moon" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Flexible Scheduling</h3>
          <p class="text-gray-600">Evening, early morning, or weekend cleaning to avoid disrupting your business operations.</p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="check-double" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Consistent Quality</h3>
          <p class="text-gray-600">Same great results every visit. Your space will always be ready for employees and clients.</p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="virus-slash" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Health-Focused</h3>
          <p class="text-gray-600">EPA-registered disinfectants and attention to high-touch surfaces for a healthier workplace.</p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="lock" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Secure & Trusted</h3>
          <p class="text-gray-600">Background-checked staff, secure access protocols, and $2M liability insurance.</p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="medal" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">Veteran-Owned</h3>
          <p class="text-gray-600">Military discipline and attention to detail. We take pride in the work we do for your business.</p>
        </div>
        
        <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
          <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
            <Icon name="file-contract" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-xl font-bold text-[#333333] mb-3">No Long Contracts</h3>
          <p class="text-gray-600">Flexible arrangements. We earn your business with quality, not legal commitments.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Commercial Cleaning Throughout <span class="gold-gradient">The Shoals</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Serving businesses throughout the Quad Cities
      </p>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-4xl mx-auto">
        {businessAreas.map((area) => (
          <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 text-center">
            <Icon name="map-marker-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
            <span class="text-gray-700 font-medium">{area}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Expert Guide -->
  <section class="py-16 px-6 bg-white">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Commercial Cleaning in Tuscumbia: <span class="gold-gradient">A Local Expert Guide</span>
      </h2>
      <div class="section-divider mb-10"></div>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-6">
        <p>
          Tuscumbia's commercial landscape is more diverse than most visitors realize. The downtown corridor along Sixth Street and around Spring Park hosts a growing collection of boutique retailers, restaurants, and professional service offices that benefit directly from the foot traffic generated by Tuscumbia's robust event calendar. Helen Keller Festival week in June alone draws thousands of visitors to the area, creating a significant window when first impressions of local businesses matter most. Commercial cleaning timed to precede major events — and restore order afterward — is a standard operating practice for downtown Tuscumbia businesses that want to present their best face during high-visibility periods.
        </p>
        <p>
          The Highway 72 corridor presents a different commercial cleaning context. Light industrial and manufacturing support offices, distribution facilities, and the commercial businesses that serve the industrial workforce along this stretch have cleaning needs that differ substantially from downtown retail. Breakrooms see heavy use from shift workers. Restrooms handle high volume. Common areas accumulate grime faster than in office environments. After-hours cleaning — either late evening after the last shift or early morning before the first — is standard for these accounts. We've built scheduling capacity specifically to handle the Colbert County industrial corridor without disrupting operations.
        </p>
        <p>
          Healthcare cleaning in the Shoals requires a different level of attention than general commercial work. Medical and dental practices throughout Tuscumbia, Muscle Shoals, Sheffield, and Florence operate under implied cleanliness standards that patients notice even when they can't articulate exactly what they're evaluating. A waiting room that feels fresh and sanitized communicates competence and professionalism before a patient has spoken to a single staff member. We use EPA-registered hospital-grade disinfectants in healthcare settings, pay particular attention to high-touch surfaces — door handles, check-in counters, armrests, payment terminals — and document our cleaning protocols for practices that maintain cleaning logs for accreditation purposes.
        </p>
        <p>
          Religious facilities across the Quad Cities — churches, fellowship halls, and ministry buildings — represent one of the most scheduling-sensitive commercial accounts we manage. The weekly rhythm of Sunday worship creates a hard deadline: the sanctuary and fellowship spaces must be clean by Sunday morning regardless of what else is happening during the week. For holidays like Christmas and Easter, where attendance can double or triple, additional pre-service cleaning is often needed. We've worked with churches in Tuscumbia, Sheffield, and Muscle Shoals long enough to understand the weight of that responsibility — getting it wrong isn't an option when hundreds of families are counting on walking into a welcoming space.
        </p>
        <p>
          The Shoals music heritage creates an unusual commercial cleaning niche that few markets can claim. Recording studios around Muscle Shoals — and the music-adjacent businesses that surround them — have specific cleaning needs: instrument storage areas that require low humidity and no aerosol products, vocal booths and control rooms where settled dust affects equipment, and common areas that maintain the creative ambiance these spaces are known for. We treat music industry commercial spaces with the same specificity we bring to medical environments: the cleaning approach is calibrated to what the space does, not just what it looks like.
        </p>
        <p>
          Consistency is what distinguishes effective commercial cleaning relationships from one-time services. The best commercial cleaning outcomes in Tuscumbia come from relationships built over months and years — where our team learns your facility's specific patterns, where buildup happens fastest, which areas need extra attention after heavy-use periods, and which surfaces require the most protection. We structure our commercial accounts to prioritize consistency: dedicated teams for recurring accounts, documented cleaning protocols, and proactive communication when we notice issues that need attention beyond our standard scope. The goal is a clean business every time we arrive, not just on the first visit.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Frequently Asked <span class="gold-gradient">Questions</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Common questions about commercial cleaning
      </p>
      
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <details class="bg-white rounded-xl shadow-md border border-gray-100 group">
            <summary class="p-6 cursor-pointer list-none flex justify-between items-center">
              <span class="font-semibold text-[#333333] pr-4">{faq.question}</span>
              <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform flex-shrink-0" />
            </summary>
            <div class="px-6 pb-6 text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-12">
        Related <span class="gold-gradient">Services</span>
      </h2>
      
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <a href="/locations/tuscumbia/deep-cleaning" class="bg-white rounded-xl p-6 shadow-md border border-gray-100 hover:border-[#FFA985] transition-all group">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mr-4">
              <Icon name="sparkles" class="w-6 h-6 text-[#FFA985]" />
            </div>
            <h3 class="text-lg font-bold text-[#333333] group-hover:text-[#FFA985]">Deep Cleaning</h3>
          </div>
          <p class="text-gray-600 text-sm">Periodic deep cleaning for commercial spaces.</p>
        </a>
        
        <a href="/locations/tuscumbia/post-construction-cleaning" class="bg-white rounded-xl p-6 shadow-md border border-gray-100 hover:border-[#FFA985] transition-all group">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mr-4">
              <Icon name="hard-hat" class="w-6 h-6 text-[#FFA985]" />
            </div>
            <h3 class="text-lg font-bold text-[#333333] group-hover:text-[#FFA985]">Post-Construction</h3>
          </div>
          <p class="text-gray-600 text-sm">Opening a new office or renovating?</p>
        </a>
        
        <a href="/locations/tuscumbia" class="bg-white rounded-xl p-6 shadow-md border border-gray-100 hover:border-[#FFA985] transition-all group">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mr-4">
              <Icon name="map-marker-alt" class="w-6 h-6 text-[#FFA985]" />
            </div>
            <h3 class="text-lg font-bold text-[#333333] group-hover:text-[#FFA985]">All Tuscumbia Services</h3>
          </div>
          <p class="text-gray-600 text-sm">Explore all our services in Tuscumbia.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-gradient-to-r from-[#FFA985] to-[#FFC67D]" id="quote">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        A Clean Business Makes the Right Impression
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Employees and clients notice cleanliness. Professional commercial cleaning keeps your Tuscumbia business looking its best.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#quote" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-[#FFA985] bg-white rounded-full shadow-lg hover:shadow-xl transition-all">
          <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
        </a>
        <a href="tel:+12568261100" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-full hover:bg-white/10 transition-all">
          <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
        </a>
      </div>
    </div>
  </section>

  </BaseLayout>

<style>
  .gold-gradient {
    background: linear-gradient(135deg, #FFA985 0%, #FFC67D 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
