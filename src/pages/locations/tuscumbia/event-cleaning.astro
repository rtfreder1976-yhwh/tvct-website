---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const city = "Tuscumbia";
const state = "Alabama";
const phone = "256-826-1100";

// Event types
const eventTypes = [
  {
    title: "Home Parties & Gatherings",
    description: "Birthdays, anniversaries, graduation celebrations, and family reunions. Get your home party-ready and enjoy hosting stress-free.",
    icon: "glass-cheers"
  },
  {
    title: "Festival Season Hosting",
    description: "Helen Keller Festival, The Miracle Worker performances, and Dickens Christmas bring visitors. Prepare your home for out-of-town guests.",
    icon: "ticket-alt"
  },
  {
    title: "Wedding & Reception Prep",
    description: "Pre-wedding cleaning for home ceremonies, reception venues, or hosting wedding guests at your Tuscumbia home.",
    icon: "heart"
  },
  {
    title: "Holiday Entertaining",
    description: "Thanksgiving, Christmas, Easter—let us handle the cleaning so you can focus on family and traditions.",
    icon: "tree"
  },
  {
    title: "Open Houses",
    description: "Selling your home? Professional cleaning creates the best first impression for potential buyers.",
    icon: "home"
  },
  {
    title: "Alabama/Auburn Game Days",
    description: "Hosting a watch party? Pre-game cleaning gets your home ready, post-game cleaning handles the aftermath.",
    icon: "football-ball"
  }
];

// Pre-event services
const preEventServices = [
  "Living areas deep cleaned",
  "Kitchen thoroughly cleaned",
  "Bathrooms sanitized & refreshed",
  "Floors vacuumed & mopped",
  "All surfaces dusted & wiped",
  "Windows & glass polished",
  "Guest bathrooms detailed",
  "Entryways & outdoor spaces"
];

// Post-event services
const postEventServices = [
  "Trash & recyclables removed",
  "Dishes washed & put away",
  "Spills & stains addressed",
  "Furniture returned to place",
  "Floors cleaned & restored",
  "Bathrooms sanitized",
  "Kitchen deep cleaned",
  "Home restored to normal"
];

// FAQs
const faqs = [
  {
    question: "How much does event cleaning cost in Tuscumbia?",
    answer: "Event cleaning pricing depends on home size and service type. Pre-event cleaning typically ranges $200-$350, post-event $150-$300. Combined packages save 10-15%. Call 256-826-1100 for a quote based on your specific event."
  },
  {
    question: "How far in advance should I book event cleaning?",
    answer: "We recommend booking 1-2 weeks in advance, especially during busy seasons like Helen Keller Festival in June or holiday periods. Last-minute requests may be accommodated based on availability."
  },
  {
    question: "Do you offer both pre-event and post-event cleaning?",
    answer: "Yes! Many Tuscumbia clients book both services. Pre-event cleaning gets your home guest-ready, and post-event cleaning restores your home afterward. Bundle both for savings."
  },
  {
    question: "Can you help prepare my home for real estate showings?",
    answer: "Absolutely! Professional cleaning before listing photos or open houses creates the best impression. We focus on the details buyers notice—sparkling bathrooms, pristine kitchens, and fresh, welcoming spaces."
  },
  {
    question: "Do you clean for Alabama and Auburn game day parties?",
    answer: "Yes! The Shoals take college football seriously. We offer pre-game cleaning to get your home party-ready and post-game cleaning to handle the aftermath of hosting. Roll Tide or War Eagle—we've got you covered!"
  },
  {
    question: "How quickly can you clean after an event?",
    answer: "We can typically schedule post-event cleaning for the next morning or same day depending on availability. Let us know your timeline when booking so we can accommodate your needs."
  },
  {
    question: "Do you clean outdoor entertaining areas?",
    answer: "Yes, we include basic outdoor cleaning for porches, patios, and entryways as part of event preparation. For extensive outdoor cleaning, let us know and we can discuss options."
  },
  {
    question: "Can I book cleaning for holiday hosting during busy seasons?",
    answer: "Yes, but book early! Thanksgiving, Christmas, and other major holidays fill up quickly. We recommend scheduling at least 2-3 weeks ahead during peak holiday periods."
  },
  {
    question: "Do you clean for Helen Keller Festival hosting in Tuscumbia?",
    answer: "Yes — the Helen Keller Festival in June is one of our busiest event-cleaning periods. Many Tuscumbia families host out-of-town guests during festival week, and we provide pre-visit deep cleaning to get guest bedrooms, bathrooms, and all common areas to company-ready standard. Book 2-3 weeks in advance during June as the festival schedule fills our Tuscumbia availability quickly."
  },
  {
    question: "Can you prepare a home for Dickens Christmas hosting?",
    answer: "Absolutely — Dickens Christmas is our busiest December event in Tuscumbia. Professional cleaning combined with your holiday decorating creates the warm, welcoming home that Shoals holiday hosting requires. We address baseboards, kitchen surfaces, bathrooms, and every area guests will see. Book by early November to secure December dates — they go fast."
  },
  {
    question: "Do you handle post-event cleaning for multi-day gatherings?",
    answer: "Yes — family reunions, multi-day holiday visits, and extended gatherings that keep your home in active hosting mode for several days are exactly the scenario our post-event cleaning is designed for. We arrive after the last guest departs and restore your home from sustained-hosting condition back to your daily baseline — kitchen deep-cleaned after days of use, bathrooms sanitized after weekend traffic, furniture returned to place."
  },
  {
    question: "Do you serve homes along Wilson Lake and in rural Colbert County?",
    answer: "Yes — lake properties and rural homes throughout Colbert County are part of our Tuscumbia event cleaning service area. Waterfront properties have specific cleaning requirements around sand, moisture, and the debris of outdoor-focused entertaining. Rural properties with larger square footage receive custom quotes. Call 256-826-1100 to discuss your property's specific needs."
  }
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Event Cleaning Tuscumbia AL",
  "provider": {
    "@type": "LocalBusiness",
    "name": "The Valley Clean Team",
    "telephone": "+12568261100",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tuscumbia",
      "addressRegion": "AL",
      "addressCountry": "US"
    }
  },
  "areaServed": {
    "@type": "Place",
    "name": "Tuscumbia, AL"
  },
  "serviceType": "Event Cleaning",
  "description": "Professional pre-event and post-event cleaning in Tuscumbia, Alabama. Parties, holidays, festivals, open houses throughout the Shoals."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
import BookingCTA from "../../../components/BookingCTA.astro";
---

<BaseLayout
  title="Event Cleaning Tuscumbia AL | Valley Clean Team"
  description="Professional event cleaning in Tuscumbia, Alabama. Pre-party, post-party, holiday hosting, open houses. Veteran-owned. Call 256-826-1100"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-gray-50 to-white">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-blue-50 border border-blue-200 px-4 py-2 rounded-full mb-4">
            <span class="text-blue-700 text-sm font-medium">
              <Icon name="glass-cheers" class="w-5 h-5 mr-2" />Pre & Post Event Cleaning
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-[#333333] mb-6 leading-tight">
            Event Cleaning in <span class="gold-gradient">Tuscumbia, Alabama</span>
          </h1>
          <p class="text-xl text-gray-700 mb-6">
            Hosting a celebration, festival guests, or holiday gathering? Our event cleaning service gets your Tuscumbia home guest-ready and handles the cleanup afterward. Enjoy your event without the stress of cleaning before or after.
          </p>
          
          <!-- Trust Badges -->
          <div class="flex flex-wrap gap-3 mb-6">
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="medal" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">Veteran-Owned</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="shield-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">$2M Insured</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="star" class="w-5 h-5 text-[#FFA985] mr-2" fill="currentColor" />
              <span class="text-sm font-semibold text-gray-700">130+ 5-Star Reviews</span>
            </div>
          </div>

          <!-- Price -->
          <div class="bg-white rounded-xl p-4 shadow-md border border-gray-100 inline-block mb-6">
            <div class="flex items-center gap-4">
              <div>
                <span class="text-sm text-gray-600">Pre-Event</span>
                <div class="text-2xl font-bold text-[#FFA985]">$200-$350</div>
              </div>
              <div class="text-gray-300">|</div>
              <div>
                <span class="text-sm text-gray-600">Post-Event</span>
                <div class="text-xl font-semibold text-gray-700">$150-$300</div>
              </div>
            </div>
            <p class="text-sm text-green-600 mt-2">
              <Icon name="tag" class="w-5 h-5 mr-1" />Bundle both & save 10-15%
            </p>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#quote" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full shadow-lg hover:shadow-xl transition-all">
              <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
            </a>
            <a href="tel:+12568261100" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-[#333333] bg-white border-2 border-[#FFA985] rounded-full hover:bg-[#FFA985]/10 transition-all">
              <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
            </a>
          </div>
        </div>

        <!-- Quote Form -->
        <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
          <h2 class="text-2xl font-bold text-[#333333] mb-2 text-center">Get Your Free Quote</h2>
          <p class="text-gray-600 text-center mb-6">Event cleaning for the Shoals</p>
          <BookingCTA city="Tuscumbia" variant="card" />
        </div>
      </div>
    </div>
  </section>

  <!-- Event Types -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Events We <span class="gold-gradient">Clean For</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Whatever you're celebrating in Tuscumbia, we'll help you host
      </p>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {eventTypes.map((event) => (
          <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
              <Icon name={event.icon} class="w-6 h-6 text-[#FFA985]" />
            </div>
            <h3 class="text-xl font-bold text-[#333333] mb-3">{event.title}</h3>
            <p class="text-gray-600">{event.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-12">
        Pre-Event & <span class="gold-gradient">Post-Event Services</span>
      </h2>
      
      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Pre-Event -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border-2 border-[#FFA985]">
          <div class="flex items-center mb-6">
            <div class="w-14 h-14 bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full flex items-center justify-center mr-4">
              <Icon name="sparkles" class="w-8 h-8 text-white" />
            </div>
            <div>
              <h3 class="text-2xl font-bold text-[#333333]">Pre-Event Cleaning</h3>
              <p class="text-gray-600">Get your home guest-ready</p>
            </div>
          </div>
          <ul class="space-y-3">
            {preEventServices.map((service) => (
              <li class="flex items-center text-gray-700">
                <Icon name="check-circle" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
                {service}
              </li>
            ))}
          </ul>
        </div>
        
        <!-- Post-Event -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="flex items-center mb-6">
            <div class="w-14 h-14 bg-gradient-to-r from-gray-400 to-gray-500 rounded-full flex items-center justify-center mr-4">
              <Icon name="broom" class="w-8 h-8 text-white" />
            </div>
            <div>
              <h3 class="text-2xl font-bold text-[#333333]">Post-Event Cleaning</h3>
              <p class="text-gray-600">We handle the aftermath</p>
            </div>
          </div>
          <ul class="space-y-3">
            {postEventServices.map((service) => (
              <li class="flex items-center text-gray-700">
                <Icon name="check-circle" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
                {service}
              </li>
            ))}
          </ul>
        </div>
      </div>
      
      <div class="text-center mt-8">
        <p class="text-lg text-[#FFA985] font-semibold">
          <Icon name="tag" class="w-5 h-5 mr-2" />Book both services and save 10-15%!
        </p>
      </div>
    </div>
  </section>

  <!-- Open House Section -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
        <div class="flex flex-col md:flex-row items-center gap-8">
          <div class="flex-shrink-0">
            <div class="w-20 h-20 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center">
              <Icon name="home" class="w-5 h-5 text-[#FFA985] text-3xl" />
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-[#333333] mb-4">Selling Your Tuscumbia Home?</h2>
            <p class="text-gray-600 mb-4">
              First impressions matter in real estate. Professional cleaning before listing photos and open houses helps your Tuscumbia home show its best. We focus on the details buyers notice—sparkling kitchens, gleaming bathrooms, and fresh, inviting spaces throughout.
            </p>
            <p class="text-gray-700 font-medium">
              Ask about our real estate preparation packages for sellers and agents!
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Expert Guide -->
  <section class="py-16 px-6 bg-white">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-3xl font-bold text-[#333333] mb-8">Event Cleaning in Tuscumbia: What Local Hosts Need to Know</h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-6">
        <p>The Helen Keller Festival brings Tuscumbia its biggest audience of the year. Your home gets its biggest audience too — if you're hosting family or out-of-town guests during festival week, those guests have opinions. Guest bedrooms need genuine deep cleaning, not a quick straightening. Bathrooms need inspection-level detail. Every common area needs to make the right impression before anyone has said hello at the door. Our event cleaning gets Tuscumbia homes to the hosting standard a week of company actually requires — and we build our June schedule around the festival calendar. Booking early for that week matters.</p>
        <p>The Miracle Worker drama season through June and July creates a second concentrated hosting wave. Families traveling to Ivy Green for the production — some returning year after year — often stay with Tuscumbia residents. Alabama summer humidity accelerates surface grime and bathroom mildew faster than hosts expect. Homes with back doors moving constantly in and out accumulate tracked-in dirt at a pace that surprises even experienced hosts. Our summer event cleaning addresses these seasonal realities specifically: not just surface presentation, but the deeper cleaning that makes a home genuinely fresh when guests are navigating Shoals heat and activity for a multi-day stay.</p>
        <p>Dickens Christmas transforms Tuscumbia each December into the area's single biggest hosting season. Your decorations do one job. Our cleaning does another. The gap between a home that looks festive and one that is also genuinely clean — baseboards wiped, kitchen surfaces detailed, bathrooms sanitized to the standard your guests actually notice — is what professional pre-event cleaning closes. Tuscumbia hosts who've used us for Dickens preparation consistently say it's the combination of their decorating and our cleaning that creates the environment they're proud of. Book by early November to secure December dates.</p>
        <p>Shoals music heritage creates an event hosting dimension that almost no other small Alabama city can claim. House concerts, music business dinners, listening sessions in homes connected to the Muscle Shoals Sound legacy — these happen in Tuscumbia. Whether you're hosting industry people or simply friends who appreciate what this community created in American popular music, your home's presentation is part of the evening. The right backdrop for a Shoals music gathering is a clean one. We make sure it is.</p>
        <p>Extended family gatherings and multi-day reunions at Wilson Lake and Spring Creek properties require post-event cleaning that goes beyond what daily hosting tidying addresses. After a full weekend of guests moving through your home — kitchen in constant use, bathrooms handling heavy traffic, common areas rearranged for the gathering — the restoration scope is different from an overnight dinner party. We arrive after the last guest departs and return your home from actively-hosting condition to the baseline you expect in your daily life. Furniture back in place. Kitchen deep-cleaned. Bathrooms sanitized. Everything the way it was, so your recovery day is actually a recovery.</p>
        <p>Alabama-Auburn game days in Tuscumbia are community events that happen in your living room. Pre-game cleaning sets the stage. Post-game cleaning handles the aftermath — the spills, the displaced furniture, the kitchen mess from a day of cooking and snacking. We handle both ends of the game day timeline so that hosting on Saturday doesn't cost you the rest of your weekend. Call 256-826-1100 to book your next Tuscumbia event clean — pre-event, post-event, or both.</p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Frequently Asked <span class="gold-gradient">Questions</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Common questions about event cleaning
      </p>
      
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <details class="bg-white rounded-xl shadow-md border border-gray-100 group">
            <summary class="p-6 cursor-pointer list-none flex justify-between items-center">
              <span class="font-semibold text-[#333333] pr-4">{faq.question}</span>
              <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform flex-shrink-0" />
            </summary>
            <div class="px-6 pb-6 text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-12">
        Related <span class="gold-gradient">Services</span>
      </h2>
      
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <a href="/locations/tuscumbia/deep-cleaning" class="bg-white rounded-xl p-6 shadow-md border border-gray-100 hover:border-[#FFA985] transition-all group">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mr-4">
              <Icon name="sparkles" class="w-6 h-6 text-[#FFA985]" />
            </div>
            <h3 class="text-lg font-bold text-[#333333] group-hover:text-[#FFA985]">Deep Cleaning</h3>
          </div>
          <p class="text-gray-600 text-sm">Thorough cleaning for special occasions.</p>
        </a>
        
        <a href="/locations/tuscumbia/recurring-maid-service" class="bg-white rounded-xl p-6 shadow-md border border-gray-100 hover:border-[#FFA985] transition-all group">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mr-4">
              <Icon name="calendar-check" class="w-6 h-6 text-[#FFA985]" />
            </div>
            <h3 class="text-lg font-bold text-[#333333] group-hover:text-[#FFA985]">Recurring Service</h3>
          </div>
          <p class="text-gray-600 text-sm">Stay party-ready all year round.</p>
        </a>
        
        <a href="/locations/tuscumbia" class="bg-white rounded-xl p-6 shadow-md border border-gray-100 hover:border-[#FFA985] transition-all group">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mr-4">
              <Icon name="map-marker-alt" class="w-6 h-6 text-[#FFA985]" />
            </div>
            <h3 class="text-lg font-bold text-[#333333] group-hover:text-[#FFA985]">All Tuscumbia Services</h3>
          </div>
          <p class="text-gray-600 text-sm">Explore all our services in Tuscumbia.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-gradient-to-r from-[#FFA985] to-[#FFC67D]" id="quote">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Focus on Your Guests, Not the Cleaning
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Let us handle the cleaning so you can enjoy hosting. From Helen Keller Festival guests to holiday gatherings, we've got your Tuscumbia home covered.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#quote" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-[#FFA985] bg-white rounded-full shadow-lg hover:shadow-xl transition-all">
          <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
        </a>
        <a href="tel:+12568261100" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-full hover:bg-white/10 transition-all">
          <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
        </a>
      </div>
      <p class="text-white/80 mt-6">
        <Icon name="star" class="w-5 h-5 mr-2" fill="currentColor" />Book early for holidays & festival season
      </p>
    </div>
  </section>

  </BaseLayout>

<style>
  .gold-gradient {
    background: linear-gradient(135deg, #FFA985 0%, #FFC67D 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
