  "Ivy Green District",
  "North Commons",
  "East Tuscumbia",
  "West Tuscumbia",
  "Cherokee",
  "Leighton",
  "Littleville",
  "Sheffield",
  "Muscle Shoals",
  "Florence"
];

// What's included
const includedServices = [
  "Remove cobwebs from all rooms",
  "Sweep/vacuum all floors (carpet + hard surfaces)",
  "Mop all hard surface floors",
  "Dust all shelves",
  "Dust blinds, windows, and window sills",
  "Wipe & clean all mirrors",
  "Wipe & clean all light switches",
  "Clean all glass surfaces",
  "Dust baseboards throughout",
  "Dust reachable ceiling fans & vents",
  "Inside/outside of microwave oven",
  "Clean kitchen backsplash",
  "Outside of stove hood",
  "Clean stovetop",
  "Wipe countertops",
  "Clean sink & chrome",
  "Exterior of kitchen cabinets & drawers",
  "Pantry floor & door",
  "Top of refrigerator",
  "Clean shower",
  "Clean tub",
  "Polish faucets",
  "Clean sinks",
  "Clean toilet and toilet area",
  "Clean bathroom counters",
  "Dust bathroom ledges",
  "Exterior of bathroom cabinets and drawers",
  "Dust bathroom doors & door frames",
  "Exterior of bedroom cabinets and drawers",
  "Dust bedroom ledges",
  "Dust bedroom doors & door frames",
  "Dust and wipe outside of washer & dryer",
  "Clean laundry room sinks",
  "Laundry room countertops",
  "Dust laundry room ledges",
  "Dust laundry room doors & door frames",
  "Dust dining room ledges",
  "Dust dining room doors & door frames",
  "Dust living room ledges",
  "Exterior of living room cabinets & drawers",
  "Dust living room doors & door frames",
  "Dust office ledges",
  "Exterior of office cabinets & drawers",
  "Dust office doors & door frames",
  "Wet wipe windows & blinds",
  "Clean inside of oven",
  "Clean inside of refrigerator",
  "Clean interior of kitchen cabinets",
  "Hand detail baseboards",
];

// FAQs
const faqs = [
  {
    question: "How much does move-out cleaning cost in Tuscumbia?",
    answer: "Move-out cleaning in Tuscumbia typically ranges from $200-$350 for apartments and average-sized homes. Larger homes may cost $350-$500+. Pricing depends on square footage, condition, and specific requirements. Call 256-826-1100 for a free quote."
  },
  {
    question: "Will move-out cleaning help me get my deposit back?",
    answer: "That's our goal! Our thorough move-out cleaning addresses everything landlords and property managers check—inside appliances, baseboards, window tracks, cabinets, and detailed bathroom cleaning. We clean to the standard expected for deposit return."
  },
  {
    question: "Do you serve the entire Quad Cities area for move-out cleaning?",
    answer: "Yes! We service move-outs throughout Tuscumbia, Sheffield, Muscle Shoals, and Florence. Whether you're leaving an apartment downtown or a house in any of the Shoals communities, we can help."
  },
  {
    question: "How far in advance should I schedule move-out cleaning?",
    answer: "We recommend booking 1-2 weeks before your move-out date, especially at month-end when demand is highest. We can sometimes accommodate last-minute requests, but advance booking guarantees your preferred date."
  },
  {
    question: "How long does move-out cleaning take?",
    answer: "Typical Tuscumbia apartments and smaller homes take 3-5 hours. Larger homes may take 5-8 hours. We provide time estimates with your quote and ensure thorough cleaning regardless of duration."
  },
  {
    question: "Do you work with Shoals property management companies?",
    answer: "Yes! We work with property managers, landlords, and real estate agents throughout Colbert County and the Quad Cities. We understand turnover timelines and inspection standards, and can coordinate directly with property managers."
  },
  {
    question: "What if the home is very dirty?",
    answer: "We can handle heavily soiled properties, though pricing may be adjusted for extreme conditions. Let us know the situation when requesting a quote, and we'll provide an accurate estimate."
  },
  {
    question: "Do you offer move-in cleaning too?",
    answer: "Absolutely! Moving into a new Tuscumbia home? We offer the same thorough cleaning to ensure your new place is spotless before you unpack. Ask about our move-in cleaning when you call."
  },
  {
    question: "What do Tuscumbia and Shoals landlords check most carefully during move-out?",
    answer: "After hundreds of move-out cleans throughout the Shoals, we've learned the consistent inspection priorities: the inside of the oven broiler drawer and under the heating element where grease accumulates, the refrigerator drip pan and coils, bathroom caulk and grout lines where Shoals humidity encourages mildew, window tracks with accumulated dust, upper kitchen cabinet interiors, and light fixture covers. These are the areas that generate the largest deposit deductions, and they're the areas our Tuscumbia move-out cleaning addresses with specific attention."
  },
  {
    question: "Does Alabama law allow landlords to deduct cleaning costs from deposits?",
    answer: "Yes — Alabama landlord-tenant law allows property managers to deduct legitimate cleaning costs from security deposits when a unit isn't returned in the condition it was rented. In the Shoals market, professional move-out cleaning that costs $200-$350 is a straightforward comparison against potential deductions of $400-$800 or more for cleaning issues that a landlord has to commission separately. The investment in professional cleaning consistently protects more deposit than it costs."
  },
  {
    question: "Can you accommodate move-out cleaning on short notice in Tuscumbia?",
    answer: "We do our best to accommodate urgent requests in Tuscumbia and the broader Shoals area. If your move-out timeline has compressed unexpectedly, call 256-826-1100 as early in the day as possible and describe your situation — we'll tell you honestly what's possible and find the earliest available slot. Advance booking of 1-2 weeks is always preferred, especially at month-end when the Shoals rental market turns over heavily and demand for move-out cleaning is at its peak."
  },
  {
    question: "Can you clean both my move-out in Tuscumbia and move-in at my new home?",
    answer: "Yes — if you're moving within the Shoals region, we can coordinate both your move-out clean in Tuscumbia and your move-in clean at your new home, whether that's in Sheffield, Muscle Shoals, Florence, or elsewhere in Colbert or Lauderdale County. Booking both services together simplifies the logistics of your move and ensures continuity: the same standard of thorough cleaning applied to the home you're leaving and the home you're arriving in. Call 256-826-1100 to discuss the coordination."
  }
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Move-Out Cleaning Tuscumbia AL",
  "provider": {
    "@type": "LocalBusiness",
    "name": "The Valley Clean Team",
    "telephone": "+12568261100",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tuscumbia",
      "addressRegion": "AL",
      "addressCountry": "US"
    }
  },
  "areaServed": neighborhoods.map(n => ({
    "@type": "Place",
    "name": `${n}, AL`
  })),
  "serviceType": "Move-Out Cleaning",
  "description": "Professional move-out cleaning services in Tuscumbia, Alabama. Get your deposit back with thorough cleaning throughout Colbert County and the Shoals."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
import BookingCTA from "../../../components/BookingCTA.astro";
---

<BaseLayout
  title="Move-Out Cleaning Tuscumbia AL | Valley Clean Team"
  description="Professional move-out cleaning in Tuscumbia, Alabama. Get your deposit back with thorough cleaning. Apartments & homes. Veteran-owned. Call 256-826-1100"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-gray-50 to-white">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-blue-50 border border-blue-200 px-4 py-2 rounded-full mb-4">
            <span class="text-blue-700 text-sm font-medium">
