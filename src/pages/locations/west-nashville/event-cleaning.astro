---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const city = "West Nashville";
const state = "Tennessee";
const phone = "(615) 961-0028";

// West Nashville neighborhoods
const neighborhoods = [
  "Belle Meade",
  "Sylvan Park",
  "The Nations",
  "West Meade",
  "Charlotte Park",
  "Sylvan Heights",
  "Cherokee Park",
  "Richland Park",
  "White Bridge",
  "Hillwood",
  "West End",
  "Green Hills"
];

// Event types
const eventTypes = [
  { name: "House Parties", icon: "glass-cheers", description: "Dinner parties, cocktail parties, birthday celebrations" },
  { name: "Holiday Entertaining", icon: "holly-berry", description: "Thanksgiving, Christmas, New Year's Eve gatherings" },
  { name: "Music Industry Events", icon: "music", description: "Album release parties, songwriter rounds, listening sessions" },
  { name: "Weddings & Receptions", icon: "heart", description: "Home weddings, rehearsal dinners, bridal showers" },
  { name: "Real Estate Open Houses", icon: "home", description: "Get Belle Meade listings show-ready" },
  { name: "Game Day Parties", icon: "football-ball", description: "Titans, Predators, Vanderbilt watch parties" }
];

// Pre-event services
const preEventServices = [
  "Deep clean living areas",
  "Kitchen & bathrooms detailed",
  "Floors vacuumed & mopped",
  "All surfaces dusted & wiped",
  "Windows & glass polished",
  "Guest bathrooms prepared",
  "Outdoor entertaining areas",
  "Entryways & foyers cleaned"
];

// Post-event services
const postEventServices = [
  "Trash & recycling removed",
  "Dishes washed & put away",
  "Spills & stains addressed",
  "Furniture returned to place",
  "Floors cleaned thoroughly",
  "Bathrooms sanitized",
  "Kitchen restored",
  "Home returned to pre-party state"
];

// FAQs
const faqs = [
  {
    question: "How much does event cleaning cost in West Nashville?",
    answer: "Pre-event cleaning typically ranges $200-$400 depending on home size. Post-event cleaning ranges $150-$350 depending on the scope. Combined packages save 10-15%. Belle Meade estates receive custom quotes. Call (615) 961-0028 for pricing."
  },
  {
    question: "How far in advance should I book pre-event cleaning?",
    answer: "We recommend booking 1-2 weeks ahead for pre-event cleaning, especially during holiday seasons. For post-event cleaning, book when you schedule your event so we can reserve your preferred time slot."
  },
  {
    question: "Do you offer both pre-event and post-event packages?",
    answer: "Yes! Many clients book both services. We'll prepare your home before guests arrive, then return after to handle cleanup. Combined packages save 10-15%."
  },
  {
    question: "Can you clean Belle Meade estates for events?",
    answer: "Absolutely! We specialize in preparing West Nashville's finest homes for entertaining. From intimate dinner parties to large gatherings, we understand the standards Belle Meade hosts expect."
  },
  {
    question: "Do you clean for real estate open houses?",
    answer: "Yes! A professionally cleaned home makes a powerful impression on buyers. We help West Nashville agents showcase properties at their best, from Belle Meade estates to Sylvan Park bungalows."
  },
  {
    question: "How quickly can you clean after an event?",
    answer: "We can often come the morning after your event or even late the same evening for smaller gatherings. Let us know your timeline and we'll accommodate."
  },
  {
    question: "Do you clean outdoor entertaining spaces?",
    answer: "Yes! Patios, decks, porches, and outdoor kitchens are included in our event cleaning. West Nashville's beautiful weather means outdoor entertaining is popular year-round."
  },
  {
    question: "Can you handle game day party cleanup?",
    answer: "Absolutely! Titans games, Predators watch parties, Vanderbilt tailgates—we've seen it all. We'll restore your home after even the most enthusiastic celebrations."
  },
  {
    question: "Do you clean for music industry events and album release parties in West Nashville?",
    answer: "Yes — Nashville's music industry creates a specific category of home event that we understand well. Album release parties, industry dinners, songwriter rounds, and listening sessions in West Nashville require a professional cleaning standard that reflects the host's professional reputation. We work with music industry professionals throughout Belle Meade, Green Hills, and the broader West Nashville area to prepare their homes for these career-significant gatherings."
  },
  {
    question: "Can you prepare our Belle Meade estate for a formal dinner party?",
    answer: "Absolutely — Belle Meade estate cleaning is a specific strength of our West Nashville event team. Formal dinner parties in Belle Meade require attention to detail that goes beyond standard cleaning: crystal and glassware areas spotless, dining and entertaining rooms immaculate, every bathroom detailed to the standard your guests expect. We've prepared some of West Nashville's finest homes for formal entertaining and understand what that standard requires."
  },
  {
    question: "Do you clean homes before real estate listing photos in West Nashville?",
    answer: "Yes — pre-listing cleaning is one of the most requested event services we provide in West Nashville. Professionally cleaned homes photograph dramatically better and make a stronger impression during showings. In Belle Meade's premium market, where listing prices demand buyers' full attention, a thoroughly cleaned home communicates care and value that buyers notice. We detail inside cabinets, appliance interiors, bathroom grout, and every area a buyer's agent will inspect."
  },
  {
    question: "How do you handle post-wedding cleanup for home receptions in West Nashville?",
    answer: "Post-wedding cleanup is one of the more intensive event cleanings we provide, and we handle it with the thoroughness and sensitivity the occasion deserves. After a home wedding or reception in West Nashville, we address the full scope: kitchen deep-cleaned from catering, dining areas restored, floors cleaned throughout, outdoor areas addressed, and every bathroom sanitized. We work quickly and professionally so the family can move into post-wedding life without the cleaning burden. Book well in advance — wedding weekends fill our schedule months ahead."
  }
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Event Cleaning West Nashville",
  "provider": {
    "@type": "LocalBusiness",
    "name": "The Valley Clean Team",
    "telephone": "+16159610028",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Nashville",
      "addressRegion": "TN",
      "addressCountry": "US"
    }
  },
  "areaServed": neighborhoods.map(n => ({
    "@type": "Place",
    "name": `${n}, Nashville, TN`
  })),
  "serviceType": "Event Cleaning",
  "description": "Professional pre-event and post-event cleaning in West Nashville. Party prep, holiday entertaining, open houses. Belle Meade, Sylvan Park, The Nations."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
import BookingCTA from "../../../components/BookingCTA.astro";
---

<BaseLayout
  title="Event Cleaning West Nashville, TN | Valley Clean Team"
  description="Professional event cleaning in West Nashville. Pre-event prep, post-party cleanup. Belle Meade, Sylvan Park, The Nations. Call (615) 961-0028"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-gray-50 to-white">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-purple-50 border border-purple-200 px-4 py-2 rounded-full mb-4">
            <span class="text-purple-700 text-sm font-medium">
              <Icon name="glass-cheers" class="w-5 h-5 mr-2" />Party Prep & Post-Event Cleanup
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-[#333333] mb-6 leading-tight">
            Event Cleaning in <span class="gold-gradient">West Nashville</span>
          </h1>
          <p class="text-xl text-gray-700 mb-6">
            Host with confidence and wake up to a clean home. Our event cleaning service handles the before and after—so you can focus on your guests. Whether it's a Belle Meade dinner party, a Nations house concert, or holiday entertaining, we make hosting stress-free.
          </p>
          
          <!-- Trust Badges -->
          <div class="flex flex-wrap gap-3 mb-6">
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="medal" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">Veteran-Owned</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="shield-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">$2M Insured</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="star" class="w-5 h-5 text-[#FFA985] mr-2" fill="currentColor" />
              <span class="text-sm font-semibold text-gray-700">130+ 5-Star Reviews</span>
            </div>
          </div>

          <!-- Price -->
          <div class="bg-white rounded-xl p-4 shadow-md border border-gray-100 inline-block mb-6">
            <div class="flex items-center gap-4">
              <div>
                <span class="text-sm text-gray-600">Pre-Event From</span>
                <div class="text-3xl font-bold text-[#FFA985]">$200</div>
              </div>
              <div class="text-gray-300">|</div>
              <div>
                <span class="text-sm text-gray-600">Post-Event From</span>
                <div class="text-2xl font-bold text-gray-700">$150</div>
              </div>
            </div>
            <p class="text-sm text-green-600 mt-2"><Icon name="tag" class="w-5 h-5 mr-1" />Combined packages save 10-15%</p>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#quote" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full shadow-lg hover:shadow-xl transition-all">
              <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
            </a>
            <a href="tel:+16159610028" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-[#333333] bg-white border-2 border-[#FFA985] rounded-full hover:bg-[#FFA985]/10 transition-all">
              <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
            </a>
          </div>
        </div>

        <!-- Quote Form -->
        <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
          <h2 class="text-2xl font-bold text-[#333333] mb-2 text-center">Get Your Free Quote</h2>
          <p class="text-gray-600 text-center mb-6">Event cleaning specialists</p>
          <BookingCTA city="West Nashville" variant="card" />
        </div>
      </div>
    </div>
  </section>

  <!-- Event Types -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Events We <span class="gold-gradient">Support</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        From intimate gatherings to major celebrations
      </p>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {eventTypes.map((event) => (
          <div class="bg-white rounded-xl p-6 shadow-md border border-gray-100">
            <div class="w-12 h-12 bg-gradient-to-r from-[#FFA985]/20 to-[#FFC67D]/20 rounded-full flex items-center justify-center mb-4">
              <Icon name={event.icon} class="w-6 h-6 text-[#FFA985]" />
            </div>
            <h3 class="text-lg font-bold text-[#333333] mb-2">{event.name}</h3>
            <p class="text-gray-600 text-sm">{event.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pre & Post Event Services -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
        <!-- Pre-Event -->
        <div>
          <h2 class="text-2xl font-bold text-[#333333] mb-6 flex items-center">
            <span class="w-10 h-10 bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full flex items-center justify-center mr-3">
              <Icon name="sparkles" class="w-5 h-5 text-white" />
            </span>
            Pre-Event Cleaning
          </h2>
          <p class="text-gray-600 mb-6">Get your home guest-ready before the party starts</p>
          <div class="space-y-3">
            {preEventServices.map((service) => (
              <div class="flex items-center bg-white rounded-lg p-3 shadow-sm border border-gray-100">
                <Icon name="check-circle" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
                <span class="text-gray-700">{service}</span>
              </div>
            ))}
          </div>
        </div>
        
        <!-- Post-Event -->
        <div>
          <h2 class="text-2xl font-bold text-[#333333] mb-6 flex items-center">
            <span class="w-10 h-10 bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full flex items-center justify-center mr-3">
              <Icon name="broom" class="w-5 h-5 text-white" />
            </span>
            Post-Event Cleanup
          </h2>
          <p class="text-gray-600 mb-6">Wake up to a clean home after the celebration</p>
          <div class="space-y-3">
            {postEventServices.map((service) => (
              <div class="flex items-center bg-white rounded-lg p-3 shadow-sm border border-gray-100">
                <Icon name="check-circle" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
                <span class="text-gray-700">{service}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas Served -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-12">
        Event Cleaning Throughout <span class="gold-gradient">West Nashville</span>
      </h2>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {neighborhoods.map((neighborhood) => (
          <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 text-center">
            <Icon name="map-marker-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
            <span class="text-gray-700 font-medium">{neighborhood}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Expert Guide -->
  <section class="py-16 px-6 bg-white">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-3xl font-bold text-[#333333] mb-8">Event Cleaning in West Nashville: The Hosting Standard for Belle Meade, Sylvan Park, and The Nations</h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-6">
        <p>West Nashville's social landscape spans a remarkable range of hosting environments, from the formal elegance of Belle Meade estates that have hosted Nashville's most prominent families for generations, to the craftsman bungalows of Sylvan Park where neighborhood dinner parties have a warmth and intimacy that's distinctly different from formal entertaining, to the converted industrial spaces and newer construction of The Nations where a younger, creative community has built a vibrant hosting culture around music, food, and the energy of Nashville's ongoing growth. Each of these environments has its own unspoken standard, and our West Nashville event cleaning service understands the difference. We calibrate our approach and our attention to detail to match what each neighborhood and each host expects — because the cleaning standard for a Belle Meade estate dinner is meaningfully different from the prep needed for a Nations house concert, and we've served both long enough to know what each requires.</p>
        <p>Nashville's music industry creates a category of event hosting that is essentially unique to this city: the album release party, the industry dinner, the songwriter round hosted at someone's home, the listening session that precedes a record launch or precedes a significant deal conversation. These gatherings bring together producers, managers, publishers, and artists in a setting that combines professional significance with personal hospitality — the host's home functions as, in a meaningful way, their professional presentation. In Belle Meade and the surrounding West Nashville neighborhoods where many music industry professionals have settled, these events happen with regularity, and the hosting standard they require is clear. A home that has been professionally cleaned — every surface detailed, bathrooms immaculate, kitchen spotless, floors done — communicates the same professional standard the host maintains in their creative and business work. Our event cleaning serves this community specifically.</p>
        <p>The West Nashville real estate market is among the most active in Davidson County, and professional cleaning for listing photos, open houses, and buyer showings represents one of the highest-return investments a seller can make before going to market. In Belle Meade, where homes routinely list at prices that make even sophisticated buyers deliberate, the condition of a property during showings affects both the pace of sale and the final number. Our pre-listing cleaning goes beyond surface presentation: we detail the inside of kitchen cabinets, clean all appliance interiors, address grout and caulk lines in bathrooms, and ensure that every area a buyer's agent will walk their client through passes both inspection and impression standards. West Nashville agents and sellers who use our pre-listing service consistently report that buyers respond differently to a professionally cleaned home — it communicates care and value that registers beyond what the listing photos can fully convey.</p>
        <p>Sylvan Park's community character — the block parties, neighborhood association gatherings, and the informal hosting culture of a neighborhood where residents know each other by name and drop by without elaborate scheduling — creates a different kind of event cleaning demand than the formal entertainment calendars of Belle Meade. In Sylvan Park, event cleaning is often a practical decision made with shorter lead time: a gathering comes together for the weekend, a home needs to be genuinely clean rather than just surface-tidied, and a host has things to do with their time besides spend Friday cleaning. Our flexible scheduling and ability to work with relatively short notice makes us the right choice for the more spontaneous hosting culture that defines Sylvan Park and similar West Nashville neighborhoods. We accommodate bookings made one to two days ahead when our schedule allows — call to check availability.</p>
        <p>Holiday entertaining in West Nashville carries the full weight of Nashville's social culture — Thanksgiving gatherings that bring multiple generations back to homes that have hosted these dinners for decades, Christmas parties in Belle Meade estates that set the community standard for what hospitality means in this part of the city, and New Year's celebrations in The Nations that reflect that neighborhood's energy and Nashville's forward momentum. The predictability of these annual events means West Nashville hosts know well in advance what they need: professional pre-event cleaning that ensures their home reflects the care and hospitality they want to project, and post-event cleaning that restores the home without requiring the host to spend the day after the celebration cleaning rather than recovering. Both services are available from our West Nashville event cleaning team, and holiday dates book out early — October and November bookings for December events are common among our regular clients.</p>
        <p>West Nashville's outdoor entertaining spaces — the porches of Sylvan Park craftsman homes that invite neighborhood gatherings, the formal gardens and grounds of Belle Meade estates that become event venues in spring and fall, and the rooftop decks and outdoor kitchens that newer construction in The Nations incorporates as standard — are an integral part of hosting in this community. Our event cleaning includes these outdoor areas as part of the full service: porch and deck surfaces cleaned, outdoor furniture wiped down, entryways swept and detailed, and the transition spaces between indoor and outdoor entertaining areas given the attention they need to maintain a seamless presentation throughout the property. Nashville's extended mild seasons mean outdoor entertaining runs from early spring well into November, making outdoor space maintenance a genuinely year-round concern for active West Nashville hosts. Call (615) 961-0028 to book your event cleaning and take the before-and-after off your hosting checklist entirely.</p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-12">
        Frequently Asked <span class="gold-gradient">Questions</span>
      </h2>
      
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <details class="bg-white rounded-xl shadow-md border border-gray-100 group">
            <summary class="p-6 cursor-pointer list-none flex justify-between items-center">
              <span class="font-semibold text-[#333333] pr-4">{faq.question}</span>
              <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform flex-shrink-0" />
            </summary>
            <div class="px-6 pb-6 text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-gradient-to-r from-[#FFA985] to-[#FFC67D]" id="quote">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Host Without the Hassle
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        We handle the before and after—you focus on your guests.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#quote" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-[#FFA985] bg-white rounded-full shadow-lg hover:shadow-xl transition-all">
          <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
        </a>
        <a href="tel:+16159610028" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-full hover:bg-white/10 transition-all">
          <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
        </a>
      </div>
    </div>
  </section>

  </BaseLayout>

<style>
  .gold-gradient {
    background: linear-gradient(135deg, #FFA985 0%, #FFC67D 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
