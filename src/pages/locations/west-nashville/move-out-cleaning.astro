---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

const city = "West Nashville";
const state = "Tennessee";
const phone = "(615) 961-0028";

// West Nashville neighborhoods
const neighborhoods = [
  "Belle Meade",
  "Sylvan Park",
  "The Nations",
  "West Meade",
  "Charlotte Park",
  "Sylvan Heights",
  "Cherokee Park",
  "Richland Park",
  "White Bridge",
  "Hillwood",
  "West End",
  "Green Hills"
];

// What's included
const includedServices = [
  "All surfaces dusted & wiped",
  "Ceiling fans & light fixtures",
  "Baseboards throughout",
  "Door frames & doors cleaned",
  "Window sills & tracks detailed",
  "Switch plates & outlets wiped",
  "Kitchen deep cleaned",
  "Inside oven & microwave",
  "Inside refrigerator & freezer",
  "Inside dishwasher",
  "Cabinets wiped inside & out",
  "Countertops sanitized",
  "Bathrooms scrubbed completely",
  "Tile & grout cleaned",
  "Toilets sanitized inside & out",
  "Mirrors & glass polished",
  "Floors vacuumed & mopped",
  "Closets cleaned out",
  "Garage swept (if applicable)"
];

// FAQs
const faqs = [
  {
    question: "How much does move-out cleaning cost in West Nashville?",
    answer: "Move-out cleaning in West Nashville typically ranges from $250-$400 for apartments and standard homes. Belle Meade estates, larger properties, and heavily soiled units are quoted individually. Call (615) 961-0028 for a free quote based on your specific property."
  },
  {
    question: "Will move-out cleaning help me get my deposit back?",
    answer: "Yes! Our thorough move-out cleaning addresses the items landlords check during inspections—inside appliances, baseboards, window tracks, cabinet interiors, and overall cleanliness. A professionally cleaned property significantly improves your chances of full deposit return."
  },
  {
    question: "How far in advance should I book move-out cleaning?",
    answer: "We recommend booking 1-2 weeks ahead, especially at month's end when demand is highest. However, we understand moves can be unpredictable and accommodate last-minute requests when possible."
  },
  {
    question: "Do you clean Belle Meade rental properties?",
    answer: "Absolutely! Whether you're leaving a Belle Meade estate, Sylvan Park rental, or The Nations apartment, we provide the same thorough service. Our $2M insurance covers properties of all values."
  },
  {
    question: "How long does move-out cleaning take?",
    answer: "Move-out cleaning typically takes 4-8 hours for standard properties. Larger homes, heavily soiled units, or properties requiring extra attention may take longer. We'll provide a time estimate with your quote."
  },
  {
    question: "Do you work with property managers?",
    answer: "Yes! We work with property managers throughout West Nashville for tenant turnovers. We offer reliable scheduling, consistent quality, and can coordinate directly with your management company."
  },
  {
    question: "What if the property is heavily soiled?",
    answer: "We can handle it! Properties requiring extra work—heavy grease buildup, neglected bathrooms, or significant cleaning challenges—receive custom quotes. We'll assess the situation and provide honest pricing."
  },
  {
    question: "Do you offer move-in cleaning too?",
    answer: "Yes! Move-in cleaning ensures your new West Nashville home is fresh and sanitized before you unpack. Same thorough service, giving you a clean start in your new space."
  },
  {
    question: "What does Tennessee law say about security deposit deductions for cleaning?",
    answer: "Tennessee landlord-tenant law allows landlords to deduct legitimate cleaning costs from security deposits when a unit isn't returned in the condition it was rented. In West Nashville's premium rental market, where deposits often run $1,500-$3,000+, professional move-out cleaning that costs $250-$400 is a straightforward investment against potential deductions of $500-$1,500 for cleaning issues. The math strongly favors professional cleaning."
  },
  {
    question: "What do West Nashville landlords check most carefully during move-out?",
    answer: "After hundreds of West Nashville move-out cleans, we know the inspection priorities: inside the oven (broiler drawer, under the element), refrigerator coils and drip pan, bathroom caulk lines where mildew grows, window tracks, upper cabinet interiors, and light fixtures. In Belle Meade and Green Hills, property managers are thorough — they check the same areas standard Nashville landlords do, but with higher cleanliness expectations for premium properties."
  },
  {
    question: "Is move-out cleaning different for Belle Meade estates versus standard apartments?",
    answer: "Yes — Belle Meade and higher-end West Nashville rentals are inspected to a premium standard. Landlords in these markets expect results that reflect the property's value. We calibrate our service accordingly: more detailed attention to luxury fixtures, stone surfaces, premium appliances, and the overall presentation standard a high-end property requires. The price reflects the property type and condition — call (615) 961-0028 to discuss your specific situation."
  },
  {
    question: "Can I get same-day or next-day move-out cleaning in West Nashville?",
    answer: "We accommodate urgent move-out timelines when the schedule allows. If you have a final walkthrough coming up faster than expected, call (615) 961-0028 as early in the day as possible. Advance booking of 1-2 weeks is strongly recommended, especially at month-end when West Nashville's active rental market means high demand for move-out cleaning. Same-day and next-day availability exists but cannot be guaranteed."
  }
];

// Schema markup
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Move-Out Cleaning West Nashville",
  "provider": {
    "@type": "LocalBusiness",
    "name": "The Valley Clean Team",
    "telephone": "+16159610028",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Nashville",
      "addressRegion": "TN",
      "addressCountry": "US"
    }
  },
  "areaServed": neighborhoods.map(n => ({
    "@type": "Place",
    "name": `${n}, Nashville, TN`
  })),
  "serviceType": "Move-Out Cleaning",
  "description": "Professional move-out cleaning in West Nashville. Get your deposit back. Belle Meade, Sylvan Park, The Nations."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
import BookingCTA from "../../../components/BookingCTA.astro";
---

<BaseLayout
  title="Move-Out Cleaning West Nashville"
  description="Professional move-out cleaning in West Nashville. Get your deposit back! Belle Meade, Sylvan Park, The Nations. Veteran-owned. Call (615) 961-0028"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-b from-gray-50 to-white">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-green-50 border border-green-200 px-4 py-2 rounded-full mb-4">
            <span class="text-green-700 text-sm font-medium">
              <Icon name="dollar-sign" class="w-5 h-5 mr-2" />Get Your Full Deposit Back
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-[#333333] mb-6 leading-tight">
            Move-Out Cleaning in <span class="gold-gradient">West Nashville</span>
          </h1>
          <p class="text-xl text-gray-700 mb-6">
            Moving is stressful enough—let us handle the cleaning. Our thorough move-out service covers everything landlords inspect: inside appliances, baseboards, window tracks, and every detail that affects your deposit. Whether you're leaving a Belle Meade estate or a Nations apartment, we'll leave it spotless.
          </p>
          
          <!-- Trust Badges -->
          <div class="flex flex-wrap gap-3 mb-6">
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="medal" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">Veteran-Owned</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="shield-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">$2M Insured</span>
            </div>
            <div class="flex items-center bg-white px-3 py-2 rounded-full shadow-sm border border-gray-200">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span class="text-sm font-semibold text-gray-700">Deposit-Back Guarantee</span>
            </div>
          </div>

          <!-- Price -->
          <div class="bg-white rounded-xl p-4 shadow-md border border-gray-100 inline-block mb-6">
            <div class="flex items-center gap-4">
              <div>
                <span class="text-sm text-gray-600">Apartments From</span>
                <div class="text-3xl font-bold text-[#FFA985]">$250</div>
              </div>
              <div class="text-gray-300">|</div>
              <div>
                <span class="text-sm text-gray-600">Average Homes</span>
                <div class="text-2xl font-bold text-gray-700">$300-$400</div>
              </div>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#quote" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white bg-gradient-to-r from-[#FFA985] to-[#FFC67D] rounded-full shadow-lg hover:shadow-xl transition-all">
              <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
            </a>
            <a href="tel:+16159610028" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-[#333333] bg-white border-2 border-[#FFA985] rounded-full hover:bg-[#FFA985]/10 transition-all">
              <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
            </a>
          </div>
        </div>

        <!-- Quote Form -->
        <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
          <h2 class="text-2xl font-bold text-[#333333] mb-2 text-center">Get Your Free Quote</h2>
          <p class="text-gray-600 text-center mb-6">Move-out cleaning specialists</p>
          <BookingCTA city="West Nashville" variant="card" />
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        What's Included in <span class="gold-gradient">Move-Out Cleaning</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Everything landlords check during move-out inspection
      </p>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {includedServices.map((service) => (
          <div class="flex items-center bg-white rounded-lg p-4 shadow-sm border border-gray-100">
            <Icon name="check-circle" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
            <span class="text-gray-700">{service}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas Served -->
  <section class="py-16 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">
        Move-Out Cleaning Throughout <span class="gold-gradient">West Nashville</span>
      </h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        From luxury rentals to urban apartments
      </p>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {neighborhoods.map((neighborhood) => (
          <div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100 text-center">
            <Icon name="map-marker-alt" class="w-5 h-5 text-[#FFA985] mr-2" />
            <span class="text-gray-700 font-medium">{neighborhood}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Expert Guide -->
  <section class="py-16 px-6 bg-white">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-3xl font-bold text-[#333333] mb-8">Move-Out Cleaning in West Nashville: What Renters in Belle Meade, Sylvan Park, and The Nations Need to Know</h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-6">
        <p>West Nashville's rental market spans one of the broadest ranges of property types and price points in all of Nashville — from the grand rental estates of Belle Meade, where monthly rents often exceed what most cities would consider annual salaries, to the craftsman bungalows of Sylvan Park that attract young professionals and established families alike, to the newer construction apartments and condos filling The Nations as that neighborhood completes its transformation from industrial district to one of Nashville's most sought-after residential areas. Each of these rental environments has its own move-out inspection standard, and the financial stakes are proportionally high across all of them. Security deposits in West Nashville routinely run $1,500 to $3,000 and higher for premium properties — which means the difference between a professional move-out clean and a landlord-conducted cleaning deduction is often measured in hundreds of dollars.</p>
        <p>Tennessee landlord-tenant law allows property managers to deduct legitimate cleaning costs from security deposits when a unit isn't returned in the condition it was rented. In practice, this means that West Nashville landlords — who are often experienced, thorough, and fully aware of what professional cleaning costs — will charge precisely for any cleaning work they need to commission after a tenant vacates. The deduction amounts they can justify for a dirty oven, a bathroom with mildew in the caulk lines, or grout that hasn't been properly cleaned are specific and documented. Our move-out cleaning addresses each of these inspection points methodically, ensuring that your landlord's walkthrough finds nothing to document as a cleaning deficiency. This is the practical difference between adequate cleaning and professionally executed move-out cleaning.</p>
        <p>After cleaning hundreds of West Nashville rental properties across Davidson County, our team has developed specific knowledge of what property managers in each neighborhood check most carefully. In Belle Meade and Green Hills, where properties are inspected by managers accustomed to luxury standards, the level of scrutiny goes beyond the basics — window tracks, the tracks of sliding glass doors, the inside of every upper cabinet, the area behind and beneath appliances, and the condition of any luxury fixtures or surfaces that may have accumulated wear during tenancy. In Sylvan Park's older craftsman homes, original hardwood floors, vintage tile, and plaster surfaces require appropriate cleaning approaches that don't create new damage while removing accumulated grime. In The Nations' newer construction, stainless appliances, quartz countertops, and modern fixtures need products matched to the material. We know these differences and bring the right approach to each.</p>
        <p>The specific areas that generate the largest security deposit deductions in West Nashville are consistent across property types: inside the oven (particularly the broiler drawer and under the heating element where cooking grease accumulates invisibly), inside the refrigerator (the drip pan at the bottom, the door gaskets, the coils in the back), bathroom caulk lines where Nashville's humidity encourages mildew growth during even a single tenancy, window tracks where years of city dust and pollen accumulate, and the interior shelves of upper kitchen cabinets that tenants rarely empty and thoroughly clean. These are the areas where our move-out cleaning focuses specific attention — not because we've been told to, but because our experience with West Nashville landlord inspections has made this knowledge operational. We know what they're looking for because we've cleaned properties they've inspected.</p>
        <p>Nashville's rental market is one of the most active in the Southeast, with significant turnover driven by the city's growth, its music and entertainment industry workforce, and the constant influx of newcomers drawn by Nashville's economic momentum. West Nashville specifically absorbs substantial rental activity because of its proximity to both downtown Nashville and the major employment corridors on the western side of the city. This turnover creates a high-volume environment for property managers, which in turn means they develop efficient inspection protocols and are not shy about applying deposit deductions for cleaning issues they document. Renters who attempt to handle their own move-out cleaning without understanding what property managers actually check frequently find that they've missed the specific areas that generate deductions — the same areas we address as a matter of standard procedure on every West Nashville move-out clean.</p>
        <p>For West Nashville renters who are relocating — whether moving across town to a larger space, transitioning to a new city for work, or leaving a furnished apartment after a short-term lease — the logistics of move-out cleaning can conflict with the rest of the moving timeline. Furniture going out while cleaning needs to happen, key return deadlines creating time pressure, and the general exhaustion of a major move can result in cleaning that is rushed and incomplete. We build our scheduling around your moving timeline specifically to eliminate this pressure: morning cleaning after your furniture is gone, evening cleaning to meet a next-day key return, or same-week emergency scheduling when the timeline compresses unexpectedly. Our goal is for West Nashville move-out cleaning to be the one element of your move that you genuinely don't have to manage. Call (615) 961-0028 to book before your date fills our schedule.</p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 bg-gray-50 px-6">
    <div class="container mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#333333] mb-12">
        Frequently Asked <span class="gold-gradient">Questions</span>
      </h2>
      
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <details class="bg-white rounded-xl shadow-md border border-gray-100 group">
            <summary class="p-6 cursor-pointer list-none flex justify-between items-center">
              <span class="font-semibold text-[#333333] pr-4">{faq.question}</span>
              <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform flex-shrink-0" />
            </summary>
            <div class="px-6 pb-6 text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-gradient-to-r from-[#FFA985] to-[#FFC67D]" id="quote">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Get Your Deposit Back
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Don't leave money on the table. Professional move-out cleaning that passes inspection.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#quote" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-[#FFA985] bg-white rounded-full shadow-lg hover:shadow-xl transition-all">
          <Icon name="calendar-check" class="w-5 h-5 mr-2" />Get Free Quote
        </a>
        <a href="tel:+16159610028" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white border-2 border-white rounded-full hover:bg-white/10 transition-all">
          <Icon name="phone" class="w-5 h-5 mr-2" />{phone}
        </a>
      </div>
    </div>
  </section>

  </BaseLayout>

<style>
  .gold-gradient {
    background: linear-gradient(135deg, #FFA985 0%, #FFC67D 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
