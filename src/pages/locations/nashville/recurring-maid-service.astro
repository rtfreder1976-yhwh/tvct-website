      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:6155101427"
          class="btn-primary px-10 py-5 rounded-full text-xl font-semibold shadow-lg"
        >
          <Icon name="phone" class="w-5 h-5 mr-2" />615-510-1427
        </a>
        <a
          href="/contact"
          class="px-10 py-5 rounded-full text-xl font-semibold border-2 border-[#333333] text-[#333333] hover:bg-[#333333] hover:text-white transition"
