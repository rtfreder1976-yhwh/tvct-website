---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SchemaMarkup from "../../../components/SchemaMarkup.astro";
import Icon from "../../../components/Icon.astro";

const faqs = [
  {
    question: "What recurring cleaning frequencies do you offer in Nashville?",
    answer:
      "We offer weekly, biweekly (every 2 weeks), and monthly recurring maid service in Nashville. Weekly cleaning keeps your home in pristine condition with 20% savings. Biweekly is our most popular option with 15% savings. Monthly works well for those who need occasional professional help with 10% savings.",
  },
  {
    question: "How much can I save with recurring maid service in Nashville?",
    answer:
      "Nashville customers save significantly with recurring service: Weekly cleaning saves up to 20%, biweekly saves 15%, and monthly saves 10% compared to one-time cleaning rates. For example, a home that costs $150 for one-time cleaning might only be $120/visit with weekly service.",
  },
  {
    question: "Is there a contract for recurring maid service?",
    answer:
      "No contracts ever! Our recurring maid service is completely flexible. Cancel or pause anytime with 48 hours notice. We believe in earning your business every visit through quality service, not locking you into agreements.",
  },
  {
    question: "Do I get the same maid every time?",
    answer:
      "Yes! We assign a dedicated cleaning team to your Nashville home. The same trusted professionals come each visit, learning your preferences and ensuring consistent quality. They'll know your home inside and out.",
  },
  {
    question: "What's included in recurring maid service?",
    answer:
      "Every recurring visit includes: dusting all surfaces, vacuuming and mopping floors, kitchen cleaning (counters, sink, appliances), bathroom sanitization, bed making, mirror cleaning, trash removal, and high-touch surface disinfection. We maintain consistent quality every single visit.",
  },
  {
    question: "Can I customize my recurring cleaning?",
    answer:
      "Absolutely! We tailor each recurring service to your needs. Want extra attention in the kitchen? Need us to skip certain rooms? Have special requests for pet areas? Just let us know and we'll customize your service plan.",
  },
  {
    question: "How do I start recurring maid service in Nashville?",
    answer:
      "Getting started is easy! Call 615-510-1427 or fill out our online form. We'll discuss your home, needs, and preferred schedule. Most clients start with a deep cleaning to establish a baseline, then begin their recurring schedule. We can often start within days.",
  },
  {
    question: "What areas of Nashville do you serve?",
    answer:
      "We serve all Nashville neighborhoods including Belle Meade, Green Hills, Sylvan Park, The Nations, 12 South, East Nashville, Germantown, West End, Hillsboro Village, Bellevue, and surrounding areas. We also serve Brentwood, Franklin, Hendersonville, Mt. Juliet, and Murfreesboro.",
  },
  {
    question: "Is biweekly or weekly cleaning better for Nashville homes with pets?",
    answer:
      "For pet owners in Nashville — particularly households with multiple pets, dogs who spend time outdoors, or cats who shed heavily — weekly cleaning is often noticeably better than biweekly. Nashville's warm climate and the activity level of an outdoor-focused city mean pet-related messes accumulate faster than in drier climates. Weekly cleaning keeps pet hair, dander, and tracked-in debris from becoming the dominant maintenance challenge, while biweekly may require more intensive attention to catch-up. We can discuss your specific pet situation and recommend the right frequency when you call.",
  },
  {
    question: "Can my Nashville recurring cleaning team work around my home's specific schedule?",
    answer:
      "Yes — scheduling flexibility is a core part of our Nashville recurring service. Whether you need morning cleaning before the workday, afternoon cleaning while kids are in school, or weekend cleaning that works with your family's rhythm, we schedule around your household's actual patterns. Music industry professionals with irregular schedules, remote workers who need specific timing around calls, and families with complex household schedules are all situations we accommodate. Your recurring schedule is built around your life, not our convenience.",
  },
  {
    question: "How does recurring maid service work in Nashville Airbnbs and short-term rentals?",
    answer:
      "If you're a Nashville Airbnb host using our recurring service to maintain your property between guests, we handle turnover cleaning as part of your scheduled service. Nashville's robust short-term rental market — driven by Music City tourism, bachelorette parties, concerts, and the general visitor appeal of one of America's most visited cities — means turnover demand can be substantial. Our recurring clients who are also hosting on Airbnb get priority scheduling coordination. Call 615-510-1427 to discuss how recurring service can be structured around your rental calendar.",
  },
  {
    question: "What makes Nashville recurring cleaning different from a one-time clean?",
    answer:
      "The difference becomes clear after two or three visits. By the third recurring visit, our team knows your home specifically: which rooms see the heaviest daily use, which surfaces need consistent attention, where dust accumulates fastest in your specific floorplan, and what your personal standards are for each area. This home-specific knowledge means recurring service becomes progressively more efficient and more tailored — each visit delivering better results in less time because your team isn't orienting themselves, they're maintaining a home they know well. One-time cleaning can never build this accumulated knowledge.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
import BookingCTA from "../../../components/BookingCTA.astro";
---

