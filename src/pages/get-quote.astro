---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Get Your Free Cleaning Quote | Valley Clean Team"
  description="Get an instant quote for house cleaning, deep cleaning, move-in/out, and more. Serving Huntsville, Athens, Florence, Nashville & surrounding areas. Takes 60 seconds."
  showNav={false}
  showFooter={false}
  schemaType="none"
>
  <style slot="preload">
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.4s ease both; }

    .trust-chip {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 0.78rem;
      color: #555;
    }
  </style>

  <!-- Header -->
  <header class="py-4 px-6 border-b border-gray-100 bg-white/95 backdrop-blur-md sticky top-0 z-50 shadow-sm">
    <div class="container mx-auto flex justify-between items-center max-w-5xl">
      <a href="/" class="inline-block">
        <picture>
          <source srcset="/images/logo.webp" type="image/webp" />
          <img src="/images/logo.png" alt="The Valley Clean Team" class="h-10 md:h-12 w-auto object-contain" width="332" height="95" fetchpriority="high" decoding="async" />
        </picture>
      </a>
      <div class="flex items-center gap-4 text-sm">
        <a href="tel:2568261100" class="hidden sm:flex items-center font-semibold text-gray-600 hover:text-[#FFA985] transition">
          <Icon name="phone" class="w-4 h-4 mr-1 text-[#FFA985]" />
          256-826-1100
        </a>
        <a href="tel:6155101427" class="hidden md:flex items-center font-semibold text-gray-600 hover:text-[#FFA985] transition">
          <Icon name="phone" class="w-4 h-4 mr-1 text-[#FFA985]" />
          615-510-1427
        </a>
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="min-h-screen bg-gradient-to-br from-gray-50 to-white py-10 px-6">
    <div class="container mx-auto max-w-xl">

      <!-- Headline -->
      <div class="text-center mb-8 fade-up">
        <h1 class="text-3xl md:text-4xl font-bold text-[#333333] mt-3 mb-3 tracking-tight">
          Your Spotless Home is 60 Seconds Away
        </h1>
        <p class="text-gray-500 text-base max-w-md mx-auto leading-relaxed">
          Skip the back-and-forth. Share your details and go straight to picking your price and time.
        </p>
      </div>

      <!-- Trust chips -->
      <div class="flex flex-wrap justify-center gap-4 mb-8 fade-up" style="animation-delay:0.05s">
        <span class="trust-chip">
          <Icon name="shield-halved" class="w-4 h-4 text-green-500" />
          Insured &amp; Bonded
        </span>
        <span class="trust-chip">
          <Icon name="star" class="w-4 h-4 text-[#FFA985]" fill="currentColor" />
          150 Five-Star Reviews
        </span>
        <span class="trust-chip">
          <Icon name="clock" class="w-4 h-4 text-blue-500" />
          We Reply in Minutes
        </span>
      </div>

      <!-- Form card — BookingKoala lead form -->
      <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-4 md:p-6 fade-up" style="animation-delay:0.1s">

        <iframe
          id="iFrameResizer0"
          style="border:0"
          src="https://thevalleycleanteam.bookingkoala.com/leads/form/4fa9fac365339ea2e313a14af815c6a78edf276f4962c9ab07613636bd067efa076d1cb13abed9c7c8e4fbcda75e4dd2c4a93ed5c34f535c7fd603d50ef85418?embed=true"
          height="1000px"
          width="100%"
          scrolling="yes"
          title="Get your free cleaning quote - The Valley Clean Team"
        ></iframe>

        <div class="flex flex-wrap items-center justify-center gap-3 mt-4">
          <span class="trust-chip justify-center font-medium bg-green-50 text-green-700 px-2 py-1 rounded-md text-[0.75rem]">
            <Icon name="shield-halved" class="w-3.5 h-3.5 text-green-600" />
            100% Satisfaction Guarantee
          </span>
          <span class="trust-chip justify-center font-medium bg-[#FFA985]/10 text-gray-700 px-2 py-1 rounded-md text-[0.75rem]">
            <Icon name="star" class="w-3.5 h-3.5 text-[#FFA985]" fill="currentColor" />
            150 5-Star Reviews
          </span>
        </div>
        <p class="text-[0.65rem] text-center text-gray-400 mt-3 uppercase tracking-wider font-bold">
          🔒 Secure &amp; No Credit Card Required
        </p>

      </div>

      <!-- Testimonial -->
      <div class="mt-8 text-center fade-up" style="animation-delay:0.15s">
        <div class="flex justify-center mb-3">
          <img src="https://ui-avatars.com/api/?name=Michelle+T&background=FFA985&color=fff&rounded=true&size=48" alt="Michelle T." class="w-12 h-12 rounded-full border-2 border-white shadow-sm" />
        </div>
        <div class="inline-flex items-center gap-1 text-yellow-400 mb-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        </div>
        <p class="text-gray-600 italic text-sm max-w-sm mx-auto">
          "They responded within 10 minutes and the pricing was exactly what they quoted. No surprises at all."
        </p>
        <p class="text-xs text-gray-400 mt-1">— Michelle T., Madison, AL &nbsp;|&nbsp; <strong class="text-gray-500">150 five-star reviews</strong></p>
      </div>

      <!-- Prefer to call -->
      <div class="mt-6 text-center fade-up" style="animation-delay:0.2s">
        <p class="text-sm text-gray-400 mb-3">Prefer to talk to someone now?</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="tel:2568261100" class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-gray-700 hover:text-[#FFA985] transition">
            <Icon name="phone" class="w-4 h-4 text-[#FFA985]" />
            Alabama: 256-826-1100
          </a>
          <a href="tel:6155101427" class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-gray-700 hover:text-[#FFA985] transition">
            <Icon name="phone" class="w-4 h-4 text-[#FFA985]" />
            Tennessee: 615-510-1427
          </a>
        </div>
      </div>

    </div>
  </main>

  <!-- BookingKoala iframe auto-resizer: lets the lead form grow/shrink to fit -->
  <script src="https://thevalleycleanteam.bookingkoala.com/resources/iframeResizer.min.js" defer></script>
</BaseLayout>
