---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Get Your Free Cleaning Quote | Valley Clean Team"
  description="Get an instant quote for house cleaning, deep cleaning, move-in/out, and more. Serving Huntsville, Athens, Florence, Nashville & surrounding areas. Takes 60 seconds."
  showNav={false}
  showFooter={false}
  schemaType="none"
>
  <style slot="preload">
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.4s ease both; }

    .step-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #FFA985;
      color: #333;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 4px 12px;
      border-radius: 999px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .field-label {
      display: block;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: #555;
      margin-bottom: 5px;
    }
    .field-input {
      width: 100%;
      padding: 12px 16px;
      border: 1.5px solid #e5e7eb;
      border-radius: 12px;
      background: #fff;
      color: #1a1a1a;
      font-size: 0.95rem;
      transition: border-color 0.2s, box-shadow 0.2s;
      box-sizing: border-box;
    }
    .field-input:focus {
      outline: none;
      border-color: #FFA985;
      box-shadow: 0 0 0 3px rgba(255, 169, 133, 0.18);
    }
    .field-input.error {
      border-color: #ef4444;
    }
    .error-msg {
      font-size: 0.75rem;
      color: #ef4444;
      margin-top: 4px;
      display: none;
    }
    .btn-submit {
      width: 100%;
      padding: 16px 24px;
      background: linear-gradient(135deg, #FFA985, #FFC67D);
      color: #333;
      font-weight: 800;
      font-size: 1.05rem;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(255, 169, 133, 0.35);
      transition: transform 0.15s, box-shadow 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(255, 169, 133, 0.45); }
    .btn-submit:active { transform: translateY(0); }
    .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
    .trust-chip {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 0.78rem;
      color: #555;
    }

    /* Radio Cards */
    .radio-card {
      position: relative;
      cursor: pointer;
      display: block;
      margin: 0;
    }
    .radio-card input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
    }
    .radio-content {
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 14px 10px;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      background: #fff;
      color: #6b7280;
      font-size: 0.85rem;
      font-weight: 700;
      line-height: 1.2;
      transition: all 0.2s ease;
      height: 100%;
    }
    .radio-card:hover .radio-content {
      border-color: #d1d5db;
    }
    .radio-card input:checked + .radio-content {
      border-color: #FFA985;
      background: rgba(255, 169, 133, 0.08);
      color: #1a1a1a;
      box-shadow: 0 2px 8px rgba(255, 169, 133, 0.15);
    }
    .radio-card input:focus-visible + .radio-content {
      box-shadow: 0 0 0 3px rgba(255, 169, 133, 0.3);
    }
  </style>

  <!-- Header -->
  <header class="py-4 px-6 border-b border-gray-100 bg-white/95 backdrop-blur-md sticky top-0 z-50 shadow-sm">
    <div class="container mx-auto flex justify-between items-center max-w-5xl">
      <a href="/" class="font-playfair text-xl md:text-2xl font-bold text-[#FFA985]">The Valley Clean Team</a>
      <div class="flex items-center gap-4 text-sm">
        <a href="tel:2568261100" class="hidden sm:flex items-center font-semibold text-gray-600 hover:text-[#FFA985] transition">
          <Icon name="phone" class="w-4 h-4 mr-1 text-[#FFA985]" />
          256-826-1100
        </a>
        <a href="tel:6155101427" class="hidden md:flex items-center font-semibold text-gray-600 hover:text-[#FFA985] transition">
          <Icon name="phone" class="w-4 h-4 mr-1 text-[#FFA985]" />
          615-510-1427
        </a>
      </div>
    </div>
  </header>

  <!-- Step progress bar -->
  <div class="bg-gray-50 border-b border-gray-200 py-3 px-6">
    <div class="container mx-auto max-w-xl flex items-center gap-3">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-full bg-[#FFA985] text-white text-xs font-bold flex items-center justify-center">1</div>
        <span class="text-sm font-semibold text-[#333]">Your Info</span>
      </div>
      <div class="flex-1 h-1 bg-gray-200 rounded mx-1">
        <div class="w-1/2 h-full bg-[#FFA985]/40 rounded"></div>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-full bg-gray-200 text-gray-400 text-xs font-bold flex items-center justify-center">2</div>
        <span class="text-sm text-gray-400">Book Your Time</span>
      </div>
    </div>
  </div>

  <!-- Main -->
  <main class="min-h-screen bg-gradient-to-br from-gray-50 to-white py-10 px-6">
    <div class="container mx-auto max-w-xl">

      <!-- Headline -->
      <div class="text-center mb-8 fade-up">
        <span class="step-pill mb-3">Step 1 of 2</span>
        <h1 class="text-3xl md:text-4xl font-bold text-[#333333] mt-3 mb-3 tracking-tight">
          Your Spotless Home is 60 Seconds Away
        </h1>
        <p class="text-gray-500 text-base max-w-md mx-auto leading-relaxed">
          Skip the back-and-forth. Tell us about your space to instantly reveal your exact price and secure your cleaning.
        </p>
      </div>

      <!-- Trust chips -->
      <div class="flex flex-wrap justify-center gap-4 mb-8 fade-up" style="animation-delay:0.05s">
        <span class="trust-chip">
          <Icon name="shield-halved" class="w-4 h-4 text-green-500" />
          Insured &amp; Bonded
        </span>
        <span class="trust-chip">
          <Icon name="star" class="w-4 h-4 text-[#FFA985]" fill="currentColor" />
          130+ Five-Star Reviews
        </span>
        <span class="trust-chip">
          <Icon name="clock" class="w-4 h-4 text-blue-500" />
          We Reply in Minutes
        </span>
      </div>

      <!-- Form card -->
      <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-7 md:p-9 fade-up" style="animation-delay:0.1s">

        <form id="quote-form" novalidate>
          <div class="space-y-5">

            <!-- Name -->
            <div>
              <label for="q-name" class="field-label">Your Name <span class="text-red-400">*</span></label>
              <input
                id="q-name"
                type="text"
                name="name"
                placeholder="Jane Smith"
                autocomplete="name"
                class="field-input"
                required
              />
              <p id="q-name-err" class="error-msg">Please enter your name.</p>
            </div>

            <!-- Email -->
            <div>
              <label for="q-email" class="field-label">Email Address <span class="text-red-400">*</span></label>
              <input
                id="q-email"
                type="email"
                name="email"
                placeholder="jane@example.com"
                autocomplete="email"
                class="field-input"
                required
              />
              <p id="q-email-err" class="error-msg">Please enter a valid email address.</p>
            </div>

            <!-- Phone -->
            <div>
              <label for="q-phone" class="field-label">Phone Number <span class="text-red-400">*</span></label>
              <input
                id="q-phone"
                type="tel"
                name="phone"
                placeholder="(256) 555-0123"
                autocomplete="tel"
                class="field-input"
                required
              />
              <p class="text-[0.7rem] text-gray-400 mt-1">We respect your privacy. Used only for your quote.</p>
              <p id="q-phone-err" class="error-msg">Please enter a valid phone number.</p>
            </div>

            <!-- Type of Cleaning -->
            <fieldset>
              <legend class="field-label mb-2">Type of Cleaning <span class="text-red-400">*</span></legend>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <label class="radio-card">
                  <input type="radio" name="service" value="Standard House Cleaning" required />
                  <div class="radio-content">Standard<br class="hidden sm:inline"> Cleaning</div>
                </label>
                <label class="radio-card">
                  <input type="radio" name="service" value="Deep Cleaning" />
                  <div class="radio-content">Deep<br class="hidden sm:inline"> Cleaning</div>
                </label>
                <label class="radio-card">
                  <input type="radio" name="service" value="Move-In / Move-Out Cleaning" />
                  <div class="radio-content">Move-In /<br class="hidden sm:inline"> Move-Out</div>
                </label>
                <label class="radio-card">
                  <input type="radio" name="service" value="Commercial Cleaning" />
                  <div class="radio-content">Office /<br class="hidden sm:inline"> Commercial</div>
                </label>
                <label class="radio-card sm:col-span-2">
                  <input type="radio" name="service" value="Other" />
                  <div class="radio-content">Other / Not Sure</div>
                </label>
              </div>
              <p id="q-service-err" class="error-msg mt-2">Please select a service type.</p>
            </fieldset>

            <!-- Square Footage -->
            <fieldset>
              <legend class="field-label mb-2">Estimated Square Footage <span class="text-red-400">*</span></legend>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <label class="radio-card">
                  <input type="radio" name="sqft" value="1000" required />
                  <div class="radio-content">Under<br class="hidden sm:inline"> 1,000 sq ft</div>
                </label>
                <label class="radio-card">
                  <input type="radio" name="sqft" value="2000" />
                  <div class="radio-content">1,000 -<br class="hidden sm:inline"> 2,000 sq ft</div>
                </label>
                <label class="radio-card">
                  <input type="radio" name="sqft" value="3000" />
                  <div class="radio-content">2,000 -<br class="hidden sm:inline"> 3,000 sq ft</div>
                </label>
                <label class="radio-card">
                  <input type="radio" name="sqft" value="4000" />
                  <div class="radio-content">3,000 -<br class="hidden sm:inline"> 4,000 sq ft</div>
                </label>
                <label class="radio-card sm:col-span-2">
                  <input type="radio" name="sqft" value="5000" />
                  <div class="radio-content">Over 4,000 sq ft</div>
                </label>
              </div>
              <p id="q-sqft-err" class="error-msg mt-2">Please select your estimated square footage.</p>
            </fieldset>

            <!-- Submit -->
            <div class="pt-2">
              <button type="submit" id="q-submit" class="btn-submit">
                <svg id="q-icon-arrow" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
                <svg id="q-icon-spinner" class="w-5 h-5 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
                </svg>
                Reveal My Price &amp; Schedule Now
              </button>
              <div class="flex flex-wrap items-center justify-center gap-3 mt-4">
                <span class="trust-chip justify-center font-medium bg-green-50 text-green-700 px-2 py-1 rounded-md text-[0.75rem]">
                  <Icon name="shield-halved" class="w-3.5 h-3.5 text-green-600" />
                  100% Satisfaction Guarantee
                </span>
                <span class="trust-chip justify-center font-medium bg-[#FFA985]/10 text-gray-700 px-2 py-1 rounded-md text-[0.75rem]">
                  <Icon name="star" class="w-3.5 h-3.5 text-[#FFA985]" fill="currentColor" />
                  130+ 5-Star Reviews
                </span>
              </div>
              <p class="text-[0.65rem] text-center text-gray-400 mt-3 uppercase tracking-wider font-bold">
                🔒 Secure &amp; No Credit Card Required
              </p>
            </div>

          </div>
        </form>

        <!-- Success state (hidden until submit) -->
        <div id="q-success" class="hidden text-center py-4">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
            <svg class="w-7 h-7 text-green-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#333] mb-2">Got it — taking you to booking now!</h3>
          <p class="text-gray-500 text-sm">Redirecting you to pick your date and time…</p>
        </div>

      </div>

      <!-- Testimonial -->
      <div class="mt-8 text-center fade-up" style="animation-delay:0.15s">
        <div class="flex justify-center mb-3">
          <img src="https://ui-avatars.com/api/?name=Michelle+T&background=FFA985&color=fff&rounded=true&size=48" alt="Michelle T." class="w-12 h-12 rounded-full border-2 border-white shadow-sm" />
        </div>
        <div class="inline-flex items-center gap-1 text-yellow-400 mb-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        </div>
        <p class="text-gray-600 italic text-sm max-w-sm mx-auto">
          "They responded within 10 minutes and the pricing was exactly what they quoted. No surprises at all."
        </p>
        <p class="text-xs text-gray-400 mt-1">— Michelle T., Madison, AL &nbsp;|&nbsp; <strong class="text-gray-500">130+ five-star reviews</strong></p>
      </div>

      <!-- Prefer to call -->
      <div class="mt-6 text-center fade-up" style="animation-delay:0.2s">
        <p class="text-sm text-gray-400 mb-3">Prefer to talk to someone now?</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <a href="tel:2568261100" class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-gray-700 hover:text-[#FFA985] transition">
            <Icon name="phone" class="w-4 h-4 text-[#FFA985]" />
            Alabama: 256-826-1100
          </a>
          <a href="tel:6155101427" class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-gray-700 hover:text-[#FFA985] transition">
            <Icon name="phone" class="w-4 h-4 text-[#FFA985]" />
            Tennessee: 615-510-1427
          </a>
        </div>
      </div>

    </div>
  </main>

  <script is:inline>
    (function () {
      var form      = document.getElementById('quote-form');
      var success   = document.getElementById('q-success');
      var submitBtn = document.getElementById('q-submit');
      var spinner   = document.getElementById('q-icon-spinner');
      var arrow     = document.getElementById('q-icon-arrow');

      function show(id) { var el = document.getElementById(id); if (el) el.style.display = 'block'; }
      function hide(id) { var el = document.getElementById(id); if (el) el.style.display = 'none'; }
      function val(id)  { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function valRadio(name) { var el = document.querySelector('input[name="' + name + '"]:checked'); return el ? el.value : ''; }
      function markError(inputId, errId, show_err) {
        var input = document.getElementById(inputId);
        var err   = document.getElementById(errId);
        if (!input || !err) return;
        if (show_err) {
          input.classList.add('error');
          err.style.display = 'block';
        } else {
          input.classList.remove('error');
          err.style.display = 'none';
        }
      }
      function markGroupError(errId, show_err) {
        var err = document.getElementById(errId);
        if (err) err.style.display = show_err ? 'block' : 'none';
      }

      function isValidEmail(e) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }
      function isValidPhone(p) { return p.replace(/\D/g, '').length >= 10; }

      // Phone formatting
      var phoneInput = document.getElementById('q-phone');
      if (phoneInput) {
        phoneInput.addEventListener('input', function (e) {
          var x = e.target.value.replace(/\D/g, '').match(/(\d{0,3})(\d{0,3})(\d{0,4})/);
          e.target.value = !x[2] ? x[1] : '(' + x[1] + ') ' + x[2] + (x[3] ? '-' + x[3] : '');
        });
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();

        var name    = val('q-name');
        var email   = val('q-email');
        var phone   = val('q-phone');
        var service = valRadio('service');
        var sqft    = valRadio('sqft');

        var valid = true;
        markError('q-name',    'q-name-err',    !name);                      if (!name)                      valid = false;
        markError('q-email',   'q-email-err',   !isValidEmail(email));       if (!isValidEmail(email))       valid = false;
        markError('q-phone',   'q-phone-err',   !isValidPhone(phone));       if (!isValidPhone(phone))       valid = false;
        markGroupError('q-service-err', !service);                           if (!service)                   valid = false;
        markGroupError('q-sqft-err',    !sqft);                              if (!sqft)                      valid = false;

        if (!valid) return;

        // Show spinner
        submitBtn.disabled = true;
        if (spinner) spinner.classList.remove('hidden');
        if (arrow)   arrow.classList.add('hidden');

        var payload = {
          name:          name,
          email:         email,
          phone:         phone,
          service:       service,
          square_footage: sqft ? parseInt(sqft, 10) : 0,
          source:        'Get Quote Form',
          page_url:      window.location.href,
          notes:         'Quote form submission — Step 1'
        };

        // Fire GA4 lead event
        if (typeof gtag === 'function') {
          gtag('event', 'generate_lead', {
            event_category: 'Lead',
            event_label:    'Get Quote Form',
            value:          1
          });
        }
        // Fire Meta Pixel
        if (typeof fbq === 'function') {
          fbq('track', 'Lead', { content_name: 'Get Quote Form' });
        }

        fetch('/api/submit-form', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(payload),
          keepalive: true
        })
          .catch(function () {}) // never block redirect on API error
          .finally(function () {
            // Show success, then redirect to booking
            form.style.display = 'none';
            if (success) success.classList.remove('hidden');
            setTimeout(function () {
              window.location.href = '/booking';
            }, 2500);
          });
      });

      // Clear error state on input
      ['q-name','q-email','q-phone'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('input', function () { markError(id, id + '-err', false); });
      });
      document.querySelectorAll('input[name="service"]').forEach(function(el) {
        el.addEventListener('change', function() { markGroupError('q-service-err', false); });
      });
      document.querySelectorAll('input[name="sqft"]').forEach(function(el) {
        el.addEventListener('change', function() { markGroupError('q-sqft-err', false); });
      });
    })();
  </script>
</BaseLayout>
