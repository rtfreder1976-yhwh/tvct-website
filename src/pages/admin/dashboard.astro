---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

// ---------------------------------------------------------------------------
// Admin authentication — checks for a secret cookie or ?key= query param.
// Set ADMIN_SECRET in your Vercel environment variables.
// To log in: visit /admin/dashboard?key=YOUR_SECRET (sets a session cookie).
// ---------------------------------------------------------------------------
const ADMIN_SECRET = import.meta.env.ADMIN_SECRET;

function isAuthorized(): boolean {
    if (!ADMIN_SECRET) return false; // Deny all if not configured

    // Check query param (used for initial login link)
    const queryKey = Astro.url.searchParams.get('key');
    if (queryKey && queryKey === ADMIN_SECRET) return true;

    // Check session cookie (set on first auth)
    const cookie = Astro.request.headers.get('cookie') ?? '';
    const adminCookie = cookie
        .split(';')
        .map(c => c.trim())
        .find(c => c.startsWith('admin_session='));
    return adminCookie?.split('=')[1] === ADMIN_SECRET;
}

if (!isAuthorized()) {
    return new Response('Unauthorized — visit /admin/dashboard?key=YOUR_ADMIN_SECRET to log in.', {
        status: 401,
        headers: { 'Content-Type': 'text/plain' },
    });
}

// Set session cookie on first auth so the dashboard stays accessible (8-hour expiry)
const keyFromQuery = Astro.url.searchParams.get('key');
if (keyFromQuery) {
    Astro.response.headers.set(
        'Set-Cookie',
        `admin_session=${ADMIN_SECRET}; HttpOnly; Secure; SameSite=Strict; Path=/admin; Max-Age=28800`
    );
}

// ---------------------------------------------------------------------------
// Live data: parallel fetch from all three API routes
// ---------------------------------------------------------------------------

function detectMarket(keyword: string, url: string = ''): string {
  const text = (keyword + ' ' + url).toLowerCase();
  if (text.includes('huntsville') || text.includes('madison') || text.includes('hampton cove')) return 'huntsville';
  if (text.includes('athens')) return 'athens';
  if (text.includes('florence') || text.includes('shoals') || text.includes('tuscumbia') || text.includes('sheffield')) return 'florence';
  if (text.includes('mountain brook') || text.includes('birmingham')) return 'birmingham';
  if (text.includes('nashville') || text.includes('brentwood') || text.includes('franklin')) return 'nashville';
  return 'huntsville';
}

function buildWeekLabels(count: number): string[] {
  const labels: string[] = [];
  const now = new Date();
  for (let i = count - 1; i >= 0; i--) {
    const d = new Date(now);
    d.setDate(d.getDate() - i * 7);
    labels.push(`${d.toLocaleString('default', { month: 'short' })} ${d.getDate()}`);
  }
  return labels;
}

const origin = Astro.url.origin;

const [rankingsResult, trafficResult, leadsResult] = await Promise.allSettled([
  fetch(`${origin}/api/rankings`).then(r => r.json()),
  fetch(`${origin}/api/traffic`).then(r => r.json()),
  fetch(`${origin}/api/leads`).then(r => r.json()),
]);

const rankingsData = rankingsResult.status === 'fulfilled' && rankingsResult.value?.success
  ? rankingsResult.value.data : null;
const trafficData  = trafficResult.status  === 'fulfilled' && trafficResult.value?.success
  ? trafficResult.value.data  : null;
const leadsData    = leadsResult.status    === 'fulfilled' && leadsResult.value?.success
  ? leadsResult.value.data    : null;

// Track data source status for each section
// 'live' = real data from external API
// 'fallback' = credentials missing or API error, using static defaults
// 'offline' = our own API route failed entirely
const rankingsSource = rankingsResult.status === 'fulfilled' ? (rankingsResult.value?.success ? 'live' : 'fallback') : 'offline';
const trafficSource  = trafficResult.status  === 'fulfilled' ? (trafficResult.value?.success  ? 'live' : 'fallback') : 'offline';
const leadsSource    = leadsResult.status    === 'fulfilled' ? (leadsResult.value?.source ?? (leadsResult.value?.success ? 'live' : 'fallback')) : 'offline';

const dataStatus: Record<string, 'live' | 'fallback' | 'offline'> = {
  rankings: rankingsSource as 'live' | 'fallback' | 'offline',
  traffic:  trafficSource  as 'live' | 'fallback' | 'offline',
  leads:    leadsSource    as 'live' | 'fallback' | 'offline',
};

// ---- Rankings ----
const rawRankings = rankingsData?.items ?? [];
const rankings = rawRankings.map((k: any) => {
  const pos = parseFloat(k.position);
  const change = k.change ?? 0;
  return {
    keyword: k.keyword,
    position: pos,
    previous: parseFloat((pos - change).toFixed(1)),
    change,
    market: detectMarket(k.keyword, k.url ?? ''),
    volume: typeof k.volume === 'string' ? parseInt(k.volume.replace(/,/g, ''), 10) || 0 : (k.volume ?? 0),
  };
}) || [
  { keyword: "cleaning service huntsville al", position: 4, previous: 6, change: 2, market: "huntsville", volume: 720 },
  { keyword: "house cleaning huntsville", position: 7, previous: 8, change: 1, market: "huntsville", volume: 480 },
  { keyword: "cleaning service athens al", position: 2, previous: 3, change: 1, market: "athens", volume: 170 },
  { keyword: "cleaning service florence al", position: 5, previous: 4, change: -1, market: "florence", volume: 210 },
  { keyword: "cleaning service nashville tn", position: 28, previous: 35, change: 7, market: "nashville", volume: 1900 },
];

const rankingSummary = rankingsData ? {
  total: rankings.length,
  avgPosition: parseFloat(rankingsData.avgPosition) || 0,
  top3: rankings.filter((k: any) => k.position <= 3).length,
  top10: rankings.filter((k: any) => k.position <= 10).length,
  improved: rankings.filter((k: any) => k.change > 0).length,
  declined: rankings.filter((k: any) => k.change < 0).length,
} : { total: 12, avgPosition: 7.4, top3: 4, top10: 10, improved: 9, declined: 1 };

// ---- Traffic ----
const currentSessions  = trafficData?.current?.sessions  ?? 1020;
const previousSessions = trafficData?.previous?.sessions ?? 910;
const currentOrganic   = trafficData?.current?.organic   ?? Math.round(currentSessions * 0.65);
const previousOrganic  = Math.round(previousSessions * 0.65);
const sessionsChange   = previousSessions > 0
  ? parseFloat(((currentSessions - previousSessions) / previousSessions * 100).toFixed(1)) : 0;
const organicChange    = previousOrganic > 0
  ? parseFloat(((currentOrganic - previousOrganic) / previousOrganic * 100).toFixed(1)) : 0;

const traffic = {
  current:  { sessions: currentSessions, organic: currentOrganic, bounceRate: parseFloat(trafficData?.current?.bounceRate ?? '42.3') },
  previous: { sessions: previousSessions, organic: previousOrganic },
  change:   { sessions: sessionsChange, organic: organicChange },
};

// Build weekly trend from daily array (30 days → 4 weeks)
const dailyTrend: number[] = trafficData?.monthlyTrend ?? [];
const weekLabels = buildWeekLabels(4);
const trafficTrend = weekLabels.map((week, i) => {
  const start = Math.max(0, dailyTrend.length - (4 - i) * 7);
  const end   = Math.max(0, dailyTrend.length - (3 - i) * 7);
  const weekSessions = dailyTrend.slice(start, end).reduce((a: number, b: number) => a + b, 0) || [850, 890, 950, currentSessions][i];
  return { week, sessions: weekSessions, organic: Math.round(weekSessions * (currentOrganic / Math.max(currentSessions, 1))) };
});

// ---- Leads ----
const leads = {
  current:  {
    total:      leadsData?.totalLeads ?? 26,
    quoteForms: leadsData?.quoteForms ?? 16,
    phoneCalls: leadsData?.phoneCalls ?? 8,
    chat:       leadsData?.chat       ?? 2,
  },
  previous: { total: leadsData?.previousTotal ?? 22 },
  change:   leadsData?.change ?? 18.2,
  byMarket: leadsData?.byMarket ?? { huntsville: 12, athens: 5, florence: 4, birmingham: 3, nashville: 2 },
};

const leadsWeekly: number[] = leadsData?.weeklyTrend ?? [18, 20, 24, leads.current.total];
const leadsTrend = weekLabels.map((week, i) => ({
  week,
  total: leadsWeekly[i] ?? 0,
  converted: Math.round((leadsWeekly[i] ?? 0) * 0.35),
}));

// ---- Conversions (static — no automated source yet) ----
const conversions = {
  leadToQuote:    72.5,
  quoteToBooked:  45.2,
  overall:        32.8,
  avgDealValue:   185,
  monthlyRevenue: 12850,
};

// ---- Competitors (static — no automated source) ----
const competitors = [
  { name: "Molly Maid Huntsville",   avgPosition: 5.2, keywords: 45,  reviews: 89,  rating: 4.6, trend: "stable" },
  { name: "Merry Maids Birmingham",  avgPosition: 6.8, keywords: 38,  reviews: 124, rating: 4.4, trend: "down"   },
  { name: "Clean Sweep AL",          avgPosition: 8.5, keywords: 22,  reviews: 45,  rating: 4.8, trend: "up"     },
];

// ---- Alerts: auto-generate from live data ----
const alerts: { type: string; message: string; date: string }[] = [];
if (sessionsChange > 5)  alerts.push({ type: "success", message: `Organic traffic up ${organicChange}% vs last period`, date: "Today" });
if (sessionsChange < -5) alerts.push({ type: "warning", message: `Traffic down ${Math.abs(sessionsChange)}% vs last period`, date: "Today" });
const topGainer = [...rankings].filter((k: any) => k.change > 0).sort((a: any, b: any) => b.change - a.change)[0];
if (topGainer) alerts.push({ type: "success", message: `↑${topGainer.change} positions: "${topGainer.keyword}" now #${topGainer.position}`, date: "This period" });
const topLoser = [...rankings].filter((k: any) => k.change < 0).sort((a: any, b: any) => a.change - b.change)[0];
if (topLoser)  alerts.push({ type: "warning", message: `↓${Math.abs(topLoser.change)} positions: "${topLoser.keyword}" now #${topLoser.position}`, date: "This period" });
if (leadsData?.change > 10) alerts.push({ type: "success", message: `Leads up ${leadsData.change}% vs last 30 days`, date: "Today" });
if (!alerts.length) alerts.push({ type: "info", message: "All metrics stable — no significant changes detected", date: "Today" });

const dashboardData = {
  generated_at: new Date().toISOString(),
  period: "Last 30 Days",
  rankings,
  rankingSummary,
  traffic,
  trafficTrend,
  leads,
  leadsTrend,
  conversions,
  competitors,
  alerts,
};

const marketColors: Record<string, string> = {
  huntsville: "bg-blue-100 text-blue-800",
  athens: "bg-green-100 text-green-800",
  florence: "bg-purple-100 text-purple-800",
  birmingham: "bg-orange-100 text-orange-800",
  nashville: "bg-pink-100 text-pink-800",
};
---

<BaseLayout
  title="SEO Dashboard | Admin"
  description="Internal SEO and business metrics dashboard"
  noindex={true}
  showNav={false}
  showFooter={false}
>
  <div class="min-h-screen bg-gray-100">
    <!-- Header -->
    <header class="bg-[#333] text-white px-6 py-4">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold">The Valley Clean Team</h1>
          <p class="text-gray-400 text-sm">SEO & Business Dashboard</p>
        </div>
        <div class="text-right text-sm">
          <p class="text-gray-400 mb-2">Last updated {new Date().toLocaleDateString()}</p>
          <!-- Data source status indicators -->
          <div class="flex gap-2 justify-end">
            {Object.entries({ rankings: 'GSC', traffic: 'GA4', leads: 'GHL' }).map(([key, label]) => {
              const status = dataStatus[key];
              return (
                <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium ${
                  status === 'live'     ? 'bg-green-500/20 text-green-300 border border-green-500/30' :
                  status === 'fallback' ? 'bg-yellow-500/20 text-yellow-300 border border-yellow-500/30' :
                                          'bg-red-500/20 text-red-300 border border-red-500/30'
                }`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${
                    status === 'live' ? 'bg-green-400' : status === 'fallback' ? 'bg-yellow-400' : 'bg-red-400'
                  }`}></span>
                  {label} {status === 'live' ? 'Live' : status === 'fallback' ? 'Fallback' : 'Offline'}
                </span>
              );
            })}
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8">
      <!-- Alerts -->
      {dashboardData.alerts.length > 0 && (
        <div class="mb-8 space-y-2">
          {dashboardData.alerts.map((alert) => (
            <div class={`p-3 rounded-lg flex items-center gap-3 ${
              alert.type === 'success' ? 'bg-green-50 text-green-800 border border-green-200' :
              alert.type === 'warning' ? 'bg-yellow-50 text-yellow-800 border border-yellow-200' :
              'bg-blue-50 text-blue-800 border border-blue-200'
            }`}>
              <span class="text-lg">
                {alert.type === 'success' ? '↑' : alert.type === 'warning' ? '↓' : 'ℹ'}
              </span>
              <span class="flex-1">{alert.message}</span>
              <span class="text-sm opacity-70">{alert.date}</span>
            </div>
          ))}
        </div>
      )}

      <!-- KPI Cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <p class="text-gray-500 text-sm">Avg Position</p>
          <p class="text-3xl font-bold text-[#333]">{dashboardData.rankingSummary.avgPosition}</p>
          <p class="text-green-600 text-sm">Top 10: {dashboardData.rankingSummary.top10}</p>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <p class="text-gray-500 text-sm">Weekly Sessions</p>
          <p class="text-3xl font-bold text-[#333]">{dashboardData.traffic.current.sessions.toLocaleString()}</p>
          <p class="text-green-600 text-sm">+{dashboardData.traffic.change.sessions}%</p>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <p class="text-gray-500 text-sm">Organic Traffic</p>
          <p class="text-3xl font-bold text-[#333]">{dashboardData.traffic.current.organic.toLocaleString()}</p>
          <p class="text-green-600 text-sm">+{dashboardData.traffic.change.organic}%</p>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <p class="text-gray-500 text-sm">Weekly Leads</p>
          <p class="text-3xl font-bold text-[#333]">{dashboardData.leads.current.total}</p>
          <p class="text-green-600 text-sm">+{dashboardData.leads.change}%</p>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <p class="text-gray-500 text-sm">Conversion Rate</p>
          <p class="text-3xl font-bold text-[#333]">{dashboardData.conversions.overall}%</p>
          <p class="text-gray-500 text-sm">Lead → Booked</p>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <p class="text-gray-500 text-sm">Monthly Revenue</p>
          <p class="text-3xl font-bold text-[#333]">${dashboardData.conversions.monthlyRevenue.toLocaleString()}</p>
          <p class="text-gray-500 text-sm">Avg: ${dashboardData.conversions.avgDealValue}</p>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 mb-8">
        <!-- Keyword Rankings -->
        <div class="bg-white rounded-xl shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
            <h2 class="text-lg font-bold text-[#333]">Keyword Rankings</h2>
            <div class="flex gap-2 text-sm">
              <span class="text-green-600">↑{dashboardData.rankingSummary.improved}</span>
              <span class="text-red-600">↓{dashboardData.rankingSummary.declined}</span>
            </div>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-2 text-left text-gray-600">Keyword</th>
                  <th class="px-4 py-2 text-center text-gray-600">Pos</th>
                  <th class="px-4 py-2 text-center text-gray-600">Change</th>
                  <th class="px-4 py-2 text-center text-gray-600">Vol</th>
                </tr>
              </thead>
              <tbody>
                {dashboardData.rankings.map((kw) => (
                  <tr class="border-b border-gray-50 hover:bg-gray-50">
                    <td class="px-4 py-3">
                      <span class="block">{kw.keyword}</span>
                      <span class={`text-xs px-2 py-0.5 rounded ${marketColors[kw.market]}`}>
                        {kw.market}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class={`font-bold ${kw.position <= 3 ? 'text-green-600' : kw.position <= 10 ? 'text-blue-600' : 'text-gray-600'}`}>
                        {kw.position}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                      {kw.change > 0 ? (
                        <span class="text-green-600 font-medium">↑{kw.change}</span>
                      ) : kw.change < 0 ? (
                        <span class="text-red-600 font-medium">↓{Math.abs(kw.change)}</span>
                      ) : (
                        <span class="text-gray-400">-</span>
                      )}
                    </td>
                    <td class="px-4 py-3 text-center text-gray-500">{kw.volume}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Traffic & Leads Chart -->
        <div class="space-y-8">
          <!-- Traffic Trend -->
          <div class="bg-white rounded-xl shadow-sm p-6">
            <h2 class="text-lg font-bold text-[#333] mb-4">Traffic Trend</h2>
            <div class="h-48 flex items-end gap-2">
              {dashboardData.trafficTrend.map((week) => (
                <div class="flex-1 flex flex-col items-center">
                  <div class="w-full flex flex-col gap-1">
                    <div
                      class="bg-[#FFA985] rounded-t"
                      style={`height: ${(week.sessions / 1200) * 150}px`}
                      title={`Sessions: ${week.sessions}`}
                    />
                    <div
                      class="bg-blue-400 rounded-b"
                      style={`height: ${(week.organic / 1200) * 150}px`}
                      title={`Organic: ${week.organic}`}
                    />
                  </div>
                  <span class="text-xs text-gray-500 mt-2">{week.week}</span>
                </div>
              ))}
            </div>
            <div class="flex gap-4 mt-4 text-sm">
              <span class="flex items-center gap-2">
                <span class="w-3 h-3 bg-[#FFA985] rounded"></span> Sessions
              </span>
              <span class="flex items-center gap-2">
                <span class="w-3 h-3 bg-blue-400 rounded"></span> Organic
              </span>
            </div>
          </div>

          <!-- Leads by Source -->
          <div class="bg-white rounded-xl shadow-sm p-6">
            <h2 class="text-lg font-bold text-[#333] mb-4">Leads by Source</h2>
            <div class="space-y-3">
              <div class="flex items-center">
                <span class="w-24 text-sm text-gray-600">Quote Forms</span>
                <div class="flex-1 h-6 bg-gray-100 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-[#FFA985]"
                    style={`width: ${(dashboardData.leads.current.quoteForms / dashboardData.leads.current.total) * 100}%`}
                  />
                </div>
                <span class="w-12 text-right text-sm font-medium">{dashboardData.leads.current.quoteForms}</span>
              </div>
              <div class="flex items-center">
                <span class="w-24 text-sm text-gray-600">Phone Calls</span>
                <div class="flex-1 h-6 bg-gray-100 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-blue-400"
                    style={`width: ${(dashboardData.leads.current.phoneCalls / dashboardData.leads.current.total) * 100}%`}
                  />
                </div>
                <span class="w-12 text-right text-sm font-medium">{dashboardData.leads.current.phoneCalls}</span>
              </div>
              <div class="flex items-center">
                <span class="w-24 text-sm text-gray-600">Chat</span>
                <div class="flex-1 h-6 bg-gray-100 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-green-400"
                    style={`width: ${(dashboardData.leads.current.chat / dashboardData.leads.current.total) * 100}%`}
                  />
                </div>
                <span class="w-12 text-right text-sm font-medium">{dashboardData.leads.current.chat}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 mb-8">
        <!-- Leads by Market -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#333] mb-4">Leads by Market</h2>
          <div class="space-y-3">
            {Object.entries(dashboardData.leads.byMarket).sort((a, b) => b[1] - a[1]).map(([market, count]) => (
              <div class="flex items-center">
                <span class={`w-28 text-sm px-2 py-1 rounded ${marketColors[market]}`}>
                  {market.charAt(0).toUpperCase() + market.slice(1)}
                </span>
                <div class="flex-1 mx-4 h-6 bg-gray-100 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-[#FFA985]"
                    style={`width: ${(count / 12) * 100}%`}
                  />
                </div>
                <span class="w-8 text-right text-sm font-medium">{count}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Conversion Funnel -->
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#333] mb-4">Conversion Funnel</h2>
          <div class="space-y-4">
            <div class="relative">
              <div class="flex justify-between mb-1">
                <span class="text-sm text-gray-600">Leads → Quotes Sent</span>
                <span class="text-sm font-bold">{dashboardData.conversions.leadToQuote}%</span>
              </div>
              <div class="h-4 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-blue-400" style={`width: ${dashboardData.conversions.leadToQuote}%`} />
              </div>
            </div>
            <div class="relative">
              <div class="flex justify-between mb-1">
                <span class="text-sm text-gray-600">Quotes → Booked</span>
                <span class="text-sm font-bold">{dashboardData.conversions.quoteToBooked}%</span>
              </div>
              <div class="h-4 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-green-400" style={`width: ${dashboardData.conversions.quoteToBooked}%`} />
              </div>
            </div>
            <div class="relative">
              <div class="flex justify-between mb-1">
                <span class="text-sm text-gray-600">Overall (Lead → Booked)</span>
                <span class="text-sm font-bold text-[#FFA985]">{dashboardData.conversions.overall}%</span>
              </div>
              <div class="h-4 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-[#FFA985]" style={`width: ${dashboardData.conversions.overall}%`} />
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Competitor Tracking -->
      <div class="bg-white rounded-xl shadow-sm overflow-hidden mb-8">
        <div class="px-6 py-4 border-b border-gray-100">
          <h2 class="text-lg font-bold text-[#333]">Competitor Tracking</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-gray-600">Competitor</th>
                <th class="px-4 py-3 text-center text-gray-600">Avg Position</th>
                <th class="px-4 py-3 text-center text-gray-600">Keywords</th>
                <th class="px-4 py-3 text-center text-gray-600">Reviews</th>
                <th class="px-4 py-3 text-center text-gray-600">Rating</th>
                <th class="px-4 py-3 text-center text-gray-600">Trend</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-50 bg-[#FFA985]/5">
                <td class="px-4 py-3 font-bold text-[#333]">The Valley Clean Team (You)</td>
                <td class="px-4 py-3 text-center font-bold">{dashboardData.rankingSummary.avgPosition}</td>
                <td class="px-4 py-3 text-center">{dashboardData.rankingSummary.total}</td>
                <td class="px-4 py-3 text-center">130+</td>
                <td class="px-4 py-3 text-center">5.0</td>
                <td class="px-4 py-3 text-center text-green-600">↑</td>
              </tr>
              {dashboardData.competitors.map((comp) => (
                <tr class="border-b border-gray-50 hover:bg-gray-50">
                  <td class="px-4 py-3">{comp.name}</td>
                  <td class="px-4 py-3 text-center">{comp.avgPosition}</td>
                  <td class="px-4 py-3 text-center">{comp.keywords}</td>
                  <td class="px-4 py-3 text-center">{comp.reviews}</td>
                  <td class="px-4 py-3 text-center">{comp.rating}</td>
                  <td class="px-4 py-3 text-center">
                    {comp.trend === 'up' ? (
                      <span class="text-red-600">↑</span>
                    ) : comp.trend === 'down' ? (
                      <span class="text-green-600">↓</span>
                    ) : (
                      <span class="text-gray-400">-</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-bold text-[#333] mb-4">Quick Actions</h2>
        <div class="flex flex-wrap gap-3">
          <a
            href="https://search.google.com/search-console"
            target="_blank"
            class="px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm transition"
          >
            Google Search Console →
          </a>
          <a
            href="https://analytics.google.com"
            target="_blank"
            class="px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm transition"
          >
            Google Analytics →
          </a>
          <a
            href="https://business.google.com"
            target="_blank"
            class="px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg text-sm transition"
          >
            Google Business Profile →
          </a>
          <a
            href="https://app.gohighlevel.com"
            target="_blank"
            class="px-4 py-2 bg-[#FFA985] hover:bg-[#ff9166] text-white rounded-lg text-sm transition"
          >
            GoHighLevel CRM →
          </a>
        </div>
      </div>
    </main>

    <footer class="text-center text-gray-500 text-sm py-8">
      <p>Internal Dashboard - Not for public access</p>
      <p class="mt-1">Data refreshes weekly or on-demand via automation scripts</p>
    </footer>
  </div>
</BaseLayout>
