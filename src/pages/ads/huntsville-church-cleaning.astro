---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
---
<BaseLayout
  title="Church Cleaning Service Huntsville AL | The Valley Clean Team"
  description="Church cleaning in Huntsville, AL. Sanctuaries, fellowship halls, classrooms, restrooms. Veteran-owned, $2M insured, flexible scheduling. Free walkthrough."
  noindex={true}
  showNav={false}
  showFooter={false}
  city="Huntsville"
  state="AL"
  serviceName="Church Cleaning"
>

<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <img src="/favicon.svg" alt="The Valley Clean Team" class="h-8 w-auto" width="32" height="32" />
      <span class="font-bold text-[#333333] text-sm hidden sm:block">The Valley Clean Team</span>
    </div>
    <a href="tel:2568261100" class="flex items-center gap-2 bg-[#FFA985] text-white px-4 py-2 rounded-full font-bold text-sm hover:bg-[#ff9060] transition">
      <Icon name="phone" class="w-4 h-4" />
      256-826-1100
    </a>
  </div>
</header>

<!-- HERO -->
<section class="bg-gradient-to-br from-[#FFF8F5] to-white py-14 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-purple-50 text-purple-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-5 border border-purple-200">
      <Icon name="cross" class="w-3.5 h-3.5" />
      We Already Clean Huntsville Churches — Ask Us for a Reference
    </div>
    <h1 class="text-4xl md:text-5xl font-extrabold text-[#333333] leading-tight mb-5">
      Church Cleaning in Huntsville<br />
      <span class="text-[#FFA985]">That Respects Your Space.</span>
    </h1>
    <p class="text-lg text-gray-600 mb-8 max-w-xl mx-auto">
      Your congregation deserves a clean, welcoming space every Sunday. The Valley Clean Team provides reliable, respectful church cleaning — scheduled around your services, not ours.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-6">
      <a href="/contact" class="bg-[#FFA985] text-white px-8 py-4 rounded-full text-lg font-bold shadow-lg hover:bg-[#ff9060] transition transform hover:scale-105">
        Request a Free Walkthrough
      </a>
      <a href="tel:2568261100" class="border-2 border-[#FFA985] text-[#FFA985] px-8 py-4 rounded-full text-lg font-bold hover:bg-[#FFF8F5] transition">
        Call 256-826-1100
      </a>
    </div>
    <p class="text-sm text-gray-400">Free on-site assessment. Nonprofit rates available. No obligation.</p>
  </div>
</section>

<section class="bg-[#333333] py-5 px-4">
  <div class="max-w-3xl mx-auto flex flex-wrap justify-center gap-6 text-white text-sm font-medium">
    <span class="flex items-center gap-2"><Icon name="star" class="w-4 h-4 text-yellow-400" /> 130+ Five-Star Reviews</span>
    <span class="flex items-center gap-2"><Icon name="shield-alt" class="w-4 h-4 text-green-400" /> $2M Liability Insurance</span>
    <span class="flex items-center gap-2"><Icon name="check-circle" class="w-4 h-4 text-blue-400" /> Background-Checked Team</span>
    <span class="flex items-center gap-2"><Icon name="heart" class="w-4 h-4 text-[#FFA985]" /> Nonprofit Rates Available</span>
  </div>
</section>

<!-- WHAT WE UNDERSTAND ABOUT CHURCHES -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">We Understand Church Facilities</h2>
    <p class="text-center text-gray-500 mb-10">Church cleaning isn't the same as office cleaning. We know that.</p>
    <div class="grid md:grid-cols-2 gap-5">
      {[
        {icon: "calendar-check", title: "Scheduled Around Your Services", desc: "We clean after Sunday services, before Wednesday night events, or on whatever schedule your ministry needs. Your congregation always walks into a clean space."},
        {icon: "users", title: "Multiple Spaces, One Team", desc: "Sanctuary, fellowship hall, classrooms, nursery, restrooms — we handle the whole facility with a consistent team who knows your space."},
        {icon: "shield-alt", title: "Trusted & Background-Checked", desc: "Every team member is background-checked. We understand the trust required to clean a church facility and we take it seriously."},
        {icon: "heart", title: "Nonprofit Rates Available", desc: "We offer special rates for churches and nonprofits. Talk to us about your budget — we'll find a solution that works."}
      ].map(item => (
        <div class="flex gap-4 p-5 bg-[#FFF8F5] rounded-2xl">
          <div class="w-10 h-10 bg-[#FFA985] rounded-full flex items-center justify-center flex-shrink-0">
            <Icon name={item.icon} class="w-5 h-5 text-white" />
          </div>
          <div>
            <h3 class="font-bold text-[#333333] mb-1">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED -->
<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-3">Church Cleaning Includes</h2>
    <p class="text-center text-gray-500 mb-10">Customized to your facility and service schedule.</p>
    <div class="grid sm:grid-cols-2 gap-3">
      {[
        "Sanctuary cleaning & pew/chair wiping",
        "Altar and platform areas cleaned",
        "Fellowship hall floors & surfaces",
        "Kitchen and food prep areas sanitized",
        "All classrooms cleaned & reset",
        "Nursery deep-cleaned & sanitized",
        "All restrooms scrubbed & restocked",
        "Entryways & lobbies cleaned",
        "Trash removal throughout facility",
        "High-touch surface disinfection"
      ].map(item => (
        <div class="flex items-start gap-3 bg-white p-4 rounded-xl shadow-sm">
          <Icon name="check" class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" />
          <span class="text-gray-700 text-sm">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CREDIBILITY -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-[#333333] mb-4">Veteran-Owned. Community-Rooted.</h2>
    <p class="text-gray-600 mb-6 text-lg">The Valley Clean Team was built on the same values your church was — integrity, service, and showing up when you say you will. We're not a franchise. We're your neighbors in North Alabama.</p>
    <div class="grid sm:grid-cols-3 gap-4">
      <div class="bg-[#FFF8F5] p-5 rounded-2xl text-center">
        <p class="text-3xl font-bold text-[#FFA985]">130+</p>
        <p class="text-sm text-gray-600 mt-1">Five-Star Reviews</p>
      </div>
      <div class="bg-[#FFF8F5] p-5 rounded-2xl text-center">
        <p class="text-3xl font-bold text-[#FFA985]">$2M</p>
        <p class="text-sm text-gray-600 mt-1">Liability Insurance</p>
      </div>
      <div class="bg-[#FFF8F5] p-5 rounded-2xl text-center">
        <p class="text-3xl font-bold text-[#FFA985]">98%+</p>
        <p class="text-sm text-gray-600 mt-1">Job Completion Rate</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-10">Church Cleaning FAQ</h2>
    <div class="space-y-4">
      {[
        {q: "Do you offer nonprofit or church rates?", a: "Yes. We offer special pricing for churches and nonprofits. Talk to us about your facility and budget — we'll work with you."},
        {q: "Can you clean around our service schedule?", a: "Absolutely. We schedule cleaning around your services — after Sunday morning, before Wednesday night, or whatever works for your ministry calendar."},
        {q: "Are your team members background-checked?", a: "Yes. Every team member passes a background check before working in any facility. We understand the trust required to clean a church."},
        {q: "How do we get a quote?", a: "Call 256-826-1100 or request a free walkthrough. We come to your facility, walk through the space, and provide a written quote with no obligation."},
        {q: "Can you handle large church facilities?", a: "Yes. We've cleaned facilities of varying sizes across North Alabama. We'll assess your space and staff accordingly."}
      ].map(faq => (
        <details class="bg-white rounded-xl p-5 cursor-pointer group shadow-sm">
          <summary class="font-bold text-[#333333] flex justify-between items-center list-none">
            {faq.q}
            <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform" />
          </summary>
          <p class="text-gray-600 mt-3 text-sm">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="py-16 px-4 bg-gradient-to-br from-[#FFA985] to-[#FFC67D]">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
      Your congregation deserves a clean, welcoming space.
    </h2>
    <p class="text-white/90 mb-8 text-lg">Free on-site walkthrough. Nonprofit rates available. No obligation.</p>
    <a href="/contact" class="bg-white text-[#FFA985] px-12 py-5 rounded-full text-xl font-bold shadow-xl hover:shadow-2xl transition transform hover:scale-105 inline-block">
      Request a Free Walkthrough
    </a>
    <p class="text-white/80 mt-4 text-sm">Or call us directly: <a href="tel:2568261100" class="underline font-bold">256-826-1100</a></p>
  </div>
</section>

<footer class="bg-[#333333] py-4 px-4 text-center text-gray-400 text-xs">
  <p>© 2026 The Valley Clean Team · Huntsville, AL · <a href="/privacy" class="underline hover:text-white">Privacy Policy</a></p>
</footer>

</BaseLayout>
