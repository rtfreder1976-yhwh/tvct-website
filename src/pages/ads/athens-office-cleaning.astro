---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
---
<BaseLayout
  title="Office Cleaning Athens AL | The Valley Clean Team"
  description="Office cleaning in Athens, AL. Reliable, insured, bondable commercial cleaning for small businesses and offices. Veteran-owned. Free quote: 256-826-1100."
  noindex={true}
  showNav={false}
  showFooter={false}
  city="Athens"
  state="AL"
  serviceName="Office Cleaning"
>

<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <img src="/logo.png" alt="The Valley Clean Team" class="h-8 w-auto" onerror="this.style.display='none'" />
      <span class="font-bold text-[#333333] text-sm hidden sm:block">The Valley Clean Team</span>
    </div>
    <a href="tel:2568261100" class="flex items-center gap-2 bg-[#FFA985] text-white px-4 py-2 rounded-full font-bold text-sm hover:bg-[#ff9060] transition">
      <Icon name="phone" class="w-4 h-4" />
      256-826-1100
    </a>
  </div>
</header>

<section class="bg-gradient-to-br from-[#FFF8F5] to-white py-14 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-5 border border-blue-200">
      <Icon name="building" class="w-3.5 h-3.5" />
      Veteran-Owned · Bondable · $2M Insured
    </div>
    <h1 class="text-4xl md:text-5xl font-extrabold text-[#333333] leading-tight mb-5">
      Office Cleaning in Athens, AL<br />
      <span class="text-[#FFA985]">That Actually Shows Up.</span>
    </h1>
    <p class="text-lg text-gray-600 mb-8 max-w-xl mx-auto">
      Athens small businesses deserve a cleaning service that's as reliable as they are. Background-checked team, after-hours availability, and a satisfaction guarantee — every visit.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-6">
      <a href="/contact" class="bg-[#FFA985] text-white px-8 py-4 rounded-full text-lg font-bold shadow-lg hover:bg-[#ff9060] transition transform hover:scale-105">
        Request a Free Walkthrough
      </a>
      <a href="tel:2568261100" class="border-2 border-[#FFA985] text-[#FFA985] px-8 py-4 rounded-full text-lg font-bold hover:bg-[#FFF8F5] transition">
        Call 256-826-1100
      </a>
    </div>
    <p class="text-sm text-gray-400">Free on-site assessment. No obligation. We come to you.</p>
  </div>
</section>

<section class="bg-[#333333] py-5 px-4">
  <div class="max-w-3xl mx-auto flex flex-wrap justify-center gap-6 text-white text-sm font-medium">
    <span class="flex items-center gap-2"><Icon name="star" class="w-4 h-4 text-yellow-400" /> 130+ Five-Star Reviews</span>
    <span class="flex items-center gap-2"><Icon name="shield-alt" class="w-4 h-4 text-green-400" /> $2M Liability Insurance</span>
    <span class="flex items-center gap-2"><Icon name="check-circle" class="w-4 h-4 text-blue-400" /> Bondable & Background-Checked</span>
    <span class="flex items-center gap-2"><Icon name="clock" class="w-4 h-4 text-[#FFA985]" /> After-Hours Available</span>
  </div>
</section>

<section class="py-14 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-10">Why Athens Businesses Choose Us</h2>
    <div class="grid md:grid-cols-2 gap-5">
      {[
        {icon: "check-circle", title: "98%+ Job Completion Rate", desc: "We don't no-show. Commercial clients lose faith fast when a vendor doesn't show up. We've built our reputation on showing up every single time."},
        {icon: "moon", title: "After-Hours Cleaning", desc: "Clean office waiting for your team every morning. We work evenings and early mornings so your business day isn't interrupted."},
        {icon: "shield-alt", title: "Insured, Bonded & Background-Checked", desc: "Every team member is vetted. $2M liability coverage. Your business assets and property are fully protected."},
        {icon: "star", title: "Satisfaction Guaranteed", desc: "If something's not right, we come back and fix it within 24 hours. No charge. No argument. That's the deal."}
      ].map(item => (
        <div class="flex gap-4 p-5 bg-[#FFF8F5] rounded-2xl">
          <div class="w-10 h-10 bg-[#FFA985] rounded-full flex items-center justify-center flex-shrink-0">
            <Icon name={item.icon} class="w-5 h-5 text-white" />
          </div>
          <div>
            <h3 class="font-bold text-[#333333] mb-1">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-3">What's Included</h2>
    <p class="text-center text-gray-500 mb-10">Customized to your office. Quoted per your specific needs.</p>
    <div class="grid sm:grid-cols-2 gap-3">
      {[
        "Reception & lobby cleaning",
        "Workstations dusted & sanitized",
        "Conference rooms detailed",
        "Break room & kitchen sanitized",
        "Restrooms cleaned & restocked",
        "Floors vacuumed & mopped",
        "Trash removed & bins relined",
        "Glass & windows cleaned",
        "High-touch surface disinfection",
        "Custom checklist per your facility"
      ].map(item => (
        <div class="flex items-start gap-3 bg-white p-4 rounded-xl shadow-sm">
          <Icon name="check" class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" />
          <span class="text-gray-700 text-sm">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-14 px-4 bg-white">
  <div class="max-w-2xl mx-auto">
    <div class="bg-[#FFF8F5] p-8 rounded-2xl border border-orange-100 text-center">
      <div class="flex justify-center gap-1 mb-4">
        {[1,2,3,4,5].map(() => <Icon name="star" class="w-5 h-5 text-yellow-400" />)}
      </div>
      <p class="text-gray-700 mb-6 italic text-lg">"Switched to Valley Clean Team 6 months ago after our last service kept canceling last minute. Night and day difference. Our Athens office is consistently clean and they've never missed a scheduled visit."</p>
      <p class="font-bold text-[#333333]">— Business Owner, Athens AL</p>
    </div>
  </div>
</section>

<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-10">Office Cleaning FAQ</h2>
    <div class="space-y-4">
      {[
        {q: "How much does office cleaning cost in Athens?", a: "Small Athens offices typically start at $125–$200 per visit. We provide a written quote after a free on-site walkthrough — no guessing."},
        {q: "Do you clean after business hours?", a: "Yes. Most Athens clients prefer evening or early morning cleaning. We work around your schedule."},
        {q: "How often should my office be cleaned?", a: "Most small offices do well with weekly cleaning. High-traffic spaces may need 2–3x per week. We'll recommend the right frequency after seeing your space."},
        {q: "Are you insured for commercial properties?", a: "Yes. $2M liability insurance, fully bonded, every team member background-checked."},
        {q: "How do I get started?", a: "Call 256-826-1100 or request a free walkthrough online. We assess your space and provide a written quote — no obligation."}
      ].map(faq => (
        <details class="bg-white rounded-xl p-5 cursor-pointer group shadow-sm">
          <summary class="font-bold text-[#333333] flex justify-between items-center list-none">
            {faq.q}
            <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform" />
          </summary>
          <p class="text-gray-600 mt-3 text-sm">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<section class="py-16 px-4 bg-gradient-to-br from-[#FFA985] to-[#FFC67D]">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
      Your Athens office, clean every time. Guaranteed.
    </h2>
    <p class="text-white/90 mb-8 text-lg">Free on-site walkthrough. Written quote. No obligation.</p>
    <a href="/contact" class="bg-white text-[#FFA985] px-12 py-5 rounded-full text-xl font-bold shadow-xl hover:shadow-2xl transition transform hover:scale-105 inline-block">
      Request a Free Walkthrough
    </a>
    <p class="text-white/80 mt-4 text-sm">Or call us directly: <a href="tel:2568261100" class="underline font-bold">256-826-1100</a></p>
  </div>
</section>

<footer class="bg-[#333333] py-4 px-4 text-center text-gray-400 text-xs">
  <p>© 2026 The Valley Clean Team · Athens, AL · <a href="/privacy" class="underline hover:text-white">Privacy Policy</a></p>
</footer>

</BaseLayout>
