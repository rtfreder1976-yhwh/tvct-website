---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
---
<BaseLayout
  title="Recurring House Cleaning Athens AL | The Valley Clean Team"
  description="Recurring maid service in Athens, AL. Weekly, biweekly & monthly house cleaning. Veteran-owned, background-checked, no contracts. Book in 60 seconds."
  noindex={true}
  showNav={false}
  showFooter={false}
  city="Athens"
  state="AL"
  serviceName="Recurring House Cleaning"
>

<!-- Minimal sticky header -->
<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <img src="/favicon.svg" alt="The Valley Clean Team" class="h-8 w-auto" width="32" height="32" />
      <span class="font-bold text-[#333333] text-sm hidden sm:block">The Valley Clean Team</span>
    </div>
    <a href="tel:2568261100" class="flex items-center gap-2 bg-[#FFA985] text-white px-4 py-2 rounded-full font-bold text-sm hover:bg-[#ff9060] transition">
      <Icon name="phone" class="w-4 h-4" />
      256-826-1100
    </a>
  </div>
</header>

<!-- HERO -->
<section class="bg-gradient-to-br from-[#FFF8F5] to-white py-14 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-green-50 text-green-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-5 border border-green-200">
      <Icon name="check-circle" class="w-3.5 h-3.5" />
      Veteran-Owned · Background-Checked · $2M Insured
    </div>
    <h1 class="text-4xl md:text-5xl font-extrabold text-[#333333] leading-tight mb-5">
      Reliable House Cleaning<br />
      <span class="text-[#FFA985]">Right Here in Athens, AL.</span>
    </h1>
    <p class="text-lg text-gray-600 mb-8 max-w-xl mx-auto">
      Athens families trust The Valley Clean Team for consistent, recurring house cleaning. Same team, same standards, every visit — no contracts, no surprises.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-6">
      <a href="/booking" class="bg-[#FFA985] text-white px-8 py-4 rounded-full text-lg font-bold shadow-lg hover:bg-[#ff9060] transition transform hover:scale-105">
        See My Price — 60 Seconds
      </a>
      <a href="tel:2568261100" class="border-2 border-[#FFA985] text-[#FFA985] px-8 py-4 rounded-full text-lg font-bold hover:bg-[#FFF8F5] transition">
        Call 256-826-1100
      </a>
    </div>
    <p class="text-sm text-gray-400">No contracts. Cancel anytime with 48 hours notice.</p>
  </div>
</section>

<!-- SOCIAL PROOF BAR -->
<section class="bg-[#333333] py-5 px-4">
  <div class="max-w-3xl mx-auto flex flex-wrap justify-center gap-6 text-white text-sm font-medium">
    <span class="flex items-center gap-2"><Icon name="star" class="w-4 h-4 text-yellow-400" /> 130+ Five-Star Reviews</span>
    <span class="flex items-center gap-2"><Icon name="map-pin" class="w-4 h-4 text-[#FFA985]" /> Locally Based in North Alabama</span>
    <span class="flex items-center gap-2"><Icon name="shield-alt" class="w-4 h-4 text-green-400" /> $2M Liability Insurance</span>
    <span class="flex items-center gap-2"><Icon name="calendar-check" class="w-4 h-4 text-blue-400" /> Start Within Days</span>
  </div>
</section>

<!-- WHY ATHENS CLIENTS CHOOSE US -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">Why Athens Families Choose Valley Clean Team</h2>
    <p class="text-center text-gray-500 mb-10">We're not a national franchise. We're your neighbors.</p>
    <div class="grid md:grid-cols-2 gap-5">
      {[
        {icon: "users", title: "Same Team Every Time", desc: "Your dedicated cleaners learn your home, your preferences, and your schedule. No strangers showing up."},
        {icon: "shield-alt", title: "Fully Insured & Bonded", desc: "$2M liability coverage. Every team member is background-checked before they ever enter a home."},
        {icon: "star", title: "Satisfaction Guaranteed", desc: "Not happy with something? We come back within 24 hours and fix it. No charge, no argument."},
        {icon: "calendar-check", title: "Flexible Scheduling", desc: "Weekly, biweekly, or monthly. Switch frequencies anytime. No penalties, no contracts."}
      ].map(item => (
        <div class="flex gap-4 p-5 bg-[#FFF8F5] rounded-2xl">
          <div class="w-10 h-10 bg-[#FFA985] rounded-full flex items-center justify-center flex-shrink-0">
            <Icon name={item.icon} class="w-5 h-5 text-white" />
          </div>
          <div>
            <h3 class="font-bold text-[#333333] mb-1">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED -->
<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-3">What's Included Every Visit</h2>
    <p class="text-center text-gray-500 mb-10">No hidden add-ons. No upsells at the door.</p>
    <div class="grid sm:grid-cols-2 gap-3">
      {[
        "Full kitchen cleaning — counters, appliances, sink",
        "All bathrooms scrubbed and sanitized",
        "Vacuuming all floors and rugs",
        "Mopping hard floors",
        "Dusting surfaces, furniture, and ceiling fans",
        "Bed making and linen straightening",
        "Mirror and glass cleaning",
        "High-touch surface disinfection",
        "Trash removal and bin relining",
        "Rotating deep tasks each visit"
      ].map(item => (
        <div class="flex items-start gap-3 bg-white p-4 rounded-xl shadow-sm">
          <Icon name="check" class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" />
          <span class="text-gray-700 text-sm">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-10">What Athens Families Say</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-[#FFF8F5] p-6 rounded-2xl border border-orange-100">
        <div class="flex gap-1 mb-3">
          {[1,2,3,4,5].map(() => <Icon name="star" class="w-4 h-4 text-yellow-400" />)}
        </div>
        <p class="text-gray-700 text-sm mb-4 italic">"Finally found a cleaning service that actually shows up when they say they will. My Athens home has been consistently clean for 8 months now. Worth every penny."</p>
        <p class="font-bold text-[#333333] text-sm">— Lisa K., Athens AL</p>
      </div>
      <div class="bg-[#FFF8F5] p-6 rounded-2xl border border-orange-100">
        <div class="flex gap-1 mb-3">
          {[1,2,3,4,5].map(() => <Icon name="star" class="w-4 h-4 text-yellow-400" />)}
        </div>
        <p class="text-gray-700 text-sm mb-4 italic">"Veteran-owned and it shows. Professional, reliable, and they actually care about doing a good job. My house smells amazing after every visit."</p>
        <p class="font-bold text-[#333333] text-sm">— Mark D., Limestone County</p>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-[#333333] mb-4">Honest Pricing. No Surprises.</h2>
    <p class="text-gray-600 mb-8">Most Athens homes run <strong>$110–$165 per biweekly visit</strong>. Get your exact price in 60 seconds.</p>
    <div class="grid sm:grid-cols-3 gap-4 mb-8">
      <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 text-center">
        <p class="text-2xl font-bold text-[#FFA985]">20%</p>
        <p class="text-sm text-gray-600 mt-1">off with weekly service</p>
      </div>
      <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 text-center">
        <p class="text-2xl font-bold text-[#FFA985]">15%</p>
        <p class="text-sm text-gray-600 mt-1">off with biweekly service</p>
      </div>
      <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100 text-center">
        <p class="text-2xl font-bold text-[#FFA985]">10%</p>
        <p class="text-sm text-gray-600 mt-1">off with monthly service</p>
      </div>
    </div>
    <a href="/booking" class="bg-[#FFA985] text-white px-10 py-4 rounded-full text-lg font-bold shadow-lg hover:bg-[#ff9060] transition inline-block">
      Get My Exact Price
    </a>
    <p class="text-xs text-gray-400 mt-3">No contracts. No credit card to get a quote.</p>
  </div>
</section>

<!-- FAQ -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-10">Quick Answers</h2>
    <div class="space-y-4">
      {[
        {q: "Do you serve all of Athens and Limestone County?", a: "Yes. We cover Athens, Ardmore, Tanner, Elkmont, Belle Mina, Clements, Mooresville, Lindsay Lane, and surrounding Limestone County areas."},
        {q: "Do I have to sign a contract?", a: "Never. Cancel or pause anytime with 48 hours notice."},
        {q: "Will I get the same cleaners each time?", a: "Yes. We assign a dedicated team to your home who learn your preferences and your home's layout."},
        {q: "What if I'm not happy with a clean?", a: "We'll come back and fix it within 24 hours. No questions, no charge."},
        {q: "How quickly can you start?", a: "Most Athens clients can start within 3–5 days of booking."}
      ].map(faq => (
        <details class="bg-gray-50 rounded-xl p-5 cursor-pointer group">
          <summary class="font-bold text-[#333333] flex justify-between items-center list-none">
            {faq.q}
            <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform" />
          </summary>
          <p class="text-gray-600 mt-3 text-sm">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="py-16 px-4 bg-gradient-to-br from-[#FFA985] to-[#FFC67D]">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
      Athens deserves a reliable cleaning team. Here we are.
    </h2>
    <p class="text-white/90 mb-8 text-lg">Takes 60 seconds to get your price. No credit card. No commitment.</p>
    <a href="/booking" class="bg-white text-[#FFA985] px-12 py-5 rounded-full text-xl font-bold shadow-xl hover:shadow-2xl transition transform hover:scale-105 inline-block">
      See My Price Now
    </a>
    <p class="text-white/80 mt-4 text-sm">Or call us directly: <a href="tel:2568261100" class="underline font-bold">256-826-1100</a></p>
  </div>
</section>

<footer class="bg-[#333333] py-4 px-4 text-center text-gray-400 text-xs">
  <p>© 2026 The Valley Clean Team · Athens, AL · <a href="/privacy" class="underline hover:text-white">Privacy Policy</a></p>
</footer>

</BaseLayout>
