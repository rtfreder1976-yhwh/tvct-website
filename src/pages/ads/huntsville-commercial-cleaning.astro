---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
---
<BaseLayout
  title="Commercial Cleaning Huntsville AL | The Valley Clean Team"
  description="Commercial cleaning in Huntsville, AL. Offices, churches, medical suites, small businesses. Veteran-owned, $2M insured, bondable. Free walkthrough quote."
  noindex={true}
  showNav={false}
  showFooter={false}
  city="Huntsville"
  state="AL"
  serviceName="Commercial Cleaning"
>

<!-- Minimal sticky header -->
<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <img src="/favicon.svg" alt="The Valley Clean Team" class="h-8 w-auto" width="32" height="32" />
      <span class="font-bold text-[#333333] text-sm hidden sm:block">The Valley Clean Team</span>
    </div>
    <a href="tel:2568261100" class="flex items-center gap-2 bg-[#FFA985] text-white px-4 py-2 rounded-full font-bold text-sm hover:bg-[#ff9060] transition">
      <Icon name="phone" class="w-4 h-4" />
      256-826-1100
    </a>
  </div>
</header>

<!-- HERO -->
<section class="bg-gradient-to-br from-[#FFF8F5] to-white py-14 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-5 border border-blue-200">
      <Icon name="building" class="w-3.5 h-3.5" />
      Veteran-Owned · Bondable · $2M Insured · Background-Checked
    </div>
    <h1 class="text-4xl md:text-5xl font-extrabold text-[#333333] leading-tight mb-5">
      Commercial Cleaning<br />
      <span class="text-[#FFA985]">Huntsville Businesses Trust.</span>
    </h1>
    <p class="text-lg text-gray-600 mb-8 max-w-xl mx-auto">
      Offices, medical suites, churches, nonprofits. We show up when we say we will, clean to your standard, and never give you a reason to find someone else.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-6">
      <a href="/contact" class="bg-[#FFA985] text-white px-8 py-4 rounded-full text-lg font-bold shadow-lg hover:bg-[#ff9060] transition transform hover:scale-105">
        Request a Free Walkthrough
      </a>
      <a href="tel:2568261100" class="border-2 border-[#FFA985] text-[#FFA985] px-8 py-4 rounded-full text-lg font-bold hover:bg-[#FFF8F5] transition">
        Call 256-826-1100
      </a>
    </div>
    <p class="text-sm text-gray-400">Free on-site assessment. No obligation. We come to you.</p>
  </div>
</section>

<!-- SOCIAL PROOF BAR -->
<section class="bg-[#333333] py-5 px-4">
  <div class="max-w-3xl mx-auto flex flex-wrap justify-center gap-6 text-white text-sm font-medium">
    <span class="flex items-center gap-2"><Icon name="star" class="w-4 h-4 text-yellow-400" /> 130+ Five-Star Reviews</span>
    <span class="flex items-center gap-2"><Icon name="shield-alt" class="w-4 h-4 text-green-400" /> $2M Liability Insurance</span>
    <span class="flex items-center gap-2"><Icon name="check-circle" class="w-4 h-4 text-blue-400" /> Bondable & Background-Checked</span>
    <span class="flex items-center gap-2"><Icon name="clock" class="w-4 h-4 text-[#FFA985]" /> After-Hours Available</span>
  </div>
</section>

<!-- WHO WE SERVE -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-4">Who We Clean For in Huntsville</h2>
    <p class="text-center text-gray-500 mb-10">We specialize in spaces where reliability isn't optional.</p>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {[
        {icon: "building", label: "Small Offices"},
        {icon: "heart", label: "Medical Suites"},
        {icon: "cross", label: "Churches & Nonprofits"},
        {icon: "briefcase", label: "Professional Services"},
        {icon: "store", label: "Retail Spaces"},
        {icon: "users", label: "Coworking Spaces"}
      ].map(item => (
        <div class="flex items-center gap-3 p-4 bg-[#FFF8F5] rounded-xl border border-orange-100">
          <div class="w-9 h-9 bg-[#FFA985] rounded-full flex items-center justify-center flex-shrink-0">
            <Icon name={item.icon} class="w-4 h-4 text-white" />
          </div>
          <span class="font-semibold text-[#333333] text-sm">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHY COMMERCIAL CLIENTS CHOOSE US -->
<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-10">What Commercial Clients Actually Need</h2>
    <div class="grid md:grid-cols-2 gap-5">
      {[
        {icon: "check-circle", title: "Reliability You Can Count On", desc: "Commercial clients fire vendors for no-shows. We have a 98%+ job completion rate. Your space gets cleaned when it's scheduled."},
        {icon: "moon", title: "After-Hours & Weekend Cleaning", desc: "We work around your business hours — evenings, early mornings, weekends. Your team comes in to a clean space, not a cleaning crew."},
        {icon: "shield-alt", title: "Fully Insured & Bondable", desc: "$2M liability coverage. Every team member is background-checked and bondable. Your property and assets are protected."},
        {icon: "star", title: "Veteran-Owned Standards", desc: "Military precision applied to cleaning operations. Checklists, accountability, and zero tolerance for cutting corners."}
      ].map(item => (
        <div class="flex gap-4 p-5 bg-white rounded-2xl shadow-sm">
          <div class="w-10 h-10 bg-[#FFA985] rounded-full flex items-center justify-center flex-shrink-0">
            <Icon name={item.icon} class="w-5 h-5 text-white" />
          </div>
          <div>
            <h3 class="font-bold text-[#333333] mb-1">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHAT'S INCLUDED -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-3">Standard Commercial Cleaning Includes</h2>
    <p class="text-center text-gray-500 mb-10">Customized to your facility. Quoted per your specific needs.</p>
    <div class="grid sm:grid-cols-2 gap-3">
      {[
        "Reception & lobby cleaning",
        "All surfaces dusted & sanitized",
        "Desks & workstations cleaned",
        "Conference rooms detailed",
        "Break rooms & kitchens sanitized",
        "Restrooms deep cleaned & restocked",
        "Floors vacuumed & mopped",
        "Trash removed & bins relined",
        "Windows & glass cleaned",
        "High-touch surface disinfection"
      ].map(item => (
        <div class="flex items-start gap-3 bg-gray-50 p-4 rounded-xl">
          <Icon name="check" class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" />
          <span class="text-gray-700 text-sm">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CHURCH CALLOUT -->
<section class="py-10 px-4 bg-[#FFF8F5]">
  <div class="max-w-2xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-white text-[#FFA985] text-sm font-semibold px-4 py-2 rounded-full mb-4 border border-orange-200 shadow-sm">
      <Icon name="cross" class="w-4 h-4" />
      Church & Nonprofit Cleaning
    </div>
    <h3 class="text-2xl font-bold text-[#333333] mb-3">We Already Clean Huntsville Churches.</h3>
    <p class="text-gray-600 mb-6">We understand the unique needs of church facilities — fellowship halls, sanctuaries, classrooms, restrooms. Flexible scheduling around your service times. Ask about our nonprofit rates.</p>
    <a href="/contact" class="bg-[#FFA985] text-white px-8 py-3 rounded-full font-bold hover:bg-[#ff9060] transition inline-block">
      Ask About Church Cleaning
    </a>
  </div>
</section>

<!-- TESTIMONIAL -->
<section class="py-14 px-4 bg-white">
  <div class="max-w-2xl mx-auto">
    <div class="bg-[#FFF8F5] p-8 rounded-2xl border border-orange-100 text-center">
      <div class="flex justify-center gap-1 mb-4">
        {[1,2,3,4,5].map(() => <Icon name="star" class="w-5 h-5 text-yellow-400" />)}
      </div>
      <p class="text-gray-700 mb-6 italic text-lg">"We've had three commercial cleaning companies before Valley Clean Team. The difference is they actually show up, they actually clean, and they actually respond when you call. That sounds basic but it's apparently rare."</p>
      <p class="font-bold text-[#333333]">— Office Manager, Huntsville Professional Services Firm</p>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-14 px-4 bg-gray-50">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#333333] mb-10">Commercial Cleaning FAQ</h2>
    <div class="space-y-4">
      {[
        {q: "How much does commercial cleaning cost in Huntsville?", a: "Small offices typically start at $150–$250 per visit. Larger facilities and custom frequencies are quoted after a free on-site walkthrough. We don't guess — we assess."},
        {q: "Do you offer after-hours cleaning?", a: "Yes. Most commercial clients prefer evenings or early mornings. We work around your schedule."},
        {q: "Are you bondable and insured?", a: "Yes. $2M liability insurance, fully bonded, and every team member is background-checked. Your property is protected."},
        {q: "Can you handle medical office cleaning?", a: "Yes. We follow healthcare cleaning protocols with EPA-registered disinfectants and understand sanitation requirements for medical environments."},
        {q: "How do I get a quote?", a: "Call 256-826-1100 or request a free walkthrough. We come to your facility, assess the scope, and provide a written quote — no obligation."}
      ].map(faq => (
        <details class="bg-white rounded-xl p-5 cursor-pointer group shadow-sm">
          <summary class="font-bold text-[#333333] flex justify-between items-center list-none">
            {faq.q}
            <Icon name="chevron-down" class="w-5 h-5 text-[#FFA985] group-open:rotate-180 transition-transform" />
          </summary>
          <p class="text-gray-600 mt-3 text-sm">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="py-16 px-4 bg-gradient-to-br from-[#FFA985] to-[#FFC67D]">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
      Stop managing your cleaning vendor. Let us handle it.
    </h2>
    <p class="text-white/90 mb-8 text-lg">Free on-site walkthrough. Written quote. No obligation.</p>
    <a href="/contact" class="bg-white text-[#FFA985] px-12 py-5 rounded-full text-xl font-bold shadow-xl hover:shadow-2xl transition transform hover:scale-105 inline-block">
      Request a Free Walkthrough
    </a>
    <p class="text-white/80 mt-4 text-sm">Or call us directly: <a href="tel:2568261100" class="underline font-bold">256-826-1100</a></p>
  </div>
</section>

<footer class="bg-[#333333] py-4 px-4 text-center text-gray-400 text-xs">
  <p>© 2026 The Valley Clean Team · Huntsville, AL · <a href="/privacy" class="underline hover:text-white">Privacy Policy</a></p>
</footer>

</BaseLayout>
