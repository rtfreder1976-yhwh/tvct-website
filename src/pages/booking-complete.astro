---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

// Static thank-you page. As of 2026-07-10 BookingKoala keeps completed
// bookings on ITS OWN thank-you page (it no longer redirects here), and
// completion conversion tracking is handled natively in BookingKoala
// (GA4 + Meta Pixel + Zapier/Make → GHL). This page is now only reachable
// via a stray old link/bookmark, so it renders a friendly message and fires
// NOTHING — firing a conversion on a bare load was the source of the
// "You're booked" false-positive bug this change fixed.
---

<BaseLayout
  title="Booking Confirmed | Valley Clean Team"
  description="Your cleaning is booked. Thank you for choosing The Valley Clean Team."
  showNav={false}
  showFooter={false}
  schemaType="none"
  noindex={true}
>
  <section class="min-h-[70vh] flex items-center justify-center px-6 py-24">
    <div class="text-center max-w-lg">
      <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-green-100 flex items-center justify-center">
        <Icon name="check-circle" class="w-12 h-12 text-green-600" />
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-[#333333] mb-4">You're booked.</h1>
      <p class="text-xl text-gray-600 mb-8">
        Thank you for choosing The Valley Clean Team. You'll get a confirmation by
        email and a text before your clean. Remember — your card isn't charged
        until after the job is done.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary px-8 py-3 rounded-full text-lg font-semibold inline-flex items-center justify-center">
          Back to Home
        </a>
        <a href="tel:2568261100" class="btn-secondary px-8 py-3 rounded-full text-lg font-semibold inline-flex items-center justify-center">
          <Icon name="phone" class="w-5 h-5 mr-2" />Questions? Call Us
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
