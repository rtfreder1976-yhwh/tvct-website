---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Schedule Your Cleaning | 100% Happiness Guarantee | Valley Clean Team"
  description="Book your professional cleaning service online in minutes. Veteran-owned, fully insured ($2M), and backed by our 100% Satisfaction Guarantee. Serving Alabama and Tennessee."
  showNav={false}
  showFooter={false}
  schemaType="service"
  serviceName="House Cleaning"
  serviceDescription="Professional house cleaning services in Alabama and Tennessee. Book online in 60 seconds."
>
  <!-- Simple, Non-Interactive Header (Leaky Funnel) -->
  <header class="py-6 px-6 border-b border-gray-100 bg-white sticky top-0 z-50">
    <div class="container mx-auto flex justify-between items-center">
      <div class="flex items-center">
        <img src="https://storage.googleapis.com/msgsndr/iKQIBhpKVL2XVPgU7HMd/media/6920802945dc047d65b4ec5d.png" alt="Valley Clean Team Logo" class="h-10 w-auto mr-3" />
        <span class="font-bold text-xl text-[#333333] hidden sm:inline">Valley Clean Team</span>
      </div>
      <div class="text-sm font-semibold text-gray-500 flex items-center">
        <Icon name="phone" class="w-4 h-4 mr-2 text-[#FFA985]" />
        Questions? <a href="tel:2568261100" class="ml-1 text-[#333333] hover:text-[#FFA985]">256-826-1100</a>
      </div>
    </div>
  </header>
  

  
    <!-- Hero Section -->
    <section class="pt-32 pb-12 px-6">
      <div class="container mx-auto text-center max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-bold mb-6 text-[#333333] tracking-tight">
          Reclaim Your Weekend, <span class="gold-gradient">Starting Now</span>
        </h1>
        <p class="text-xl text-gray-600 mb-6 max-w-2xl mx-auto">
          Choose your service, pick a time, and relax. We'll handle the hard work with military precision and a 100% satisfaction guarantee.
        </p>
        <div class="flex flex-wrap justify-center gap-6 text-sm text-gray-500 mb-8">
          <span class="flex items-center">
            <Icon name="check-circle" class="w-5 h-5 text-green-500 mr-2" />
            100% Happiness Guarantee
          </span>
          <span class="flex items-center">
            <Icon name="shield-check" class="w-5 h-5 text-blue-500 mr-2" />
            $2M Insurance Coverage
          </span>
          <span class="flex items-center">
            <Icon name="flag-usa" class="w-5 h-5 text-[#FFA985] mr-2" />
            Veteran-Owned Integrity
          </span>
        </div>
      </div>
    </section>

    <!-- Booking Widget Section -->
    <section class="pb-20 px-6">
      <div class="container mx-auto max-w-4xl">
        <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden relative">
          <!-- Risk Reversal Banner -->
          <div class="bg-gradient-to-r from-green-50 to-white border-b border-green-100 px-6 py-4 flex flex-col sm:flex-row items-center justify-center text-green-800 text-sm md:text-base font-semibold gap-2">
            <div class="flex items-center">
              <Icon name="shield-check" class="w-6 h-6 mr-2 text-green-600" />
              NO-RISK BOOKING: Cards are NOT charged until AFTER your clean.
            </div>
            <span class="hidden sm:inline mx-2 opacity-30">|</span>
            <div class="flex items-center">
              <Icon name="lock" class="w-5 h-5 mr-2 text-gray-400" />
              Secure 256-bit Encryption
            </div>
          </div>
          <iframe
            src="https://thevalleycleanteam.bookingkoala.com/booknow?embed=true"
            style="border:none;min-height:1000px"
            width="100%"
            scrolling="no"
            title="Book a cleaning service"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- Trust Section -->
    <section class="py-16 px-6 bg-gray-50">
      <div class="container mx-auto max-w-4xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-[#333333] mb-4">The Valley Clean Team Difference</h2>
          <p class="text-gray-500 max-w-xl mx-auto">Experience the precision and care that comes with a veteran-owned, community-focused team.</p>
          <div class="section-divider mt-6"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center">
              <Icon name="shield-halved" class="w-6 h-6  text-[#333333]" />
            </div>
            <h3 class="text-xl font-bold text-[#333333] mb-2">Insured & Bonded</h3>
            <p class="text-gray-600">Your home is protected. All our cleaners are fully insured and background checked.</p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center">
              <Icon name="star" class="w-6 h-6  text-[#333333]" fill="currentColor" />
            </div>
            <h3 class="text-xl font-bold text-[#333333] mb-2">130+ 5-Star Reviews</h3>
            <p class="text-gray-600">Our customers love us. See why we're the top-rated cleaning service in the area.</p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center">
              <Icon name="flag-usa" class="w-6 h-6  text-[#333333]" />
            </div>
            <h3 class="text-xl font-bold text-[#333333] mb-2">Veteran Owned</h3>
            <p class="text-gray-600">Proudly veteran-owned and operated with military precision and dedication.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Alternative -->
    <section class="py-16 px-6">
      <div class="container mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-bold text-[#333333] mb-4">Prefer to Talk to Someone?</h2>
        <p class="text-gray-600 mb-6">No problem! Our friendly team is here to help you schedule your cleaning.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="tel:2568261100" class="btn-primary px-8 py-3 rounded-full text-lg font-semibold inline-flex items-center justify-center">
            <Icon name="phone" class="w-5 h-5 mr-2" />
            256-826-1100
          </a>
          <a href="/contact" class="btn-secondary px-8 py-3 rounded-full text-lg font-semibold inline-flex items-center justify-center">
            <Icon name="envelope" class="w-5 h-5 mr-2" />
            Contact Us
          </a>
        </div>
      </div>
    </section>
  

  

  <script src="https://thevalleycleanteam.bookingkoala.com/resources/embed.js" defer></script>
</BaseLayout>
