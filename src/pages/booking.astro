---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Book Your Premium Cleaning - Schedule Online"
  description="Book your military-precision cleaning service online in minutes. Choose your service, select a time, and get instant confirmation. Top-rated in Northern Alabama and Middle Tennessee."
  showNav={false}
>
  <!-- Funnel Header (Removes navigation to keep users trapped on page) -->
  <header class="absolute top-0 w-full z-50 border-b border-white/10 mt-0">
    <div class="container mx-auto px-6 py-6 flex justify-center items-center">
      <div class="flex flex-col items-center">
        <span class="font-playfair text-2xl md:text-3xl font-bold text-[#FFA985]">
          The Valley Clean Team
        </span>
        <span class="text-xs text-gray-400 uppercase tracking-[0.2em] mt-1 font-semibold">
          Secure Online Booking
        </span>
      </div>
    </div>
  </header>

  <!-- Premium Hero Section -->
  <section class="relative pt-36 pb-24 overflow-hidden bg-gray-900">
    <!-- Background Elements -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-800 to-black opacity-90"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#FFA985]/10 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#FFC67D]/10 rounded-full blur-[80px] translate-y-1/2 -translate-x-1/2"></div>
    </div>

    <div class="container relative z-10 mx-auto px-6 max-w-4xl text-center">
      <span class="inline-block px-4 py-1.5 rounded-full bg-[#FFA985]/20 text-[#FFA985] text-sm font-bold tracking-wider uppercase mb-6 shadow-[0_0_15px_rgba(255,169,133,0.3)]">
        Instant Online Booking
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 leading-tight tracking-tight">
        Schedule Your Perfect <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#FFA985] to-[#FFC67D] drop-shadow-sm">Clean Today</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 mb-10 max-w-2xl mx-auto font-light leading-relaxed">
        Reclaim your time. Pick a date, choose a package, and experience our veteran-owned, military-precision standards.
      </p>
      
      <!-- Value Props -->
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-base font-medium text-gray-200">
        <span class="flex items-center bg-white/5 px-4 py-2 rounded-lg border border-white/10 backdrop-blur-sm">
          <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
          Upfront Pricing
        </span>
        <span class="flex items-center bg-white/5 px-4 py-2 rounded-lg border border-white/10 backdrop-blur-sm">
          <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
          Guaranteed Results
        </span>
        <span class="flex items-center bg-white/5 px-4 py-2 rounded-lg border border-white/10 backdrop-blur-sm">
          <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
          Secure Payment
        </span>
      </div>
    </div>
  </section>

  <!-- Form Section -->
  <section class="relative -mt-10 pb-24 px-6 z-20">
    <div class="container mx-auto max-w-7xl">
      <!-- Glassmorphic Booking Container -->
      <div class="bg-white/90 backdrop-blur-xl rounded-3xl shadow-2xl border border-white overflow-hidden">
        <!-- The user's provided BookingKoala embed -->
        <iframe 
          src="https://thevalleycleanteam.bookingkoala.com/booknow?embed=true" 
          style="border:none;height:1000px" 
          width="100%" 
          scrolling="no"
          title="Online Scheduling Widget"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Trust Indicators -->
  <section class="py-20 px-6 bg-gradient-to-b from-white to-gray-50 border-t border-gray-100">
    <div class="container mx-auto max-w-7xl">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4 tracking-tight">The Valley Clean Team Standard</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">We don't cut corners; we clean them. Our reputation is built on accountability, precision, and delivering exactly what we promise.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-10">
        <div class="group p-8 rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-xl transition duration-300">
          <div class="w-16 h-16 mb-6 rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 flex items-center justify-center shadow-lg group-hover:-translate-y-1 transition transform duration-300">
            <Icon name="shield-halved" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Vetted & Insured</h3>
          <p class="text-gray-600 leading-relaxed font-light">Every specialist who steps into your home has passed rigorous background checks and is covered by comprehensive insurance.</p>
        </div>

        <div class="group p-8 rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-xl transition duration-300">
          <div class="w-16 h-16 mb-6 rounded-2xl bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center shadow-lg group-hover:-translate-y-1 transition transform duration-300">
            <Icon name="star" class="w-8 h-8 text-gray-900" fill="currentColor" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">130+ 5-Star Reviews</h3>
          <p class="text-gray-600 leading-relaxed font-light">Join hundreds of satisfied residents and local businesses who trust our meticulous standards week after week.</p>
        </div>

        <div class="group p-8 rounded-2xl bg-white border border-gray-100 shadow-sm hover:shadow-xl transition duration-300">
          <div class="w-16 h-16 mb-6 rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 flex items-center justify-center shadow-lg group-hover:-translate-y-1 transition transform duration-300">
            <Icon name="flag-usa" class="w-8 h-8 text-[#FFA985]" />
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-3">Veteran Owned</h3>
          <p class="text-gray-600 leading-relaxed font-light">We operate with the integrity and precision instilled by military service. We do what we say we're going to do.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Alternative Contact -->
  <section class="py-24 px-6 bg-gray-900 text-center text-white">
    <div class="container mx-auto max-w-2xl">
      <h2 class="text-3xl md:text-4xl font-bold mb-6 tracking-tight">Have Unique Requirements?</h2>
      <p class="text-xl text-gray-300 mb-10 font-light">
        If you need a custom quote for a large facility or simply prefer speaking with a human, our team is standing by to assist you.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="tel:2568261100" class="w-full sm:w-auto px-8 py-4 rounded-full bg-gradient-to-r from-[#FFA985] to-[#FFC67D] text-gray-900 text-lg font-bold shadow-[0_4px_14px_rgba(255,169,133,0.4)] hover:shadow-[0_6px_20px_rgba(255,169,133,0.6)] hover:-translate-y-1 transition-all duration-300 flex items-center justify-center">
          <Icon name="phone" class="w-5 h-5 mr-3" />
          Call (256) 826-1100
        </a>
        <a href="/contact" class="w-full sm:w-auto px-8 py-4 rounded-full bg-white/10 text-white text-lg font-bold border border-white/20 hover:bg-white/20 transition-all duration-300 flex items-center justify-center backdrop-blur-sm">
          <Icon name="envelope" class="w-5 h-5 mr-3" />
          Contact Support
        </a>
      </div>
    </div>
  </section>

  <!-- Required scripts from BookingKoala -->
  <script src="https://thevalleycleanteam.bookingkoala.com/resources/embed.js" defer></script>
</BaseLayout>
