---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";

const today = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout 
  title="Privacy Policy | The Valley Clean Team"
  description="Privacy Policy for The Valley Clean Team. Learn how we protect your personal information and ensure data security for our clients in Alabama and Tennessee."
>
  <div class="pt-32 pb-20 px-6">
    <div class="container mx-auto max-w-4xl">
      <!-- Header Section -->
      <div class="text-center mb-16">
        <h1 class="text-5xl md:text-6xl font-bold mb-4 text-[#333333]">Privacy <span class="gold-gradient">Policy</span></h1>
        <div class="section-divider"></div>
        <p class="text-gray-500 italic">Last Updated: {today}</p>
      </div>

      <!-- Main Content -->
      <div class="bg-white rounded-3xl p-8 md:p-12 shadow-xl border border-gray-100 prose prose-slate max-w-none">
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="info-circle" class="w-6 h-6 text-[#FFA985] mr-3" />
            1. Introduction
          </h2>
          <p class="text-gray-600 leading-relaxed">
            At <strong>The Valley Clean Team</strong>, we value your privacy and are committed to protecting your personal data. This Privacy Policy explains how we collect, use, and safeguard your information when you visit our website, book our cleaning services, or communicate with us.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="database" class="w-6 h-6 text-[#FFA985] mr-3" />
            2. Information We Collect
          </h2>
          <p class="text-gray-600 mb-4">We may collect several types of information from and about users of our services, including:</p>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2 mt-1 flex-shrink-0" />
              <span><strong>Contact Information:</strong> Name, physical address, email address, and phone number.</span>
            </li>
            <li class="flex items-start">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2 mt-1 flex-shrink-0" />
              <span><strong>Service Details:</strong> Information about your home or office layout, pets, specific cleaning preferences, and entry instructions (like alarm codes or key locations).</span>
            </li>
            <li class="flex items-start">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2 mt-1 flex-shrink-0" />
              <span><strong>Payment Information:</strong> We use secure, third-party payment processors to handle credit card transactions. We do not store full credit card numbers on our servers.</span>
            </li>
            <li class="flex items-start">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2 mt-1 flex-shrink-0" />
              <span><strong>Technical Data:</strong> IP address, browser type, and usage patterns collected via cookies and similar tracking technologies when you browse our site.</span>
            </li>
          </ul>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="cog" class="w-6 h-6 text-[#FFA985] mr-3" />
            3. How We Use Your Information
          </h2>
          <p class="text-gray-600 mb-4">We use the information we collect for various purposes, including:</p>
          <ul class="space-y-3 text-gray-600">
            <li>To provide, maintain, and improve our luxury cleaning services.</li>
            <li>To schedule and manage your cleaning appointments.</li>
            <li>To process payments and provide invoices.</li>
            <li>To communicate with you about your service, including reminders and follow-ups.</li>
            <li>To send marketing communications (which you can opt-out of at any time).</li>
            <li>To respond to your inquiries and offer customer support.</li>
          </ul>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="share-alt" class="w-6 h-6 text-[#FFA985] mr-3" />
            4. Sharing Your Information
          </h2>
          <p class="text-gray-600 mb-4">
            We do not sell or rent your personal information to third parties. We may share your information with:
          </p>
          <ul class="space-y-3 text-gray-600">
            <li><strong>Service Providers:</strong> Contractors and employees who need the information to perform their cleaning duties.</li>
            <li><strong>Business Partners:</strong> Third-party tools we use for scheduling, CRM, and payment processing.</li>
            <li><strong>Legal Requirements:</strong> If required by law, we may disclose information to comply with legal processes or protect our rights.</li>
          </ul>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="shield" class="w-6 h-6 text-[#FFA985] mr-3" />
            5. Data Security
          </h2>
          <p class="text-gray-600 leading-relaxed">
            We implement industry-standard security measures to protect your information, including secure servers and encrypted communication for payment info. Our team is trained on the importance of maintaining client confidentiality, especially regarding home access codes and personal space.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="mouse-pointer" class="w-6 h-6 text-[#FFA985] mr-3" />
            6. Cookies and Tracking
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Our website uses cookies to enhance your experience. These cookies help us understand how you use our site and allow us to remember your preferences. You can adjust your browser settings to refuse cookies, though some features of the site may not function properly as a result.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="user-check" class="w-6 h-6 text-[#FFA985] mr-3" />
            7. Your Rights
          </h2>
          <p class="text-gray-600 mb-4">
            You have the right to:
          </p>
          <ul class="space-y-3 text-gray-600">
            <li>Access the personal data we hold about you.</li>
            <li>Request corrections to any inaccurate information.</li>
            <li>Request deletion of your data (subject to legal or contractual obligations).</li>
            <li>Opt-out of marketing communications by clicking "unsubscribe" in our emails or contacting us directly.</li>
          </ul>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="envelope" class="w-6 h-6 text-[#FFA985] mr-3" />
            8. Contact Us
          </h2>
          <p class="text-gray-600 mb-6">
            If you have questions about this Privacy Policy or our practices, please reach out to us:
          </p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
              <p class="font-bold text-[#333333] mb-1">Email</p>
              <a href="mailto:hello@thevalleycleanteam.com" class="text-[#FFA985] hover:underline">hello@thevalleycleanteam.com</a>
            </div>
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
              <p class="font-bold text-[#333333] mb-1">Phone</p>
              <a href="tel:2568261100" class="text-[#FFA985] hover:underline">256-826-1100</a>
            </div>
          </div>
        </section>
      </div>

      <!-- Back to Home -->
      <div class="mt-12 text-center">
        <a href="/" class="inline-flex items-center text-[#FFA985] font-semibold hover:underline">
          <Icon name="arrow-left" class="w-4 h-4 mr-2" />
          Back to Home
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .gold-gradient {
    background: linear-gradient(135deg, #FFA985 0%, #FF8C61 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .section-divider {
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, #ffa985 0%, #ffc67d 100%);
    margin: 0 auto 1.5rem;
  }
</style>
