---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
---

<BaseLayout
  title="Page Not Found | Valley Clean Team"
  description="The page you're looking for doesn't exist. Find professional cleaning services in Alabama & Tennessee from The Valley Clean Team."
>
  <section class="pt-32 pb-20 px-6 min-h-screen flex items-center">
    <div class="container mx-auto max-w-2xl text-center">
      <div class="mb-8">
        <Icon name="home" class="w-20 h-20 text-[#FFA985] mx-auto mb-6" />
        <h1 class="text-6xl md:text-8xl font-bold text-[#FFA985] mb-4">404</h1>
        <h2 class="text-3xl md:text-4xl font-bold text-[#333333] mb-4">
          Page Not Found
        </h2>
        <p class="text-xl text-gray-600 mb-8">
          Looks like this page got cleaned away! The page you're looking for
          doesn't exist or may have moved.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a
          href="/"
          class="btn-primary px-8 py-4 rounded-full text-lg font-semibold inline-flex items-center justify-center"
        >
          <Icon name="home" class="w-5 h-5 mr-2" />
          Back to Home
        </a>
        <a
          href="/contact"
          class="border-2 border-[#FFA985] text-[#FFA985] hover:bg-[#FFA985] hover:text-white px-8 py-4 rounded-full text-lg font-semibold transition inline-flex items-center justify-center"
        >
          <Icon name="phone" class="w-5 h-5 mr-2" />
          Contact Us
        </a>
      </div>

      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <h3 class="text-xl font-bold text-[#333333] mb-4">
          Looking for cleaning services?
        </h3>
        <div class="grid sm:grid-cols-2 gap-4 text-left">
          <a
            href="/services"
            class="flex items-center text-gray-700 hover:text-[#FFA985] transition"
          >
            <Icon name="check" class="w-4 h-4 text-[#FFA985] mr-2 flex-shrink-0" />
            Our Services
          </a>
          <a
            href="/pricing"
            class="flex items-center text-gray-700 hover:text-[#FFA985] transition"
          >
            <Icon name="check" class="w-4 h-4 text-[#FFA985] mr-2 flex-shrink-0" />
            Pricing
          </a>
          <a
            href="/locations"
            class="flex items-center text-gray-700 hover:text-[#FFA985] transition"
          >
            <Icon name="check" class="w-4 h-4 text-[#FFA985] mr-2 flex-shrink-0" />
            Service Areas
          </a>
          <a
            href="/about"
            class="flex items-center text-gray-700 hover:text-[#FFA985] transition"
          >
            <Icon name="check" class="w-4 h-4 text-[#FFA985] mr-2 flex-shrink-0" />
            About Us
          </a>
        </div>
      </div>

      <p class="mt-8 text-gray-500">
        Need help? Call us at
        <a
          href="tel:2568261100"
          class="text-[#FFA985] font-semibold hover:underline">256-826-1100</a
        >
      </p>
    </div>
  </section>
</BaseLayout>
