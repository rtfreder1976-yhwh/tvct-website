            <Icon name="phone" class="w-5 h-5 mr-2" />
            Call Nashville: (615) 510-1427
          </a>
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-white/10 text-white font-bold rounded-full hover:bg-white/20 transition-colors text-lg border border-white/20">
