---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import Icon from '../../components/Icon.astro';

const publishDate = "December 9, 2025";
const modifiedDate = "April 29, 2026";
const author = "The Valley Clean Team";
const readTime = "12 min read";
const heroImage = "https://storage.googleapis.com/msgsndr/iKQIBhpKVL2XVPgU7HMd/media/6920802945dc047d65b4ec5d.png";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does move-out cleaning cost in Huntsville, AL?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Professional move-out cleaning in Huntsville typically costs $199–$400 depending on the size and condition of the property. This is almost always less than what Madison County property managers charge for cleaning deductions from your security deposit, which commonly run $400–$800 for a full clean."
      }
    },
    {
      "@type": "Question",
      "name": "What do Huntsville property managers check during move-out inspection?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Madison County property managers inspect: inside the oven and broiler drawer, range hood filters, refrigerator door gaskets, under and behind appliances, dishwasher drain filter, bathroom grout and caulking, exhaust fan covers, toilet base and behind the tank, shower door tracks, all baseboards, window tracks and blinds, light fixtures and ceiling fan blades, HVAC vents, and all closet interiors."
      }
    },
    {
      "@type": "Question",
      "name": "How long before my move-out date should I schedule cleaning?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Schedule your move-out clean for the day furniture is removed or the day after. Everything needs to be out first — you can't properly clean around furniture. Book professional cleaning at least 1 week in advance, as Huntsville move-out cleaners get booked quickly at month-end."
      }
    },
    {
      "@type": "Question",
      "name": "Does Alabama law protect tenants from unfair deposit deductions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Alabama landlords have 35 days to return your deposit with an itemized list of deductions. Deductions must be reasonable and documented. Normal wear and tear cannot be charged. Wrongful withholding can result in double damages. The best protection is a thorough professional clean that leaves nothing to dispute."
      }
    }
  ]
};
