          <a href="tel:2568261100" class="inline-flex items-center justify-center px-8 py-4 bg-[#FFA985] text-white font-bold rounded-full hover:bg-[#ff9a70] transition text-lg">
            <Icon name="phone" class="w-5 h-5 mr-2" />(256) 826-1100
          </a>
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-white border-2 border-white font-bold rounded-full hover:bg-white/10 transition text-lg">
            Get a Free Quote
          </a>
