---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SchemaMarkup from "../../components/SchemaMarkup.astro";
import Icon from "../../components/Icon.astro";

// Make this page dynamic via SSR
export const prerender = false;

const publishDate = new Date("May 4 2026");
const author = "The Valley Clean Team";
const readTime = "5 min read";

const isPublished = new Date().getTime() >= publishDate.getTime();

---

<BaseLayout
  title="What's in a Professional Move-In Clean?"
  description={isPublished ? "Moving into a new home in Huntsville, Nashville or the Shoals? See exactly what a professional move-in clean covers so your space is sanitized before you unpack." : "Coming Soon: What Is Included in a Professional Move-In Clean?"}
  noindex={!isPublished}
  ogImage="https://storage.googleapis.com/msgsndr/iKQIBhpKVL2XVPgU7HMd/media/6920802945dc047d65b4ec5d.png"
>
  <SchemaMarkup
    type="article"
    title="What Is Included in a Professional Move-In Clean?"
    description="Moving to a new home? Learn exactly what is included in a professional move-in clean to ensure your new space is sanitized before you unpack a single box."
    publishDate="May 4 2026"
    author={author}
  />
  <!-- Hero Section -->
  <section class="pt-24 pb-16 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="inline-block px-4 py-2 bg-[#FFA985]/20 text-[#FFA985] rounded-full text-sm font-medium mb-6">
          Educational/Checklist
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          What Is Included in a Professional Move-In Clean?
        </h1>
        <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
          {isPublished ? "Expert Cleaning Guide" : "Coming May 4 2026."}
        </p>
        <div class="flex items-center justify-center space-x-4 text-gray-400 mb-8">
          <span>May 4 2026</span>
          <span>•</span>
          <span>{readTime}</span>
          <span>•</span>
          <span>By {author}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content Toggle based on Published Date -->
  {isPublished ? (
    <article class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- DIRECT ANSWER BLOCK - Critical for AEO -->
        <div
          class="bg-[#FFA985]/10 border-l-4 border-[#FFA985] p-6 mb-8 rounded-r-lg"
        >
          <p class="text-lg text-gray-700 font-medium mb-0">
            <strong>Quick Answer:</strong> A professional move-in clean covers a
            top-to-bottom deep clean of your new home before you unpack—thorough
            dusting, full floor care, complete kitchen and bathroom
            sanitization, and interior window cleaning. The goal is a fresh,
            sanitized space with no trace of previous occupants.
          </p>
        </div>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">
          Why Invest in a Professional Move-In Clean?
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          Moving into a new home is an exciting chapter, but it can also be
          overwhelming. A professional move-in clean offers the peace of mind
          that your new space isn't just clean—it's pristine. As you prepare to
          settle in, our trained specialists handle every detail, following
          military-precision checklists so nothing gets missed. The Valley Clean
          Team delivers meticulous, veteran-owned service that upholds the
          highest standards across the Shoals and surrounding areas.
        </p>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">
          The Essentials of a Move-In Clean
        </h2>
        <p class="text-lg text-gray-600 mb-6">
          Our <a href="/services/move-in-out-cleaning" class="text-[#FFA985] hover:underline">move-in cleaning service</a> is designed to restore and protect your
          new home. Here's what you can expect:
        </p>
        <ul class="space-y-3 text-lg text-gray-600 list-disc pl-6 mb-8">
          <li>
            <strong>Thorough dusting:</strong> We dust all surfaces, including
            high-touch areas like light switches and door handles.
          </li>
          <li>
            <strong>Floor care:</strong> Floors are mopped, vacuumed, and
            polished to perfection, leaving no trace of previous occupants.
          </li>
          <li>
            <strong>Kitchen sanitization:</strong> From the inside of cabinets to
            appliances, every inch of the kitchen is cleaned and disinfected.
          </li>
          <li>
            <strong>Bathroom scrubbing:</strong> We sanitize, deodorize, and
            polish bathrooms, including tiles, toilets, and fixtures.
          </li>
          <li>
            <strong>Window cleaning:</strong> Interior windows are cleaned to let
            in the light and enhance your view.
          </li>
        </ul>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">
          Customized Cleaning for Every Home
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          At The Valley Clean Team, we recognize that each home is unique, so our
          approach is never one-size-fits-all. We offer tailored cleaning plans
          to meet the specific needs of your new home in the Shoals and
          surrounding areas. Whether it's a cozy apartment or a sprawling estate,
          our service is flexible and precise.
        </p>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">
          Additional Services
        </h2>
        <p class="text-lg text-gray-600 mb-6">
          Moving is a major investment. That's why we offer add-ons for those who
          want the complete package:
        </p>
        <div class="space-y-6 mb-8">
          <div class="bg-gray-50 p-6 rounded-xl">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Carpet Cleaning</h3>
            <p class="text-lg text-gray-600 mb-0">
              Deep-cleaning carpets for a truly fresh start in your new home.
            </p>
          </div>
          <div class="bg-gray-50 p-6 rounded-xl">
            <h3 class="text-xl font-bold text-gray-900 mb-3">
              Upholstery Cleaning
            </h3>
            <p class="text-lg text-gray-600 mb-0">
              Removing dust and allergens from your furniture before you settle
              in.
            </p>
          </div>
          <div class="bg-gray-50 p-6 rounded-xl">
            <h3 class="text-xl font-bold text-gray-900 mb-3">
              Exterior Window Cleaning
            </h3>
            <p class="text-lg text-gray-600 mb-0">
              Enhancing curb appeal with spotless windows inside and out.
            </p>
          </div>
        </div>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">
          Transparent Pricing
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          We believe clarity is crucial. Our pricing is transparent, with move-in
          cleaning packages starting at <strong>$125</strong>. We provide upfront
          quotes, so you know exactly what to expect—a clean start without
          surprises. If your new place needs extra attention, a <a href="/services/deep-cleaning" class="text-[#FFA985] hover:underline">deep clean</a>
          can be added to the scope.
        </p>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">
          Why Choose The Valley Clean Team?
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          As a veteran-owned and women-owned business, The Valley Clean Team is
          committed to excellence and accountability. We honor our promises,
          delivering results with integrity and precision, and our
          community-focused approach ensures your satisfaction is guaranteed.
        </p>

        <!-- CLOSING CTA -->
        <div class="bg-gray-900 p-8 rounded-xl text-center mt-12">
          <p class="text-2xl font-bold text-white mb-4">
            Reclaim Your Time—Book Your Move-In Clean Today
          </p>
          <p class="text-lg text-gray-300 mb-6">
            Don't let the stress of moving overshadow your excitement. Let our
            trained specialists handle the details so you can start your new
            chapter with confidence.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="tel:2568261100"
              class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white bg-[#FFA985] rounded-full hover:bg-[#ff9a70] transition"
            >
              <Icon name="phone" class="w-5 h-5 mr-2" />Call 256-826-1100
            </a>
            <a
              href="/contact"
              class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white border-2 border-white rounded-full hover:bg-white/10 transition"
            >
              Request Quote Online
            </a>
          </div>
        </div>
      </div>
    </article>
  ) : (
    <article class="py-16 bg-white border-t border-gray-100 shadow-inner">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 bg-gray-50 rounded-2xl">
        <div class="prose prose-lg max-w-none text-center">
          <Icon name="clock" class="w-16 h-16 text-[#FFA985] mx-auto mb-6" />
          <h2 class="text-3xl font-bold text-gray-800 mb-4 mt-0">Article Coming Soon!</h2>
          <p class="text-gray-600 m-0">This article is locked and scheduled to automatically publish on <br/><strong class="text-gray-800 text-xl">May 4 2026</strong>.<br/>Check back then!</p>
          <div class="mt-12">
            <a href="/blog" class="inline-flex items-center justify-center px-6 py-3 text-lg font-semibold text-white bg-[#FFA985] rounded-full hover:bg-[#ff9a70] transition shadow-md no-underline">
              Back to Blog
            </a>
          </div>
        </div>
      </div>
    </article>
  )}
</BaseLayout>
