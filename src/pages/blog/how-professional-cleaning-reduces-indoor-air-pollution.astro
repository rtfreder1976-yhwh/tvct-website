  ogImage="https://storage.googleapis.com/msgsndr/iKQIBhpKVL2XVPgU7HMd/media/6920802945dc047d65b4ec5d.png"
>
  <SchemaMarkup
    type="article"
    title="How Professional Cleaning Reduces Indoor Air Pollution"
    description="Breathe easier at home. Learn how regular professional cleaning significantly reduces indoor air pollution, dust mites, and allergens for a healthier family."
    publishDate="September 14 2026"
    author={author}
  />
  <!-- Hero Section -->
  <section class="pt-24 pb-16 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
