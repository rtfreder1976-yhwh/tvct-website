    type="article"
    title="Back-to-School Cleaning Reset for Busy Madison County Parents"
    description="Get your Madison County home ready for back-to-school with our ultimate cleaning reset guide for busy parents. Create a fresh, organized space for learning."
    publishDate="August 10 2026"
    author={author}
  />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero Section -->
  <section class="pt-24 pb-16 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="inline-block px-4 py-2 bg-[#FFA985]/20 text-[#FFA985] rounded-full text-sm font-medium mb-6">
          Pain Point
