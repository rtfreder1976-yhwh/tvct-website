---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";

const today = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title="Terms of Service | The Valley Clean Team"
  description="Terms of Service for The Valley Clean Team, including our Recruiting SMS Program terms and conditions for job applicants in Alabama and Tennessee."
>
  <div class="pt-32 pb-20 px-6">
    <div class="container mx-auto max-w-4xl">
      <!-- Header Section -->
      <div class="text-center mb-16">
        <h1 class="text-5xl md:text-6xl font-bold mb-4 text-[#333333]">Terms of <span class="gold-gradient">Service</span></h1>
        <div class="section-divider"></div>
        <p class="text-gray-500 italic">Last Updated: {today}</p>
      </div>

      <!-- Main Content -->
      <div class="bg-white rounded-3xl p-8 md:p-12 shadow-xl border border-gray-100 prose prose-slate max-w-none">
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="info-circle" class="w-6 h-6 text-[#FFA985] mr-3" />
            1. Introduction
          </h2>
          <p class="text-gray-600 leading-relaxed">
            These Terms of Service govern your use of <strong>The Valley Clean Team</strong> website and services. By accessing our site, booking our cleaning services, or communicating with us, you agree to these terms. Please review them along with our <a href="/privacy" class="text-[#FFA985] hover:underline">Privacy Policy</a>.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="comments" class="w-6 h-6 text-[#FFA985] mr-3" />
            2. The Valley Clean Team — Recruiting SMS Program Terms &amp; Conditions
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>Program name:</strong> The Valley Clean Team Recruiting SMS
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>Program description.</strong> When you apply to provide cleaning services through The Valley Clean Team and give us your mobile number with consent, we send you text messages about your application, screening questions, scheduling a trial clean, and onboarding. These are not marketing messages.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>Message frequency.</strong> Recurring messages; frequency varies based on your application and onboarding activity.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>Cost.</strong> Message and data rates may apply. The Valley Clean Team does not charge for the messages, but your mobile carrier's standard rates apply.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>To opt out.</strong> Reply STOP at any time to unsubscribe. You will receive one confirmation message and then no further texts. Reply START to resubscribe.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>For help.</strong> Reply HELP, or contact us at <a href="mailto:careers@thevalleycleanteam.com" class="text-[#FFA985] hover:underline">careers@thevalleycleanteam.com</a> or <a href="tel:2568261100" class="text-[#FFA985] hover:underline">(256) 826-1100</a>.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>Consent.</strong> Consent to receive text messages is not a condition of being hired or engaged. By providing your mobile number and agreeing to our SMS consent statement on our application, lead form, Indeed, or BookingKoala careers page, you agree to receive these messages.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>Privacy.</strong> We will not sell, rent, or share your mobile number or SMS opt-in consent with third parties or affiliates for marketing purposes. See our <a href="/privacy" class="text-[#FFA985] hover:underline">Privacy Policy</a>.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            <strong>Carriers.</strong> Carriers are not liable for delayed or undelivered messages.
          </p>
          <p class="text-gray-600 leading-relaxed">
            <strong>Supported carriers.</strong> AT&amp;T, T-Mobile, Verizon, and other major U.S. carriers.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-bold text-[#333333] mb-4 flex items-center">
            <Icon name="envelope" class="w-6 h-6 text-[#FFA985] mr-3" />
            3. Contact Us
          </h2>
          <p class="text-gray-600 mb-6">
            If you have questions about these Terms of Service, please reach out to us:
          </p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
              <p class="font-bold text-[#333333] mb-1">Email</p>
              <a href="mailto:hello@thevalleycleanteam.com" class="text-[#FFA985] hover:underline">hello@thevalleycleanteam.com</a>
            </div>
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
              <p class="font-bold text-[#333333] mb-1">Phone</p>
              <a href="tel:2568261100" class="text-[#FFA985] hover:underline">256-826-1100</a>
            </div>
          </div>
        </section>
      </div>

      <!-- Back to Home -->
      <div class="mt-12 text-center">
        <a href="/" class="inline-flex items-center text-[#FFA985] font-semibold hover:underline">
          <Icon name="arrow-left" class="w-4 h-4 mr-2" />
          Back to Home
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .gold-gradient {
    background: linear-gradient(135deg, #FFA985 0%, #FF8C61 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .section-divider {
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, #ffa985 0%, #ffc67d 100%);
    margin: 0 auto 1.5rem;
  }
</style>
