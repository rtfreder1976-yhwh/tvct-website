---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import QuoteForm from "../components/QuoteForm.astro";

// LocalBusiness schema for Commercial Quote page
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "The Valley Clean Team",
  url: "https://thevalleycleanteam.com",
  telephone: "256-826-1100",
  email: "hello@thevalleycleanteam.com",
  description: "Specialized commercial cleaning quotes for medical clinics, dental offices, and churches in Alabama and Tennessee.",
};
---

<BaseLayout
  title="Commercial Cleaning Quote | Valley Clean Team"
  description="Request a professional cleaning quote for your medical office, dental clinic, or church. Disciplined reliability for the Shoals & Huntsville area."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />

  <section class="pt-32 pb-20 px-6">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <h1 class="text-5xl md:text-6xl font-bold mb-4 text-[#333333]">
          Commercial <span class="gold-gradient">Solutions</span>
        </h1>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600">
          We take the burden of facility management off your desk. No morning cleaning "surprises," no staff complaints—just consistent, disciplined service so you can focus on your patients and community.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-gray-100">
        <!-- Quote Form -->
        <div>
          <h2 class="text-3xl font-bold mb-6 text-[#333333]">Quote Request</h2>
          <QuoteForm 
            formId="commercial-quote-form" 
            source="Commercial Specialty Form"
          />
          <p class="text-sm text-gray-500 mt-4 italic">
            *Our team will contact you within 2 business hours to schedule a facility walkthrough.
          </p>
        </div>

        <!-- Benefits/Trust -->
        <div class="space-y-8">
          <div>
            <h3 class="text-2xl font-bold mb-4 text-[#333333]">The Manager's Peace of Mind</h3>
            <p class="text-gray-600">
               We understand that as an Office Manager, you bear the brunt of any cleaning failure. We built TVCT to be the partner that eliminates those headaches before they start.
            </p>
          </div>

          <div class="space-y-4">
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">End the Staff Cleaning Complaints</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Zero "Consistency Fade" Guarantee</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Veteran-Led Professional Accountability</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">After-Hours Support & Reliability</span>
            </div>
          </div>

          <div class="pt-6 border-t border-gray-100">
             <h4 class="font-bold text-[#333333] mb-2 text-lg">Trust the TVCT Standard</h4>
             <p class="text-gray-600 italic">
               "We focus on the protocols others miss, so you can focus on your patients and community."
             </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
