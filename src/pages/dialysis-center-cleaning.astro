---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import QuoteForm from "../components/QuoteForm.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "The Valley Clean Team - Dialysis Center Sanitization",
  url: "https://thevalleycleanteam.com/dialysis-center-cleaning",
  telephone: "256-826-1100",
  email: "hello@thevalleycleanteam.com",
  description: "High-decibel, medical-grade sanitization for dialysis centers. Because clean isn't an aesthetic—it's a critical safety requirement.",
};
---

<BaseLayout
  title="Dialysis Center Cleaning & Sanitization | Valley Clean Team"
  description="Specialized high-decibel sanitization for sensitive facilities. We provide documented, disciplined reliability for dialysis centers."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />

  <section class="pt-32 pb-20 px-6">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <h1 class="text-5xl md:text-6xl font-bold mb-4 text-[#333333]">
          Dialysis Center <span class="gold-gradient">Sanitization</span>
        </h1>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600">
          We specialize in high-decibel sanitization for sensitive facilities. For your patients, "clean" isn't just an aesthetic—it’s a critical safety requirement.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-gray-100">
        <!-- Quote Form -->
        <div>
          <h2 class="text-3xl font-bold mb-6 text-[#333333]">Review Our Protocol</h2>
          <QuoteForm 
            formId="dialysis-quote-form" 
            source="Dialysis Center Landing Page"
          />
          <p class="text-sm text-gray-500 mt-4 italic">
            *Request a 10-minute walkthrough to see how our medical-grade protocols align with your center's requirements.
          </p>
        </div>

        <!-- Benefits/Trust -->
        <div class="space-y-8">
          <div>
            <h3 class="text-2xl font-bold mb-4 text-[#333333]">The Patient Safety Standard</h3>
            <p class="text-gray-600">
               We provide documented, disciplined reliability so you can focus on patient care without worrying about facility standards or compliance lapses.
            </p>
          </div>

          <div class="space-y-4">
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">High-Decibel Sanitization Procedures</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Cross-Contamination Prevention Guidelines</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Documented Cleaning Records</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Veteran-Led Quality Assurance</span>
            </div>
          </div>

          <div class="pt-6 border-t border-gray-100">
             <h4 class="font-bold text-[#333333] mb-2 text-lg">Trust the TVCT Standard</h4>
             <p class="text-gray-600 italic">
               "We bring military-grade discipline to medical safety, so your patients are never compromised."
             </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
