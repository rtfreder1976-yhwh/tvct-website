---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import QuoteForm from "../components/QuoteForm.astro";

// Enhanced LocalBusiness + FAQPage schema for Church Cleaning
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "The Valley Clean Team - Church & Ministry Cleaning Services",
  url: "https://thevalleycleanteam.com/church-cleaning",
  telephone: "256-826-1100",
  email: "hello@thevalleycleanteam.com",
  description: "Professional church cleaning services in Alabama and Tennessee. Sanctuary, fellowship hall, and ministry facility cleaning with veteran-owned reliability and faith-driven stewardship.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Tuscumbia",
    addressRegion: "AL",
    postalCode: "35674",
    addressCountry: "US"
  },
  areaServed: [
    { "@type": "City", name: "Florence, AL" },
    { "@type": "City", name: "Muscle Shoals, AL" },
    { "@type": "City", name: "Sheffield, AL" },
    { "@type": "City", name: "Tuscumbia, AL" },
    { "@type": "City", name: "Huntsville, AL" },
    { "@type": "City", name: "Madison, AL" },
    { "@type": "City", name: "Decatur, AL" }
  ]
};

const faqs = [
  {
    question: "What makes church cleaning different from regular office cleaning?",
    answer: "Churches require a reverent approach to sanctuaries, respect for sacred spaces, and understanding of facility layouts that include sanctuaries, fellowship halls, classrooms, and nurseries. We specialize in this unique environment and have built our reputation serving faith-based organizations."
  },
  {
    question: "How often should a church be cleaned?",
    answer: "Most churches benefit from weekly cleaning before Sunday services. High-traffic facilities with multiple events may need bi-weekly or additional deep cleaning. We'll assess your facility and recommend a schedule that keeps your space ready for worship and fellowship."
  },
  {
    question: "Can you work around our church schedule and events?",
    answer: "Absolutely. We offer flexible scheduling including evening, weekend, and event-based cleaning. We understand that your sanctuary needs to be pristine for Sunday morning, and we work around your calendar to make that happen."
  },
  {
    question: "Are your cleaners background-checked and trustworthy?",
    answer: "Yes. Every member of our team is fully background-checked, bonded, and vetted. We understand the importance of trust when entering a sacred space, and we take that responsibility seriously."
  },
  {
    question: "Do you have experience with large multi-building church campuses?",
    answer: "Yes. We've successfully managed everything from single-building churches to large multi-building campuses with sanctuaries, fellowship halls, classrooms, offices, and outdoor spaces. We customize our approach to your facility's unique layout."
  },
  {
    question: "What if we're currently using volunteers for cleaning?",
    answer: "We respect that many churches rely on volunteer teams. Professional cleaning can complement volunteer efforts by handling the deep cleaning and regular maintenance, freeing your volunteers to focus on ministry. Many churches find this hybrid approach works best."
  },
  {
    question: "How much does church cleaning cost?",
    answer: "Pricing depends on your facility size, frequency, and specific needs. We provide free, no-obligation facility walkthroughs and custom quotes. Most churches find our pricing competitive and the reliability invaluable."
  },
  {
    question: "What's included in your church cleaning service?",
    answer: "Standard service includes sanctuary vacuuming and dusting, fellowship hall cleaning, restroom sanitization, classroom tidying, trash removal, and floor care. We customize based on your facility's specific areas and needs."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Church Cleaning Services Alabama | Huntsville, Florence, Muscle Shoals | Valley Clean Team"
  description="Professional church and ministry cleaning in Alabama (Shoals, Huntsville, Madison, Decatur). Sanctuary, fellowship hall, and facility cleaning. Veteran-owned, background-checked, $2M insured. Free walkthrough."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />

  <section class="pt-32 pb-20 px-6">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <h1 class="text-5xl md:text-6xl font-bold mb-4 text-[#333333]">
          Church & Ministry <span class="gold-gradient">Cleaning Services</span>
        </h1>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600">
          Your facility is more than just a building—it's a sanctuary. We ensure your space is always ready for worship, fellowship, and first-time guests, so your staff can focus on ministry, not maintenance. Veteran-owned. Faith-driven. Disciplined reliability.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-gray-100">
        <!-- Quote Form -->
        <div>
          <h2 class="text-3xl font-bold mb-6 text-[#333333]">Request a Stewardship Walkthrough</h2>
          <QuoteForm 
            formId="church-quote-form" 
            source="Church Cleaning Landing Page"
          />
          <p class="text-sm text-gray-500 mt-4 italic">
            *We'll contact you within 2 business hours to schedule a complimentary facility review.
          </p>
        </div>

        <!-- Benefits/Trust -->
        <div class="space-y-8">
          <div>
            <h3 class="text-2xl font-bold mb-4 text-[#333333]">The Stewardship of Sanctuary</h3>
            <p class="text-gray-600">
               A clean, welcoming environment is the first thing a new visitor notices. We help local ministries maintain a standard of excellence that reflects your mission. Our veteran-owned team brings military discipline to every detail.
            </p>
          </div>

          <div class="space-y-4">
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Spotless Sanctuaries & Nurseries</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Ready for Fellowship & Events</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Reverent & Consistent Care</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Veteran-Led Accountability</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">Background-Checked Cleaners</span>
            </div>
            <div class="flex items-center space-x-4">
              <div class="w-10 h-10 rounded-full bg-[#FFA985]/10 flex items-center justify-center text-[#FFA985]">
                <Icon name="check" class="w-5 h-5" />
              </div>
              <span class="font-semibold text-[#333333]">$2M Liability Insurance</span>
            </div>
          </div>

          <div class="pt-6 border-t border-gray-100">
             <h4 class="font-bold text-[#333333] mb-2 text-lg">Our Promise to Your Ministry</h4>
             <p class="text-gray-600 italic">
               "We handle the details quietly and dependably, ensuring your building always serves your core mission."
             </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-20 px-6 bg-gradient-to-br from-gray-50 to-white">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Serving Churches Across <span class="gold-gradient">Alabama</span>
        </h2>
        <div class="section-divider"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {
          [
            { city: "Florence", county: "Lauderdale" },
            { city: "Muscle Shoals", county: "Colbert" },
            { city: "Sheffield", county: "Colbert" },
            { city: "Tuscumbia", county: "Colbert" },
            { city: "Huntsville", county: "Madison" },
            { city: "Madison", county: "Madison" },
            { city: "Decatur", county: "Morgan" },
          ].map((area) => (
            <div class="bg-white rounded-xl p-6 shadow-md border border-gray-200 text-center">
              <Icon name="map-marker-alt" class="w-6 h-6 text-[#FFA985] mx-auto mb-3" />
              <p class="font-semibold text-[#333333]">{area.city}</p>
              <p class="text-sm text-gray-500">{area.county} County</p>
            </div>
          ))
        }
      </div>

      <div class="text-center mt-12">
        <p class="text-gray-600">
          <Icon name="phone" class="w-5 h-5 text-[#FFA985] mr-2" />
          Serving other areas? Call <a
            href="tel:2568261100"
            class="text-[#FFA985] font-semibold hover:underline">256-826-1100</a
          >
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Church Cleaning <span class="gold-gradient">FAQs</span>
        </h2>
        <div class="section-divider"></div>
      </div>

      <div class="space-y-4">
        {
          faqs.map((faq, index) => (
            <div
              class="faq-item bg-white rounded-xl p-6 shadow-md border border-gray-200 cursor-pointer"
              onclick="this.classList.toggle('active')"
            >
              <div class="flex justify-between items-center">
                <h3 class="font-bold text-[#333333] pr-4">{faq.question}</h3>
                <Icon
                  name="chevron-down"
                  class="w-5 h-5 text-[#FFA985] faq-icon flex-shrink-0"
                />
              </div>
              <div class="faq-answer">
                <p class="text-gray-600 mt-4">{faq.answer}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-gradient-to-br from-[#FFA985]/10 to-gray-100">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-[#333333]">
        Ready for a <span class="gold-gradient">Cleaner Sanctuary</span>?
      </h2>
      <p class="text-xl text-gray-600 mb-8">
        Get a free walkthrough and customized cleaning plan for your church or ministry
      </p>
      <div
        class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-6 mb-8"
      >
        <a
          href="tel:2568261100"
          class="btn-primary px-12 py-5 rounded-full text-xl font-semibold inline-block shadow-lg"
        >
          <Icon name="phone" class="w-5 h-5 mr-2" />Call 256-826-1100
        </a>
        <a
          href="/#quote-form"
          class="flex items-center text-gray-700 hover:text-[#FFA985] transition text-lg font-semibold px-8 py-5 bg-white border-2 border-gray-300 rounded-full shadow-md"
        >
          <Icon name="envelope" class="w-5 h-5 mr-2" />Request Walkthrough
        </a>
      </div>
      <p class="text-gray-600">
        <Icon name="clock" class="w-5 h-5 text-[#FFA985] mr-2" />
        We respond to all church inquiries within 2 business hours
      </p>
    </div>
  </section>
</BaseLayout>
