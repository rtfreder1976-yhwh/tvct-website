---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SchemaMarkup from "../../components/SchemaMarkup.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import Icon from "../../components/Icon.astro";

const title = "Regular House Cleaning Huntsville AL | Weekly & Bi-Weekly Maid Service";
const description =
  "Trusted recurring maid service in Huntsville, AL & Nashville, TN. Weekly, bi-weekly & monthly plans. Save 20% on recurring bookings. Veteran-owned, 130+ 5-star reviews.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Regular Cleaning & Maid Service",
  description:
    "Professional maid services and recurring house cleaning plans. Weekly, bi-weekly, and monthly options with consistent, reliable cleaners.",
  provider: {
    "@type": "LocalBusiness",
    name: "The Valley Clean Team",
    telephone: "256-826-1100",
    email: "hello@thevalleycleanteam.com",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Huntsville",
      addressRegion: "AL",
      addressCountry: "US",
    },
  },
  areaServed: [
    { "@type": "State", name: "Alabama" },
    { "@type": "State", name: "Tennessee" },
  ],
  serviceType: "Maid Service",
  offers: {
    "@type": "Offer",
    priceSpecification: {
      "@type": "PriceSpecification",
      price: "125",
      priceCurrency: "USD",
      minPrice: "125",
    },
    availability: "https://schema.org/InStock",
  },
};

const faqs = [
  {
    question:
      "What is the difference between a maid service and regular cleaning?",
    answer:
      "We use the terms interchangeably! Our maid service provides the consistent, personalized attention you'd expect from a dedicated maid, backed by the reliability, insurance, and professionalism of a top-rated company.",
  },
  {
    question: "How often should I schedule regular cleaning?",
    answer:
      "It depends on your lifestyle. Families with kids or pets benefit from weekly maid service. Most households do well with bi-weekly visits. Monthly cleaning works for smaller homes or those who maintain well between visits.",
  },
  {
    question: "What's included in your maid service?",
    answer:
      "Our maid service covers all essential areas: vacuuming, mopping, dusting, bathroom sanitizing, kitchen cleaning, and trash removal. It maintains your home's cleanliness and order between deep cleans.",
  },
  {
    question: "Can I customize my maid service?",
    answer:
      "Absolutely! We tailor each visit to your priorities. Focus on certain rooms, add specific tasks, or skip areas you handle yourself. Your cleaning, your way.",
  },
  {
    question: "Do I need a deep clean first?",
    answer:
      "We recommend starting with a deep clean if your home hasn't been professionally cleaned recently. This gives our maid team a clean baseline to maintain.",
  },
  {
    question: "What if I need to skip or reschedule?",
    answer:
      "Life happens! Just give us 24-48 hours notice and we'll reschedule at no charge. We're flexible and understand schedules change.",
  },
  {
    question: "Will I have the same cleaner each time?",
    answer:
      "We prioritize consistency. You'll typically have the same maid or team for each visit, so they learn your home and preferences.",
  },
  {
    question: "How do I save with recurring service?",
    answer:
      "Weekly service saves 20%, bi-weekly saves 15%, and monthly saves 10% compared to one-time cleaning rates. The more frequent, the bigger the discount.",
  },
  {
    question: "Are your cleaners background checked?",
    answer:
      "Yes, every maid service team member undergoes thorough background checks. We're also fully insured with $2M liability coverage and bonded for your protection.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const cleaningTasks = [
  {
    section: "All Rooms",
    icon: "check-double",
    tasks: [
      "Empty trash",
      "Sweep/vacuum floors (carpet + hard surfaces)",
      "Mop floors (hard surfaces)",
      "Dust shelves",
      "Dust blinds, windows, window sills",
      "Wipe & clean mirrors",
      "Wipe & clean light switches",
      "Dust furniture/lamps",
    ],
  },
  {
    section: "Kitchen",
    icon: "kitchen-set",
    tasks: [
      "Inside/outside of microwave oven",
      "Clean backsplash",
      "Exterior of trash can",
      "Outside of stove hood",
      "Clean stovetop",
      "Countertops",
      "Clean sink & chrome",
      "Exterior of cabinets & drawers",
      "Pantry floor & door",
      "Tables and chairs",
      "Outside of appliances",
    ],
  },
  {
    section: "Bathrooms",
    icon: "bath",
    tasks: [
      "Clean shower",
      "Clean tub",
      "Polish faucets",
      "Clean sinks",
      "Clean toilet and toilet area",
      "Clean counters",
      "Dust ledges",
      "Exterior of cabinets and drawers",
      "Vacuum rugs",
    ],
  },
  {
    section: "Bedrooms",
    icon: "bed",
    tasks: [
      "Make beds (change linen if available)",
      "Vacuum rugs",
      "Exterior of cabinets and drawers",
      "Dust ledges",
    ],
  },
  {
    section: "Laundry Room",
    icon: "shirt",
    tasks: [
      "Dust and wipe the outside of washer & dryer",
      "Clean sinks",
      "Vacuum rugs",
      "Countertops",
      "Dust ledges",
    ],
  },
  {
    section: "Dining Room",
    icon: "utensils",
    tasks: ["Dust ledges", "Tables & chairs"],
  },
  {
    section: "Living Room",
    icon: "couch",
    tasks: [
      "Dust ledges",
      "Exterior of cabinets & drawers",
    ],
  },
  {
    section: "Office",
    icon: "briefcase",
    tasks: [
      "Dust ledges",
      "Vacuum rugs",
      "Exterior of cabinets & drawers",
    ],
  },
];

const pricingPlans = [
  {
    name: "Weekly",
    discount: "20% OFF",
    description: "Best for families, pet owners, or busy households",
    features: [
      "Same cleaner each week",
      "Priority scheduling",
      "Maximum savings",
      "Always guest-ready",
    ],
    popular: false,
  },
  {
    name: "Bi-Weekly",
    discount: "15% OFF",
    description: "Most popular - perfect balance of clean and cost",
    features: [
      "Consistent cleaner",
      "Flexible scheduling",
      "Great savings",
      "Maintains cleanliness",
    ],
    popular: true,
  },
  {
    name: "Monthly",
    discount: "10% OFF",
    description: "Ideal for smaller homes or light maintenance",
    features: [
      "Thorough monthly reset",
      "Budget-friendly",
      "Easy scheduling",
      "Refreshes your space",
    ],
    popular: false,
  },
];

const benefits = [
  {
    icon: "clock",
    title: "Reclaim Your Time",
    description:
      "Stop spending weekends cleaning. We handle it so you can enjoy life.",
  },
  {
    icon: "heart",
    title: "Healthier Home",
    description:
      "Regular cleaning reduces allergens, dust, and bacteria for a healthier environment.",
  },
  {
    icon: "smile",
    title: "Less Stress",
    description:
      "Come home to a clean house every time. No more cleaning guilt or overwhelm.",
  },
  {
    icon: "piggy-bank",
    title: "Save Money",
    description:
      "Regular maintenance extends the life of carpets, floors, and fixtures.",
  },
  {
    icon: "users",
    title: "Always Guest-Ready",
    description:
      "Unexpected visitors? No problem. Your home is always presentable.",
  },
  {
    icon: "leaf",
    title: "Eco-Friendly Options",
    description:
      "Green cleaning products available upon request for sensitive households.",
  },
];

const serviceAreas = [
  { name: "Huntsville", link: "/locations/huntsville/recurring-maid-service" },
  { name: "Madison", link: "/locations/madison/recurring-maid-service" },
  { name: "Athens", link: "/locations/athens/recurring-maid-service" },
  { name: "Florence", link: "/locations/florence/recurring-maid-service" },
  { name: "Decatur", link: "/locations/decatur/recurring-maid-service" },
  {
    name: "Muscle Shoals",
    link: "/locations/muscle-shoals/recurring-maid-service",
  },
  { name: "Mountain Brook", link: "/locations/mountain-brook" },
  {
    name: "Mountain Brook",
    link: "/locations/mountain-brook/recurring-maid-service",
  },
  { name: "Nashville", link: "/locations/nashville/recurring-maid-service" },
  {
    name: "West Nashville",
    link: "/locations/west-nashville/recurring-maid-service",
  },
];
const commonProblems = [
  {
    icon: "clock",
    problem: "Weekends Gone to Cleaning",
    solution: "Saturday morning shouldn't mean three hours of vacuuming and scrubbing. Recurring maid service means you come home to a clean house without giving up your free time to create it.",
  },
  {
    icon: "broom",
    problem: "Cleaning That Never Catches Up",
    solution: "When you only clean when it's visibly dirty, you're always starting behind. A regular cleaning schedule changes the baseline — each visit maintains a higher standard instead of recovering from a week of accumulation.",
  },
  {
    icon: "users",
    problem: "Rotating Cleaners, Inconsistent Results",
    solution: "Different person every time means different standards every time. We assign the same cleaning professional to your home so results stay consistent and the service gets better as they learn your space.",
  },
  {
    icon: "heart",
    problem: "A Home That Never Feels Clean Enough",
    solution: "There's a difference between picked up and actually clean. Professional recurring cleaning addresses the surfaces, the floors, the bathrooms, and the kitchen on a schedule that keeps everything genuinely maintained.",
  },
];
import BookingCTA from "../../components/BookingCTA.astro";
---

<BaseLayout title={title} description={description} ogImage="https://storage.googleapis.com/msgsndr/iKQIBhpKVL2XVPgU7HMd/media/6920802945dc047d65b4ec5d.png">
  <SchemaMarkup type="organization" />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-br from-white to-gray-50">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div
            class="inline-block bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 px-4 py-2 rounded-full mb-4"
          >
            <span class="text-[#FFA985] font-semibold">
              <Icon name="calendar-check" class="w-5 h-5 mr-2" />Save Up to 20%
              with Recurring Service
            </span>
          </div>
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-[#333333]"
          >
            Professional <span class="gold-gradient">Regular Cleaning</span> & Maid
            Services
          </h1>
          <p class="text-xl text-gray-700 mb-6">
            Keep your home consistently clean with our reliable recurring maid
            service. Weekly, bi-weekly, or monthly visits tailored to your
            lifestyle and budget. Never come home to a messy house again.
          </p>
          <div class="flex flex-wrap gap-4 mb-8">
            <div class="flex items-center text-gray-700">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span>Same Cleaner Each Visit</span>
            </div>
            <div class="flex items-center text-gray-700">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span>Flexible Scheduling</span>
            </div>
            <div class="flex items-center text-gray-700">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span>No Contracts Required</span>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="tel:2568261100"
              class="btn-primary px-8 py-4 rounded-full text-lg font-semibold text-center shadow-lg"
            >
              <Icon name="phone" class="w-5 h-5 mr-2" />Call 256-826-1100
            </a>
            <a
              href="/#quote-form"
              class="btn-secondary px-8 py-4 rounded-full text-lg font-semibold text-center"
            >
              Get Free Quote
            </a>
          </div>
        </div>

        <!-- Pricing Card -->
        <div
          class="bg-white rounded-2xl p-8 shadow-2xl border-2 border-[#FFA985]/20"
        >
          <div class="text-center mb-6">
            <h3 class="text-2xl font-bold text-[#333333] mb-2">
              Regular Cleaning Pricing
            </h3>
            <p class="text-gray-600">Affordable plans for every budget</p>
          </div>

          <div class="space-y-4 mb-6">
            <div
              class="flex justify-between items-center p-4 bg-gray-50 rounded-xl"
            >
              <div>
                <h4 class="font-bold text-[#333333]">Small Home</h4>
                <p class="text-sm text-gray-600">Up to 1,500 sq ft</p>
              </div>
              <div class="text-right">
                <span class="text-2xl font-bold text-[#FFA985]">From $176</span>
              </div>
            </div>

            <div
              class="flex justify-between items-center p-4 bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 rounded-xl border-2 border-[#FFA985]"
            >
              <div>
                <h4 class="font-bold text-[#333333]">Medium Home</h4>
                <p class="text-sm text-gray-600">1,500 - 2,500 sq ft</p>
              </div>
              <div class="text-right">
                <span class="text-2xl font-bold text-[#FFA985]">From $281</span>
                <p class="text-xs text-gray-600">Most Popular</p>
              </div>
            </div>

            <div
              class="flex justify-between items-center p-4 bg-gray-50 rounded-xl"
            >
              <div>
                <h4 class="font-bold text-[#333333]">Large Home</h4>
                <p class="text-sm text-gray-600">2,500 - 4,000 sq ft</p>
              </div>
              <div class="text-right">
                <span class="text-2xl font-bold text-[#FFA985]">From $436</span>
              </div>
            </div>

            <div
              class="flex justify-between items-center p-4 bg-gray-50 rounded-xl"
            >
              <div>
                <h4 class="font-bold text-[#333333]">XL Home</h4>
                <p class="text-sm text-gray-600">4,000+ sq ft</p>
              </div>
              <div class="text-right">
                <span class="text-2xl font-bold text-[#FFA985]">From $656</span>
              </div>
            </div>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6">
            <p class="text-green-800 text-sm text-center">
              <Icon name="tag" class="w-5 h-5 mr-2" />
              <strong>Weekly = 20% OFF</strong> | Bi-Weekly = 15% OFF | Monthly =
              10% OFF
            </p>
          </div>

          <BookingCTA variant="card" />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <section class="py-8 px-6 bg-gray-50">
    <div class="container mx-auto">
      <TrustBadges variant="full" showGuarantee={true} />
    </div>
  </section>

  <!-- Pricing Plans -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Choose Your <span class="gold-gradient">Cleaning Schedule</span>
        </h2>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Pick the frequency that works for your lifestyle. All plans include
          our full regular cleaning service.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {
          pricingPlans.map((plan) => (
            <div
              class={`bg-white rounded-2xl p-8 shadow-lg border-2 ${plan.popular ? "border-[#FFA985] relative" : "border-gray-200"} hover:shadow-xl transition-shadow`}
            >
              {plan.popular && (
                <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                  <span class="bg-gradient-to-r from-[#FFA985] to-[#FFC67D] text-white px-4 py-1 rounded-full text-sm font-bold">
                    Most Popular
                  </span>
                </div>
              )}
              <div class="text-center mb-6">
                <h3 class="text-2xl font-bold text-[#333333] mb-2">
                  {plan.name}
                </h3>
                <div class="inline-block bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-bold mb-3">
                  {plan.discount}
                </div>
                <p class="text-gray-600 text-sm">{plan.description}</p>
              </div>
              <ul class="space-y-3 mb-8">
                {plan.features.map((feature) => (
                  <li class="flex items-center text-gray-700">
                    <Icon name="check" class="w-5 h-5 text-[#FFA985] mr-3" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href="/#quote-form"
                class={`w-full py-3 rounded-lg text-center block font-semibold ${plan.popular ? "btn-primary" : "btn-secondary"}`}
              >
                Get Started
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          What's <span class="gold-gradient">Included</span>
        </h2>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Every regular cleaning visit covers all the essentials to keep your
          home fresh and tidy
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          cleaningTasks.map((room) => (
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-shadow">
              <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                <Icon name={room.icon} class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-xl font-bold mb-4 text-[#333333]">
                {room.section}
              </h3>
              <ul class="space-y-2">
                {room.tasks.map((task) => (
                  <li class="flex items-start text-gray-600 text-sm">
                    <Icon
                      name="check"
                      class="w-5 h-5 text-[#FFA985] mr-2 mt-1 flex-shrink-0"
                    />
                    <span>{task}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Common Problems We Solve -->
  <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Common Problems <span class="gold-gradient">We Solve</span>
        </h2>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          The real reasons people start a recurring cleaning service — and what happens when they do.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          commonProblems.map((item) => (
            <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-200 hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                <Icon name={item.icon} class="w-8 h-8 text-white" />
              </div>
              <h3 class="text-xl font-bold mb-3 text-[#333333]">{item.problem}</h3>
              <p class="text-gray-600">{item.solution}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Why Choose <span class="gold-gradient">Regular Cleaning</span>?
        </h2>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          More than a clean home — it's the foundation of a better-run household.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          benefits.map((benefit) => (
            <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-200 hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                <Icon name={benefit.icon} class="w-8 h-8 text-white" />
              </div>
              <h3 class="text-xl font-bold mb-3 text-[#333333]">
                {benefit.title}
              </h3>
              <p class="text-gray-600">{benefit.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          How It <span class="gold-gradient">Works</span>
        </h2>
        <div class="section-divider"></div>
      </div>

      <div class="space-y-8">
        <div class="flex items-start gap-6">
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center text-white font-bold text-xl flex-shrink-0"
          >
            1
          </div>
          <div>
            <h3 class="text-xl font-bold text-[#333333] mb-2">
              Book Your First Clean
            </h3>
            <p class="text-gray-600">
              Call us or fill out our online form. We'll discuss your home,
              preferences, and schedule a time that works for you.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-6">
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center text-white font-bold text-xl flex-shrink-0"
          >
            2
          </div>
          <div>
            <h3 class="text-xl font-bold text-[#333333] mb-2">
              Initial Deep Clean (Recommended)
            </h3>
            <p class="text-gray-600">
              We start with a deep clean to establish a baseline. This makes
              regular maintenance more effective and efficient.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-6">
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center text-white font-bold text-xl flex-shrink-0"
          >
            3
          </div>
          <div>
            <h3 class="text-xl font-bold text-[#333333] mb-2">
              Regular Visits Begin
            </h3>
            <p class="text-gray-600">
              Your assigned cleaner arrives on schedule. Same person, advance scheduling
              same great results every time.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-6">
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center text-white font-bold text-xl flex-shrink-0"
          >
            4
          </div>
          <div>
            <h3 class="text-xl font-bold text-[#333333] mb-2">
              Enjoy Your Clean Home
            </h3>
            <p class="text-gray-600">
              Come home to a consistently clean, fresh-smelling home. No more
              weekend cleaning sessions!
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Regular Cleaning <span class="gold-gradient">Service Areas</span>
        </h2>
        <div class="section-divider"></div>
      </div>

      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-4xl mx-auto mb-8"
      >
        {
          serviceAreas.map((area) => (
            <a
              href={area.link}
              class="bg-white rounded-xl p-4 shadow-md border border-gray-200 text-center hover:border-[#FFA985] hover:shadow-lg transition group"
            >
              <Icon name="map-marker-alt" class="w-5 h-5 text-[#FFA985] mb-2" />
              <p class="font-semibold text-[#333333] group-hover:text-[#FFA985] transition">
                {area.name}
              </p>
            </a>
          ))
        }
      </div>

      <div class="text-center">
        <p class="text-gray-600">
          <Icon name="phone" class="w-5 h-5 text-[#FFA985] mr-2" />
          Don't see your area? Call <a
            href="tel:2568261100"
            class="text-[#FFA985] font-semibold hover:underline">256-826-1100</a
          >
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Regular Cleaning <span class="gold-gradient">FAQs</span>
        </h2>
        <div class="section-divider"></div>
      </div>

      <div class="space-y-4">
        {
          faqs.map((faq, index) => (
            <div
              class="faq-item bg-white rounded-xl p-6 shadow-md border border-gray-200 cursor-pointer"
              onclick="this.classList.toggle('active')"
            >
              <div class="flex justify-between items-center">
                <h3 class="font-bold text-[#333333] pr-4">{faq.question}</h3>
                <Icon
                  name="chevron-down"
                  class="w-5 h-5 text-[#FFA985] faq-icon flex-shrink-0"
                />
              </div>
              <div class="faq-answer">
                <p class="text-gray-600 mt-4">{faq.answer}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-gradient-to-br from-[#FFA985]/10 to-gray-100">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-[#333333]">
        Ready for a <span class="gold-gradient">Consistently Clean Home</span>?
      </h2>
      <p class="text-xl text-gray-600 mb-8">
        Start your regular cleaning service today and reclaim your weekends
      </p>
      <div
        class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-6 mb-8"
      >
        <a
          href="tel:2568261100"
          class="btn-primary px-12 py-5 rounded-full text-xl font-semibold inline-block shadow-lg"
        >
          <Icon name="phone" class="w-5 h-5 mr-2" />Call 256-826-1100
        </a>
        <a
          href="/#quote-form"
          class="flex items-center text-gray-700 hover:text-[#FFA985] transition text-lg font-semibold px-8 py-5 bg-white border-2 border-gray-300 rounded-full shadow-md"
        >
          <Icon name="envelope" class="w-5 h-5 mr-2" />Get Free Quote
        </a>
      </div>
      <p class="text-gray-600">
        <Icon name="clock" class="w-5 h-5 text-[#FFA985] mr-2" />
        Most quotes replied to within 2 hours
      </p>
    </div>
  </section>
</BaseLayout>
