---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SchemaMarkup from "../../components/SchemaMarkup.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import Icon from "../../components/Icon.astro";

const title = "Airbnb & Vacation Rental Cleaning | Valley Clean Team";
const description =
  "Airbnb turnover service & vacation rental cleaning across AL & TN. Same-day flips, linen service & restocking. $2M insured, veteran-owned. Call 256-826-1100.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Airbnb Turnover Service & Vacation Rental Cleaning",
  description:
    "Professional Airbnb turnover service and vacation rental cleaning for short-term rental hosts. Same-day turnovers, linen service, restocking, and photo documentation across Alabama and Tennessee.",
  provider: {
    "@type": "LocalBusiness",
    name: "The Valley Clean Team",
    telephone: "256-826-1100",
    email: "hello@thevalleycleanteam.com",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Huntsville",
      addressRegion: "AL",
      addressCountry: "US",
    },
  },
  areaServed: [
    { "@type": "State", name: "Alabama" },
    { "@type": "State", name: "Tennessee" },
  ],
  serviceType: "Vacation Rental Cleaning",
  offers: {
    "@type": "Offer",
    priceSpecification: {
      "@type": "PriceSpecification",
      price: "150",
      priceCurrency: "USD",
      minPrice: "150",
    },
    availability: "https://schema.org/InStock",
  },
};

const faqs = [
  {
    question: "How quickly can you turn over my vacation rental?",
    answer:
      "Standard vacation rental turnovers take 2-3 hours depending on property size. We specialize in same-day flips with advance notice to ensure your next guests arrive on time.",
  },
  {
    question: "Do you restock supplies?",
    answer:
      "Yes! As part of our comprehensive vacation rental cleaning, we can restock toiletries, paper products, coffee, and other amenities. You provide the supplies, or we can purchase and bill you.",
  },
  {
    question: "What if a guest leaves the property extremely dirty?",
    answer:
      "We handle it. Extra-dirty properties may require additional time and cost, but we'll communicate before proceeding. We document conditions with photos when needed.",
  },
  {
    question: "Can you coordinate with my booking calendar?",
    answer:
      "Absolutely. Many hosts give us calendar access so we can schedule turnovers automatically. No more back-and-forth messaging before every checkout.",
  },
  {
    question: "Do you handle laundry?",
    answer:
      "Yes, we wash, dry, and make beds with fresh linens. We can work with linens on-site or coordinate with your linen service for pickup/delivery.",
  },
  {
    question: "What about damage or inventory issues?",
    answer:
      "We photograph any damage, missing items, or issues and report immediately. This documentation helps with guest claims and Airbnb's resolution process.",
  },
  {
    question: "Do you clean multiple properties?",
    answer:
      "We serve hosts with single properties to those managing 20+ units. Volume discounts available for multi-property vacation rental accounts.",
  },
  {
    question: "How do I get started?",
    answer:
      "Call or text 256-826-1100, or fill out our contact form. We'll discuss your property, turnover schedule, and specific requirements.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const turnoverChecklist = [
  {
    section: "All Rooms",
    icon: "home",
    tasks: [
      "Sweep/vacuum floors (carpet + hard surfaces)",
      "Mop floors",
      "Empty trash",
      "Dust shelves, furniture, and lamps",
      "Dust all blinds, windows, and window sills",
      "Sanitize high-touch items (TV remotes, light switches)",
      "Clean and refresh cloth items (couches, chairs, throw pillows)",
      "Launder throw blankets and replace once clean",
      "Dust baseboards",
      "Vacuum drapes/curtains",
      "Wipe & clean glass surfaces",
    ],
  },
  {
    section: "Bedrooms",
    icon: "bed",
    tasks: [
      "Remove mattress protector, sheets, pillowcases, and blanket",
      "Wash, dry, fold, and put away linens",
      "Dust tops of dressers and nightstands",
      "Wipe down ceiling fans and décor",
      "Clean interior windows and dust windowsills",
      "Disinfect high-touch items (light switches, TV remotes)",
      "Check room for personal belongings (notify host if found)",
      "Vacuum floors including under the bed",
      "Remake bed with fresh bedding",
      "Ensure décor and knick-knacks are arranged neatly",
    ],
  },
  {
    section: "Bathrooms",
    icon: "bath",
    tasks: [
      "Gather dirty towels and bathmats — wash, dry, fold, and put away",
      "Check drawers/cabinets for guest items (notify host if found)",
      "Clean mirrors",
      "Clean and disinfect countertops, backsplashes, sinks, and faucets",
      "Scrub bathtubs, faucets, showers, and shower doors",
      "Remove hard water stains",
      "Sanitize toilets (inside, outside, around, and behind)",
      "Clean interior windows and dust windowsills, vents, and fans",
      "Replenish amenities (hand soap, toilet paper, etc.)",
      "Ensure bathroom items are arranged nicely",
    ],
  },
  {
    section: "Living Room",
    icon: "couch",
    tasks: [
      "Wipe down hard surfaces and shelving",
      "Dust appliances and decor (TVs, electronics, etc.)",
      "Clean interior windows & glass doors",
      "Dust all light fixtures (ceiling fans and lamps)",
      "Sanitize high-touch items (TV remotes, light switches)",
      "Clean and refresh cloth items (couches, chairs, throw pillows)",
      "Launder throw blankets and replace once clean",
      "Clean under couch cushions",
      "Vacuum drapes/curtains",
      "Ensure media and décor are arranged neatly",
      "Place Welcome Book in accessible area",
    ],
  },
  {
    section: "Kitchen",
    icon: "kitchen-set",
    tasks: [
      "Wash, disinfect, and put away dishes",
      "Sanitize all surfaces (counters, cabinets, tables)",
      "Disinfect inside of sink and backsplashes",
      "Wipe interiors and exteriors of small appliances (microwave, coffee maker)",
      "Inspect and clean inside and outside of oven, refrigerator, and freezer",
      "Refill kitchen supplies (dish soap, dish towels, sponges)",
      "Clean interior windows and dust windowsills",
      "Take out trash, disinfect garbage can, replace trash bag",
      "Make sure all kitchen supplies are arranged neatly",
    ],
  },
  {
    section: "Laundry Room",
    icon: "shirt",
    tasks: [
      "Clean out the washing machine detergent tray",
      "Clean up soap or softener spills on the washing machine",
      "Clean out the dryer lint",
      "Disinfect knobs, buttons, and doors of the machines",
      "Clean out the sink and anything in its drain",
      "Restock laundry detergent, softener, or dryer sheets",
      "Pull out machines and sweep/dust behind them",
      "Keep supplies well labeled and organized",
      "Check laundry baskets or drying racks are clean and ready",
    ],
  },
];

const whyChooseUs = [
  {
    icon: "clock",
    title: "Fast Turnovers",
    description:
      "We work with your checkout/check-in schedule. Tight windows are our specialty.",
  },
  {
    icon: "star",
    title: "5-Star Ready",
    description:
      "Every clean is inspection-ready. We know what vacation rental guests notice and review.",
  },
  {
    icon: "camera",
    title: "Photo Documentation",
    description:
      "We photograph damages and issues to protect you with Airbnb claims.",
  },
  {
    icon: "calendar-check",
    title: "Calendar Sync",
    description:
      "Connect your booking calendar for automatic scheduling. No more coordination headaches.",
  },
  {
    icon: "box-open",
    title: "Restocking Service",
    description:
      "Toiletries, linens, supplies—we ensure guests have everything they need.",
  },
  {
    icon: "phone",
    title: "Reliable Communication",
    description:
      "Text or call confirmation when we're done. Never wonder about turnover status.",
  },
];

const pricingTiers = [
  {
    name: "All Sizes",
    price: "From $150",
    description: "Vacation rentals & Airbnbs",
    time: "Based on property size",
  },
];

const serviceAreas = [
  { name: "Huntsville", link: "/locations/huntsville/airbnb-cleaning" },
  { name: "Madison", link: "/locations/madison/airbnb-cleaning" },
  { name: "Athens", link: "/locations/athens/airbnb-cleaning" },
  { name: "Florence", link: "/locations/florence/airbnb-cleaning" },
  { name: "Muscle Shoals", link: "/locations/muscle-shoals/airbnb-cleaning" },
  { name: "Decatur", link: "/locations/decatur/airbnb-cleaning" },
  { name: "Mountain Brook", link: "/locations/mountain-brook" },
  { name: "Nashville", link: "/locations/nashville/airbnb-cleaning" },
  { name: "West Nashville", link: "/locations/west-nashville/airbnb-cleaning" },
];
const commonProblems = [
  {
    icon: "star",
    problem: "A Cleanliness Review That Tanks Your Rating",
    solution: "One 3-star cleanliness review drops your overall score and immediately reduces booking conversions. Guests who book based on a 4.9 cleanliness rating won't book at 4.6. We clean to 5-star standards because that's what your income depends on.",
  },
  {
    icon: "clock",
    problem: "Tight Same-Day Turnover Windows",
    solution: "Checkout at 11am, check-in at 3pm. Four hours to strip beds, deep-clean bathrooms, sanitize the kitchen, and reset everything to guest-ready. We build our operation around these tight windows — it's not a special request, it's our standard.",
  },
  {
    icon: "camera",
    problem: "Damage That Goes Undocumented",
    solution: "Without photo documentation before and after each guest stay, damage claims become your word against theirs. We photograph conditions on every turnover — protection for your Airbnb disputes and your security deposit claims.",
  },
  {
    icon: "calendar-check",
    problem: "Coordinating Every Turnover Manually",
    solution: "Managing a vacation rental shouldn't mean coordinating every single turnover by text message. We sync with your booking calendar so turnovers schedule automatically. You get confirmation when we're done — no chasing required.",
  },
];
import BookingCTA from "../../components/BookingCTA.astro";
---

<BaseLayout title={title} description={description} ogImage="https://storage.googleapis.com/msgsndr/iKQIBhpKVL2XVPgU7HMd/media/6920802945dc047d65b4ec5d.png">
  <SchemaMarkup type="organization" />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-6 bg-gradient-to-br from-white to-gray-50">
    <div class="container mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div
            class="inline-block bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 px-4 py-2 rounded-full mb-4"
          >
            <span class="text-[#FFA985] font-semibold">
              <Icon name="key" class="w-5 h-5 mr-2" />Protect Your Superhost
              Status
            </span>
          </div>
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-[#333333]"
          >
            Airbnb Turnover Service & <span class="gold-gradient"
              >Vacation Rental Cleaning</span
            >
          </h1>
          <p class="text-xl text-gray-700 mb-6">
            Fast, reliable Airbnb turnover service and vacation rental cleaning
            across Alabama and Tennessee. We specialize in same-day flips,
            linen service, and restocking to keep your reviews flawless.
          </p>
          <div class="flex flex-wrap gap-4 mb-8">
            <div class="flex items-center text-gray-700">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span>Same-Day Turnovers</span>
            </div>
            <div class="flex items-center text-gray-700">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span>Linen Service Available</span>
            </div>
            <div class="flex items-center text-gray-700">
              <Icon name="check-circle" class="w-5 h-5 text-[#FFA985] mr-2" />
              <span>Restocking Included</span>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="tel:2568261100"
              class="btn-primary px-8 py-4 rounded-full text-lg font-semibold text-center shadow-lg"
            >
              <Icon name="phone" class="w-5 h-5 mr-2" />Call 256-826-1100
            </a>
            <a
              href="/#quote-form"
              class="btn-secondary px-8 py-4 rounded-full text-lg font-semibold text-center"
            >
              Get Free Quote
            </a>
          </div>
        </div>

        <!-- Pricing Card -->
        <div
          class="bg-white rounded-2xl p-8 shadow-2xl border-2 border-[#FFA985]/20"
        >
          <div class="text-center mb-6">
            <h3 class="text-2xl font-bold text-[#333333] mb-2">
              Turnover Pricing
            </h3>
            <p class="text-gray-600">Competitive rates for quality results</p>
          </div>

          <div class="space-y-4 mb-6">
            <div
              class="flex justify-between items-center p-4 rounded-xl bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 border-2 border-[#FFA985]"
            >
              <div>
                <h4 class="font-bold text-[#333333]">Airbnb Turnover</h4>
                <p class="text-sm text-gray-600">All property sizes</p>
              </div>
              <div class="text-right">
                <span class="text-2xl font-bold text-[#FFA985]">From $150</span>
                <p class="text-xs text-gray-600">Based on size & needs</p>
              </div>
            </div>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6">
            <p class="text-green-800 text-sm text-center">
              <Icon name="tag" class="w-5 h-5 mr-2" />
              <strong>Multi-property discounts</strong> available for hosts with 3+
              listings
            </p>
          </div>

          <BookingCTA variant="card" />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <section class="py-8 px-6 bg-gray-50">
    <div class="container mx-auto">
      <TrustBadges variant="full" showGuarantee={true} />
    </div>
  </section>

  <!-- Why Hosts Choose Us -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Why Hosts <span class="gold-gradient">Choose Us</span>
        </h2>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We understand the vacation rental business. Your reviews depend on
          cleanliness—we deliver every time.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          whyChooseUs.map((item) => (
            <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-200 hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                <Icon name={item.icon} class="w-8 h-8 text-white" />
              </div>
              <h3 class="text-xl font-bold mb-3 text-[#333333]">
                {item.title}
              </h3>
              <p class="text-gray-600">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Turnover Checklist -->
  <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Complete Turnover <span class="gold-gradient">Checklist</span>
        </h2>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Every turnover follows our comprehensive checklist so nothing is
          missed
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          turnoverChecklist.map((room) => (
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-shadow">
              <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                <Icon name={room.icon} class="w-6 h-6 text-white" />
              </div>
              <h3 class="text-xl font-bold mb-4 text-[#333333]">
                {room.section}
              </h3>
              <ul class="space-y-2">
                {room.tasks.map((task) => (
                  <li class="flex items-start text-gray-600 text-sm">
                    <Icon
                      name="check"
                      class="w-5 h-5 text-[#FFA985] mr-2 mt-1 flex-shrink-0"
                    />
                    <span>{task}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Vacation Rental Turnover Section -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          What Is <span class="gold-gradient">Vacation Rental Turnover Cleaning?</span>
        </h2>
        <div class="section-divider"></div>
      </div>
      <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
        <p class="text-lg text-gray-700 mb-4">
          Vacation rental turnover cleaning is the full-service clean performed between guest checkouts and new guest check-ins. Unlike standard house cleaning, a turnover must be completed quickly, thoroughly, and to hospitality standards — every single time.
        </p>
        <p class="text-lg text-gray-700 mb-4">
          Our Airbnb turnover service covers everything: stripping and remaking beds with fresh linens, deep-cleaning bathrooms, sanitizing the kitchen, restocking supplies, and a final walk-through to ensure the property is guest-ready. We work around your booking calendar — tight same-day windows included.
        </p>
        <p class="text-lg text-gray-700">
          We serve vacation rental hosts across Huntsville, Athens, Florence, Muscle Shoals, Nashville, and Mountain Brook. Whether you manage one cabin or a portfolio of short-term rentals, our vacation rental turnover cleaning keeps your 5-star rating intact.
        </p>
      </div>
    </div>
  </section>

  <!-- The Cost of Bad Reviews -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          The Real Cost of <span class="gold-gradient"
            >Cleanliness Complaints</span
          >
        </h2>
        <div class="section-divider"></div>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
        <div class="grid md:grid-cols-3 gap-8 text-center">
          <div>
            <div class="text-4xl font-bold text-red-500 mb-2">-30%</div>
            <p class="text-gray-600">
              Average booking rate drop after 1-star cleanliness reviews
            </p>
          </div>
          <div>
            <div class="text-4xl font-bold text-red-500 mb-2">$500+</div>
            <p class="text-gray-600">
              Lost revenue per month from poor cleanliness ratings
            </p>
          </div>
          <div>
            <div class="text-4xl font-bold text-red-500 mb-2">72%</div>
            <p class="text-gray-600">
              Of guests say cleanliness is their #1 priority
            </p>
          </div>
        </div>

        <div
          class="mt-8 p-6 bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 rounded-xl"
        >
          <p class="text-center text-gray-700">
            <strong>Protect your investment.</strong> Professional turnover cleaning
            isn't an expense—it's insurance for your rental income and reputation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Common Problems We Solve -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Common Problems <span class="gold-gradient">We Solve</span>
        </h2>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          The issues that cost vacation rental hosts reviews, bookings, and income — and how we fix them.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          commonProblems.map((item) => (
            <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-200 hover:shadow-xl transition-shadow">
              <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                <Icon name={item.icon} class="w-8 h-8 text-white" />
              </div>
              <h3 class="text-xl font-bold mb-3 text-[#333333]">{item.problem}</h3>
              <p class="text-gray-600">{item.solution}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Airbnb Cleaning <span class="gold-gradient">Service Areas</span>
        </h2>
        <div class="section-divider"></div>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Serving vacation rental hosts across Alabama and Tennessee
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-8">
        {
          serviceAreas.map((area) => (
            <a
              href={area.link}
              class="bg-white rounded-xl p-4 shadow-md border border-gray-200 text-center hover:border-[#FFA985] hover:shadow-lg transition group"
            >
              <Icon name="map-marker-alt" class="w-5 h-5 text-[#FFA985] mb-2" />
              <p class="font-semibold text-[#333333] group-hover:text-[#FFA985] transition">
                {area.name}
              </p>
            </a>
          ))
        }
      </div>

      <div class="text-center">
        <p class="text-gray-600">
          <Icon name="phone" class="w-5 h-5 text-[#FFA985] mr-2" />
          Property in another area? Call <a
            href="tel:2568261100"
            class="text-[#FFA985] font-semibold hover:underline">256-826-1100</a
          >
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 px-6 content-visibility-auto">
    <div class="container mx-auto max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
          Airbnb Cleaning <span class="gold-gradient">FAQs</span>
        </h2>
        <div class="section-divider"></div>
      </div>

      <div class="space-y-4">
        {
          faqs.map((faq, index) => (
            <div
              class="faq-item bg-white rounded-xl p-6 shadow-md border border-gray-200 cursor-pointer"
              onclick="this.classList.toggle('active')"
            >
              <div class="flex justify-between items-center">
                <h3 class="font-bold text-[#333333] pr-4">{faq.question}</h3>
                <Icon
                  name="chevron-down"
                  class="w-5 h-5 text-[#FFA985] faq-icon flex-shrink-0"
                />
              </div>
              <div class="faq-answer">
                <p class="text-gray-600 mt-4">{faq.answer}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-gradient-to-br from-[#FFA985]/10 to-gray-100">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-[#333333]">
