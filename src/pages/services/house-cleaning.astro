---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SchemaMarkup from "../../components/SchemaMarkup.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import Icon from "../../components/Icon.astro";

const title =
    "House Cleaning Services AL & TN | Valley Clean Team";
const description =
    "Professional house cleaning in Huntsville, Athens, Florence, Mountain Brook & Nashville. Same team every visit. Pet-safe products. Call 256-826-1100.";

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "House Cleaning Services",
    description:
        "Comprehensive house cleaning services, ranging from standard housekeeping to deep spring cleans and move-in/move-out readiness.",
    provider: {
        "@type": "LocalBusiness",
        name: "The Valley Clean Team",
        telephone: "256-826-1100",
        email: "hello@thevalleycleanteam.com",
        address: {
            "@type": "PostalAddress",
            addressLocality: "Huntsville",
            addressRegion: "AL",
            addressCountry: "US",
        },
    },
    areaServed: [
        { "@type": "City", name: "Huntsville" },
        { "@type": "City", name: "Athens" },
        { "@type": "City", name: "Madison" },
        { "@type": "State", name: "Alabama" },
        { "@type": "State", name: "Tennessee" },
    ],
    serviceType: "House Cleaning",
    offers: {
        "@type": "Offer",
        priceSpecification: {
            "@type": "PriceSpecification",
            price: "125",
            priceCurrency: "USD",
            minPrice: "125",
        },
        availability: "https://schema.org/InStock",
    },
};

const faqs = [
    {
        question: "What is included in a standard house cleaning?",
        answer: "Standard house cleaning covers every room top to bottom: all surfaces dusted and wiped, kitchen counters and appliances cleaned, bathrooms scrubbed and sanitized, floors vacuumed and mopped, beds made, mirrors cleaned streak-free, and trash removed. We cover the full room — not just the surfaces you'd notice on a walk-through.",
    },
    {
        question: "Do I need to be home while you clean my house?",
        answer: "Most of our clients are not home during cleaning. We establish a secure access method — key, garage code, or lockbox — before your first visit. All cleaners are background-checked, bonded, and insured. You'll receive a text when we're on our way and when we're done.",
    },
    {
        question: "How long does a house cleaning take?",
        answer: "A 2-bedroom home typically takes 2-3 hours. Three-bedroom homes run 3-4 hours. Larger homes or those in need of extra attention take longer. We'll give you a time estimate when you book so you can plan your day.",
    },
    {
        question: "Can I customize what gets cleaned in my house?",
        answer: "Yes — we build your cleaning around your priorities. Focus on specific rooms, skip spaces you handle yourself, add tasks like inside-refrigerator cleaning or baseboard detail. Tell us what matters most and we'll calibrate every visit to that.",
    },
    {
        question: "Do you use pet-safe and eco-friendly cleaning products?",
        answer: "Yes. We use professional-grade, family-safe products that are effective without harsh chemical residue or strong fumes. If someone in your household has specific sensitivities — allergies, asthma, an infant, a pet with chemical sensitivities — let us know and we'll use fragrance-free or hypoallergenic products at no extra charge.",
    },
    {
        question: "Will I get the same cleaner every visit?",
        answer: "We prioritize consistency. We assign the same cleaning professional or team to your home so they learn your layout, your preferences, and the things that matter to you. Over time the service gets more personalized, not less.",
    },
    {
        question: "How is house cleaning priced?",
        answer: "House cleaning in Huntsville and Athens starts at $125 for smaller homes. Final pricing depends on square footage, number of bedrooms and bathrooms, and your specific needs. We provide a transparent quote before booking — no surprises on the day.",
    },
    {
        question: "What's the difference between house cleaning and deep cleaning?",
        answer: "House cleaning maintains surfaces that are already reasonably clean. Deep cleaning addresses everything that doesn't get covered in routine visits: inside appliances, inside cabinet interiors, baseboards and door frames, window tracks, grout lines, and other detail areas. Most new clients start with a deep clean, then move to regular house cleaning for ongoing maintenance.",
    },
    {
        question: "Is there a contract or minimum commitment?",
        answer: "No contracts. Our recurring service is completely flexible — cancel or skip anytime with 48 hours notice. We earn your continued business through results, not paperwork.",
    },
    {
        question: "What is your satisfaction guarantee?",
        answer: "If anything about your cleaning doesn't meet your standards, call us within 24 hours and we'll return to correct it at no charge. No forms, no arguments. We do it right or we come back and fix it.",
    },
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};

const cleaningTasks = [
    {
        section: "Bathrooms",
        icon: "bath",
        tasks: [
            "Toilet scrubbed and sanitized inside and out",
            "Shower and bathtub scrubbed — tile, grout, and fixtures",
            "Sink and vanity cleaned and polished",
            "Mirrors cleaned streak-free",
            "Counters and ledges wiped",
            "Trash emptied and liner replaced",
            "Floors mopped and disinfected",
            "High-touch surfaces sanitized",
        ],
    },
    {
        section: "Kitchen",
        icon: "kitchen-set",
        tasks: [
            "Countertops and backsplash wiped and sanitized",
            "Stovetop and burners cleaned",
            "Microwave interior and exterior cleaned",
            "Refrigerator exterior wiped down",
            "Dishwasher exterior cleaned",
            "Sink scrubbed and chrome polished",
            "Cabinet fronts cleaned",
            "Floors swept and mopped",
        ],
    },
    {
        section: "Bedrooms",
        icon: "bed",
        tasks: [
            "All surfaces dusted",
            "Ceiling fans and light fixtures dusted",
            "Floors vacuumed",
            "Bed made with clean presentation",
            "Mirrors cleaned streak-free",
            "Baseboards wiped",
            "Trash removed",
        ],
    },
    {
        section: "Living Areas",
        icon: "couch",
        tasks: [
            "All surfaces dusted including shelves and decor",
            "Furniture dusted",
            "Floors vacuumed and mopped",
            "Glass and mirrors cleaned streak-free",
            "High-touch surfaces sanitized",
            "Trash removed and bins relined",
        ],
    },
];

const commonProblems = [
    {
        icon: "clock",
        problem: "No Time to Clean Properly",
        solution: "You know how to clean your house. You just don't have three hours on a Saturday to do it. We're in, thorough, and done — on a schedule that fits your week, not the other way around.",
    },
    {
        icon: "broom",
        problem: "Cleaning That Never Stays Clean",
        solution: "The problem with doing it yourself is the baseline keeps resetting. Professional recurring cleaning changes the baseline — each visit maintains a higher level instead of playing catch-up from scratch.",
    },
    {
        icon: "allergies",
        problem: "Dust, Dander & Allergy Triggers",
        solution: "Pet dander on the furniture. Dust accumulating on ceiling fans. Allergens building in carpet fibers. Regular professional cleaning addresses the sources, not just the surfaces you see.",
    },
    {
        icon: "leaf",
        problem: "Harsh Chemical Smells",
        solution: "The bleach smell that lingers for hours. The headache from conventional cleaners. We use professional-grade products that clean thoroughly without the chemical overload — safe for kids, pets, and sensitive households.",
    },
];

const serviceAreas = [
    { name: "Huntsville", link: "/locations/huntsville/weekly-cleaning" },
    { name: "Madison", link: "/locations/madison" },
    { name: "Athens", link: "/locations/athens/weekly-cleaning" },
    { name: "Florence", link: "/locations/florence/weekly-cleaning" },
    { name: "Decatur", link: "/locations/decatur" },
    { name: "Muscle Shoals", link: "/locations/muscle-shoals" },
    { name: "Mountain Brook", link: "/locations/mountain-brook/weekly-cleaning" },
    { name: "Nashville", link: "/locations/nashville" },
    { name: "West Nashville", link: "/locations/west-nashville" },
];

const benefits = [
    {
        icon: "star",
        title: "130+ Five-Star Reviews",
        description: "Families across Huntsville, Athens, and Madison County have trusted us with their homes. Read what they say — the results speak for themselves.",
    },
    {
        icon: "users",
        title: "Same Team, Every Visit",
        description: "We assign your home a dedicated cleaning professional from day one. They learn your space, your preferences, and what matters most to you.",
    },
    {
        icon: "shield-alt",
        title: "Fully Insured & Background-Checked",
        description: "$2 million liability insurance. Every team member background-checked and bonded. You're handing us your keys — we take that seriously.",
    },
    {
        icon: "medal",
        title: "Veteran-Owned, Detail-Oriented",
        description: "Military precision means we don't cut corners, we don't skip steps, and we show up when we say we will. Every single time.",
    },
];
import BookingCTA from "../../components/BookingCTA.astro";
---

<BaseLayout title={title} description={description}>
    <SchemaMarkup type="organization" />
    <script
        type="application/ld+json"
        set:html={JSON.stringify(serviceSchema)}
    />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <!-- Hero Section -->
    <section class="pt-32 pb-16 px-6 bg-gradient-to-br from-white to-gray-50">
        <div class="container mx-auto">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div>
                    <div
                        class="inline-block bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 px-4 py-2 rounded-full mb-4"
                    >
                        <span class="text-[#FFA985] font-semibold">
                            <Icon
                                name="sparkles"
                                class="w-5 h-5 mr-2"
                            />Top-Rated House Cleaners
                        </span>
                    </div>
                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-[#333333]"
                    >
                        Professional <span class="gold-gradient">House Cleaning</span> in Alabama & Tennessee
                    </h1>
                    <p class="text-xl text-gray-700 mb-6">
                        Your house doesn't clean itself between visits. And carving out three hours on a Saturday to do it right — every week — isn't realistic. Our professional house cleaning service keeps your home consistently clean so you stop spending your free time on it. Same trusted team, honest pricing, 24-hour satisfaction guarantee.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 mb-8">
                        <a
                            href="tel:2568261100"
                            class="btn-primary px-8 py-4 rounded-full text-lg font-semibold text-center shadow-lg"
                        >
                            <Icon name="phone" class="w-5 h-5 mr-2" />Call
                            256-826-1100
                        </a>
                        <a
                            href="/#quote-form"
                            class="btn-secondary px-8 py-4 rounded-full text-lg font-semibold text-center"
                        >
                            Request Your Free Quote
                        </a>
                    </div>
                </div>

                <div
                    class="bg-white rounded-2xl p-8 shadow-2xl border-2 border-[#FFA985]/20"
                >
                    <div class="text-center mb-6">
                        <h3 class="text-2xl font-bold text-[#333333] mb-2">
                            Book Your House Cleaning
                        </h3>
                        <p class="text-gray-600">
                            Get a fast, accurate quote today.
                        </p>
                    </div>
                    <BookingCTA variant="card" />
                </div>
            </div>
        </div>
    </section>

    <!-- Trust Badges -->
    <section class="py-8 px-6 bg-gray-50">
        <div class="container mx-auto">
            <TrustBadges variant="full" showGuarantee={true} />
        </div>
    </section>

    <!-- Image/Text Section -->
    <section class="py-20 px-6 bg-white">
        <div class="container mx-auto max-w-6xl">
            <div class="grid md:grid-cols-2 gap-12 items-center mb-20">
                <div class="rounded-3xl overflow-hidden shadow-2xl">
                    <img
                        height="492" width="492" src="/images/services/Cleaningpic6-305.webp"
                        alt="Freshly cleaned kitchen and living area"
                        loading="lazy"
                        class="w-full h-[400px] object-cover hover:scale-105 transition-transform duration-700"
                    />
                </div>
                <div>
                    <h2
                        class="text-3xl md:text-4xl font-bold mb-6 text-[#333333]"
                    >
                        Cleaning Built Around Your Life
                    </h2>
                    <p class="text-lg text-gray-600 mb-6">
                        Your home isn't generic, and your cleaning shouldn't be either. We build your service around what actually matters — extra time in the bathrooms, specific products for hardwood floors, a guest room that only needs attention before holidays. Tell us what's important and we calibrate every visit to that standard.
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700">Customized to your priorities — not a one-size-fits-all checklist</span>
                        </li>
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700">Weekly, biweekly, or monthly — whatever frequency fits your household</span>
                        </li>
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700">Pet-safe and family-safe products throughout — no harsh residue</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div
                    class="rounded-3xl overflow-hidden shadow-2xl order-1 md:order-2"
                >
                    <img
                        height="492" width="492" src="/images/services/Cleaningpic4-306.webp"
                        alt="Spotless bathroom cleaning service"
                        loading="lazy"
                        class="w-full h-[400px] object-cover hover:scale-105 transition-transform duration-700"
                    />
                </div>
                <div class="order-2 md:order-1">
                    <h2
                        class="text-3xl md:text-4xl font-bold mb-6 text-[#333333]"
                    >
                        Handing Us Your Keys Is a Big Deal. We Know That.
                    </h2>
                    <p class="text-lg text-gray-600 mb-6">
                        You're trusting strangers with your home, your possessions, your family's space. We earn that trust through background checks, bonding, insurance, and the kind of consistent conduct that keeps clients with us for years rather than months. Every cleaner on our team has been vetted. Every visit is covered by $2 million in liability insurance.
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700">Every cleaner rigorously background-checked and bonded</span>
                        </li>
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700">Veteran-owned — the accountability military culture demands</span>
                        </li>
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700">24-hour satisfaction guarantee — if it's not right, we fix it at no charge</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- What's Included -->
    <section class="py-20 px-6 content-visibility-auto">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    What's Included in Every <span class="gold-gradient">House Cleaning</span>
                </h2>
                <div class="section-divider"></div>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    Every room, every visit. Not just the surfaces you'd notice on a walk-through — the ones that actually make a difference.
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                {
                    cleaningTasks.map((room) => (
                        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-shadow">
                            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                                <Icon
                                    name={room.icon}
                                    class="w-6 h-6 text-white"
                                />
                            </div>
                            <h3 class="text-xl font-bold mb-4 text-[#333333]">
                                {room.section}
                            </h3>
                            <ul class="space-y-2">
                                {room.tasks.map((task) => (
                                    <li class="flex items-start text-gray-600 text-sm">
                                        <Icon
                                            name="check"
                                            class="w-5 h-5 text-[#FFA985] mr-2 mt-1 flex-shrink-0"
                                        />
                                        <span>{task}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Common Problems We Solve -->
    <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    Common Problems <span class="gold-gradient">We Solve</span>
                </h2>
                <div class="section-divider"></div>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    These are the real reasons people call us — and what we actually do about them.
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                {
                    commonProblems.map((item) => (
                        <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-200 hover:shadow-xl transition-shadow">
                            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                                <Icon name={item.icon} class="w-8 h-8 text-white" />
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-[#333333]">{item.problem}</h3>
                            <p class="text-gray-600">{item.solution}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-20 px-6 content-visibility-auto">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    Why Choose <span class="gold-gradient">The Valley Clean Team</span>?
                </h2>
                <div class="section-divider"></div>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    There are plenty of cleaning services in Alabama and Tennessee. Here's what makes the difference with us.
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                {
                    benefits.map((benefit) => (
                        <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-200 hover:shadow-xl transition-shadow">
                            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                                <Icon
                                    name={benefit.icon}
                                    class="w-8 h-8 text-white"
                                />
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-[#333333]">
                                {benefit.title}
                            </h3>
                            <p class="text-gray-600">{benefit.description}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Service Areas -->
    <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    House Cleaning <span class="gold-gradient">Service Areas</span>
                </h2>
                <div class="section-divider"></div>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    Serving families across Alabama and Tennessee — Huntsville, Athens, Florence, Mountain Brook, Nashville, and everywhere in between.
                </p>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-4xl mx-auto mb-8">
                {
                    serviceAreas.map((area) => (
                        <a
                            href={area.link}
                            class="bg-white rounded-xl p-4 shadow-md border border-gray-200 text-center hover:border-[#FFA985] hover:shadow-lg transition group"
                        >
                            <Icon name="map-marker-alt" class="w-5 h-5 text-[#FFA985] mb-2" />
                            <p class="font-semibold text-[#333333] group-hover:text-[#FFA985] transition">
                                {area.name}
                            </p>
                        </a>
                    ))
                }
            </div>

            <div class="text-center">
                <p class="text-gray-600">
                    <Icon name="phone" class="w-5 h-5 text-[#FFA985] mr-2" />
                    Don't see your area? Call <a href="tel:2568261100" class="text-[#FFA985] font-semibold hover:underline">256-826-1100</a>
                </p>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 px-6 content-visibility-auto">
        <div class="container mx-auto max-w-4xl">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    House Cleaning <span class="gold-gradient">FAQs</span>
                </h2>
                <div class="section-divider"></div>
            </div>

            <div class="space-y-4">
                {
                    faqs.map((faq) => (
                        <div
                            class="faq-item bg-white rounded-xl p-6 shadow-md border border-gray-200 cursor-pointer"
                            onclick="this.classList.toggle('active')"
                        >
                            <div class="flex justify-between items-center">
                                <h3 class="font-bold text-[#333333] pr-4">
                                    {faq.question}
                                </h3>
                                <Icon
                                    name="chevron-down"
                                    class="w-5 h-5 text-[#FFA985] faq-icon flex-shrink-0"
                                />
                            </div>
                            <div class="faq-answer">
                                <p class="text-gray-600 mt-4">{faq.answer}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="py-20 px-6 bg-gradient-to-br from-[#FFA985]/10 to-gray-100">
        <div class="container mx-auto max-w-4xl text-center">
            <h2 class="text-4xl md:text-5xl font-bold mb-6 text-[#333333]">
                Stop Cleaning Your House <span class="gold-gradient">Every Weekend</span>
            </h2>
            <p class="text-xl text-gray-600 mb-8">
                Call us, get a transparent quote, and let us handle the cleaning. You've got better things to do with your Saturday.
            </p>
            <div
                class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-6"
            >
                <a
                    href="tel:2568261100"
                    class="btn-primary px-12 py-5 rounded-full text-xl font-semibold inline-block shadow-lg"
                >
                    <Icon name="phone" class="w-5 h-5 mr-2" />Call 256-826-1100
                </a>
                <a
                    href="/#quote-form"
                    class="btn-secondary px-8 py-5 rounded-full text-xl font-semibold"
                >
                    Get Free Quote
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
