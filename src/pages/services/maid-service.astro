---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SchemaMarkup from "../../components/SchemaMarkup.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import Icon from "../../components/Icon.astro";

const title =
    "Maid Service Huntsville AL | Veteran-Owned | Valley Clean Team";
const description =
    "Huntsville's top-rated maid service. Same cleaner every visit, 130+ 5-star reviews, $2M insured. Weekly, bi-weekly & monthly plans. Book in 60 seconds.";

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Professional Maid Service",
    description:
        "Professional maid services for homes and apartments. Trusted, consistent, and detailed house cleaning by vetted professionals.",
    provider: {
        "@type": "LocalBusiness",
        name: "The Valley Clean Team",
        telephone: "256-826-1100",
        email: "hello@thevalleycleanteam.com",
        address: {
            "@type": "PostalAddress",
            addressLocality: "Huntsville",
            addressRegion: "AL",
            addressCountry: "US",
        },
    },
    areaServed: [
        { "@type": "City", name: "Huntsville" },
        { "@type": "City", name: "Athens" },
        { "@type": "City", name: "Madison" },
        { "@type": "State", name: "Alabama" },
        { "@type": "State", name: "Tennessee" },
    ],
    serviceType: "Maid Service",
    offers: {
        "@type": "Offer",
        priceSpecification: {
            "@type": "PriceSpecification",
            price: "125",
            priceCurrency: "USD",
            minPrice: "125",
        },
        availability: "https://schema.org/InStock",
    },
};

const faqs = [
    {
        question: "Do you provide your own cleaning supplies?",
        answer: "Yes — we arrive fully equipped. All professional-grade supplies and equipment are included. If you prefer specific products for your flooring, surfaces, or sensitivities, just let us know and we'll use them instead.",
    },
    {
        question: "How long does a maid service visit take?",
        answer: "A standard home takes 2-4 hours depending on size and condition. We'll give you a realistic time estimate when you book so you can plan around it. We prioritize thorough over fast.",
    },
    {
        question: "Will I have the same maid every time?",
        answer: "Yes — consistent team assignment is one of our core commitments. The same professional returns each visit. They learn your home, your preferences, the spots that need extra attention, and what matters most to you. That institutional knowledge makes each visit better than the last.",
    },
    {
        question: "Are your maids background-checked?",
        answer: "Yes. Every team member goes through a thorough background check before their first visit. We're fully bonded and carry $2 million in liability insurance. You're trusting us with your home — we take that seriously.",
    },
    {
        question: "What is your satisfaction guarantee?",
        answer: "If anything about your maid service visit doesn't meet your standard, call within 24 hours and we return to correct it at no charge. No debate, no forms. We do it right or we come back and fix it.",
    },
    {
        question: "How is maid service priced?",
        answer: "Maid service starts at $125 for smaller homes in Huntsville and Athens. Final pricing is based on home size, number of rooms, and your specific needs. We provide a transparent quote before booking — no surprises on the day of your clean.",
    },
    {
        question: "What's the difference between maid service and deep cleaning?",
        answer: "Maid service maintains surfaces that are already reasonably clean — the ongoing upkeep that keeps your home consistently tidy. Deep cleaning reaches what routine visits don't: inside appliances, cabinet interiors, baseboards, window tracks, grout lines. Most new clients start with a deep clean first, then transition to regular maid service.",
    },
    {
        question: "Can I skip or reschedule a visit?",
        answer: "Yes — give us 48 hours notice and we'll reschedule at no charge. Life changes and we stay flexible. You can pause service, change frequency, or cancel altogether without contracts or penalties.",
    },
    {
        question: "Do you serve all of Alabama and Tennessee?",
        answer: "We serve Huntsville, Athens, Madison, Florence, Muscle Shoals, Decatur, Mountain Brook, Nashville, West Nashville, and surrounding areas. Call 256-826-1100 to confirm service at your specific address.",
    },
    {
        question: "Is there a contract or minimum commitment?",
        answer: "No contracts, ever. Our maid service is completely flexible — cancel or adjust anytime with 48 hours notice. We believe in earning your continued business through results, not contractual obligation.",
    },
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};

const cleaningTasks = [
    {
        section: "All Rooms",
        icon: "home",
        tasks: [
            "Empty trash",
            "Sweep/vacuum floors (carpet + hard surfaces)",
            "Mop floors (hard surfaces)",
            "Dust shelves",
            "Dust blinds, windows, window sills",
            "Wipe & clean mirrors",
            "Wipe & clean light switches",
            "Dust furniture/lamps",
        ],
    },
    {
        section: "Kitchen",
        icon: "kitchen-set",
        tasks: [
            "Inside/outside of microwave oven",
            "Clean backsplash",
            "Exterior of trash can",
            "Outside of stove hood",
            "Clean stovetop",
            "Countertops",
            "Clean sink & chrome",
            "Exterior of cabinets & drawers",
            "Pantry floor & door",
            "Tables and chairs",
            "Outside of appliances",
        ],
    },
    {
        section: "Bathrooms",
        icon: "bath",
        tasks: [
            "Clean shower",
            "Clean tub",
            "Polish faucets",
            "Clean sinks",
            "Clean toilet and toilet area",
            "Clean counters",
            "Dust ledges",
            "Exterior of cabinets and drawers",
            "Vacuum rugs",
        ],
    },
    {
        section: "Bedrooms",
        icon: "bed",
        tasks: [
            "Make beds (change linen if available)",
            "Vacuum rugs",
            "Exterior of cabinets and drawers",
            "Dust ledges",
        ],
    },
    {
        section: "Laundry Room",
        icon: "shirt",
        tasks: [
            "Dust and wipe the outside of washer & dryer",
            "Clean sinks",
            "Vacuum rugs",
            "Countertops",
            "Dust ledges",
        ],
    },
    {
        section: "Dining Room",
        icon: "utensils",
        tasks: ["Dust ledges", "Tables & chairs"],
    },
    {
        section: "Living Room",
        icon: "couch",
        tasks: [
            "Dust ledges",
            "Exterior of cabinets & drawers",
        ],
    },
    {
        section: "Office",
        icon: "briefcase",
        tasks: [
            "Dust ledges",
            "Vacuum rugs",
            "Exterior of cabinets & drawers",
        ],
    },
];

const commonProblems = [
    {
        icon: "clock",
        problem: "Not Enough Hours in the Week",
        solution: "Between work, family, and everything else, cleaning is the task that always gets bumped. Weekly or biweekly maid service removes it from your list entirely — your home stays clean without you having to find the time.",
    },
    {
        icon: "broom",
        problem: "Inconsistent Results from Different Cleaners",
        solution: "Rotating cleaners mean rotating results. You never know what you're getting. We assign the same professional to your home every visit — same standards, same knowledge of your space, every time.",
    },
    {
        icon: "shield-alt",
        problem: "Concerns About Trusting Someone in Your Home",
        solution: "Every cleaner on our team is background-checked, bonded, and insured. We've built our reputation on being trusted with people's homes — and we protect that trust on every visit.",
    },
    {
        icon: "leaf",
        problem: "Chemical Sensitivity in Your Household",
        solution: "Kids, pets, or family members with allergies or sensitivities don't have to live with harsh chemical residue. Tell us what your household needs and we calibrate our products accordingly.",
    },
];

const serviceAreas = [
    { name: "Huntsville", link: "/locations/huntsville/weekly-cleaning" },
    { name: "Madison", link: "/locations/madison" },
    { name: "Athens", link: "/locations/athens/weekly-cleaning" },
    { name: "Florence", link: "/locations/florence/weekly-cleaning" },
    { name: "Decatur", link: "/locations/decatur" },
    { name: "Muscle Shoals", link: "/locations/muscle-shoals" },
    { name: "Mountain Brook", link: "/locations/mountain-brook/weekly-cleaning" },
    { name: "Nashville", link: "/locations/nashville" },
    { name: "West Nashville", link: "/locations/west-nashville" },
];

const benefits = [
    {
        icon: "users",
        title: "Same Cleaner Every Visit",
        description: "Dedicated team assignment from day one. Your cleaner learns your home, your preferences, and your priorities — the service improves over time, not just stays consistent.",
    },
    {
        icon: "shield-check",
        title: "Fully Vetted & Insured",
        description: "Every cleaner background-checked and bonded. $2 million liability insurance on every visit. You're handing us your keys — we earn that trust.",
    },
    {
        icon: "calendar-alt",
        title: "No Contracts, Flexible Scheduling",
        description: "Weekly, biweekly, or monthly — your choice. Skip, pause, or cancel anytime with 48 hours notice. No fees, no penalties.",
    },
    {
        icon: "medal",
        title: "Veteran-Owned Standards",
        description: "Military discipline means we show up when we say, clean what we say, and stand behind every visit with our 24-hour satisfaction guarantee.",
    },
];
import BookingCTA from "../../components/BookingCTA.astro";
---

<BaseLayout title={title} description={description}>
    <SchemaMarkup type="organization" />
    <script
        type="application/ld+json"
        set:html={JSON.stringify(serviceSchema)}
    />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <!-- Hero Section -->
    <section class="pt-32 pb-16 px-6 bg-gradient-to-br from-white to-gray-50">
        <div class="container mx-auto">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div>
                    <div
                        class="inline-block bg-gradient-to-r from-[#FFA985]/10 to-[#FFC67D]/10 px-4 py-2 rounded-full mb-4"
                    >
                        <span class="text-[#FFA985] font-semibold">
                            <Icon name="star" class="w-5 h-5 mr-2" />5-Star
                            Rated Maid Service
                        </span>
                    </div>
                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-[#333333]"
                    >
                        Professional <span class="gold-gradient">Maid Service</span> Across Alabama & Tennessee
                    </h1>
                    <p class="text-xl text-gray-700 mb-6">
                        A maid service is only as good as the person who shows up. We assign the same trusted professional to your home every visit — someone who learns your space, your preferences, and what clean actually means to you. Background-checked, insured, and accountable on every visit.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 mb-8">
                        <a
                            href="tel:2568261100"
                            class="btn-primary px-8 py-4 rounded-full text-lg font-semibold text-center shadow-lg"
                        >
                            <Icon name="phone" class="w-5 h-5 mr-2" />Call
                            256-826-1100
                        </a>
                        <a
                            href="/#quote-form"
                            class="btn-secondary px-8 py-4 rounded-full text-lg font-semibold text-center"
                        >
                            Request Your Free Quote
                        </a>
                    </div>
                </div>

                <div
                    class="bg-white rounded-2xl p-8 shadow-2xl border-2 border-[#FFA985]/20"
                >
                    <div class="text-center mb-6">
                        <h3 class="text-2xl font-bold text-[#333333] mb-2">
                            Hire Your Maid Today
                        </h3>
                        <p class="text-gray-600">
                            Fast, easy, and secure online bookings.
                        </p>
                    </div>
                    <BookingCTA variant="card" />
                </div>
            </div>
        </div>
    </section>

    <!-- Trust Badges -->
    <section class="py-8 px-6 bg-gray-50">
        <div class="container mx-auto">
            <TrustBadges variant="full" showGuarantee={true} />
        </div>
    </section>

    <!-- Image/Text Section -->
    <section class="py-20 px-6 bg-white">
        <div class="container mx-auto max-w-6xl">
            <div class="grid md:grid-cols-2 gap-12 items-center mb-20">
                <div class="rounded-3xl overflow-hidden shadow-2xl">
                    <img
                        height="492" width="492" src="/images/services/Cleaningpic16-310.webp"
                        alt="Professional Maid Cleaning a Kitchen"
                        loading="lazy"
                        class="w-full h-[400px] object-cover hover:scale-105 transition-transform duration-700"
                    />
                </div>
                <div>
                    <h2
                        class="text-3xl md:text-4xl font-bold mb-6 text-[#333333]"
                    >
                        Detailed Cleaning For Every Room
                    </h2>
                    <p class="text-lg text-gray-600 mb-6">
                        Our professional maids don't just skim the surface. We
                        provide thorough, deep cleaning designed to tackle the
                        dust and grime that regular routines miss.
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700"
                                >Detailed dusting of all surfaces including
                                baseboards and ceiling fans</span
                            >
                        </li>
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700"
                                >Thorough sanitization of high-touch areas like
                                doorknobs and light switches</span
                            >
                        </li>
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700"
                                >Immaculate floors with premium vacuuming and
                                mopping</span
                            >
                        </li>
                    </ul>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div
                    class="rounded-3xl overflow-hidden shadow-2xl order-1 md:order-2"
                >
                    <img
                        height="492" width="492" src="/images/services/Cleaningpic17-302.webp"
                        alt="Happy Maid Service Customer Living Room"
                        loading="lazy"
                        class="w-full h-[400px] object-cover hover:scale-105 transition-transform duration-700"
                    />
                </div>
                <div class="order-2 md:order-1">
                    <h2
                        class="text-3xl md:text-4xl font-bold mb-6 text-[#333333]"
                    >
                        Relax and Enjoy Your Free Time
                    </h2>
                    <p class="text-lg text-gray-600 mb-6">
                        Imagine coming home to a perfectly clean house without
                        having to lift a finger. Our reliable maid service
                        caters to your lifestyle.
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700"
                                >Weekly, bi-weekly, or monthly scheduling
                                options</span
                            >
                        </li>
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700"
                                >Consistent quality backed by our 24-hour
                                satisfaction guarantee</span
                            >
                        </li>
                        <li class="flex items-start">
                            <Icon
                                name="check-circle"
                                class="w-6 h-6 text-[#FFA985] mr-3 mt-1 flex-shrink-0"
                            />
                            <span class="text-gray-700"
                                >Fully insured and bonded cleaning professionals</span
                            >
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- What's Included -->
    <section class="py-20 px-6 content-visibility-auto">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    What's Included in Every <span class="gold-gradient">Maid Service Visit</span>
                </h2>
                <div class="section-divider"></div>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    Every room, every visit. Not a quick pass — a thorough clean that maintains a genuinely high standard.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-6">
                {
                    cleaningTasks.map((room) => (
                        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-shadow">
                            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                                <Icon
                                    name={room.icon}
                                    class="w-6 h-6 text-white"
                                />
                            </div>
                            <h3 class="text-xl font-bold mb-4 text-[#333333]">
                                {room.section}
                            </h3>
                            <ul class="space-y-2">
                                {room.tasks.map((task) => (
                                    <li class="flex items-start text-gray-600 text-sm">
                                        <Icon
                                            name="check"
                                            class="w-5 h-5 text-[#FFA985] mr-2 mt-1 flex-shrink-0"
                                        />
                                        <span>{task}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Common Problems We Solve -->
    <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    Common Problems <span class="gold-gradient">We Solve</span>
                </h2>
                <div class="section-divider"></div>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    The real reasons people look for a maid service — and what we actually do about them.
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                {
                    commonProblems.map((item) => (
                        <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-200 hover:shadow-xl transition-shadow">
                            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                                <Icon name={item.icon} class="w-8 h-8 text-white" />
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-[#333333]">{item.problem}</h3>
                            <p class="text-gray-600">{item.solution}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-20 px-6 content-visibility-auto">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    Why Choose <span class="gold-gradient">The Valley Clean Team</span>?
                </h2>
                <div class="section-divider"></div>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    A maid service is only as good as the people doing the work. Here's what sets ours apart.
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                {
                    benefits.map((benefit) => (
                        <div class="bg-white rounded-2xl p-8 shadow-md border border-gray-200 hover:shadow-xl transition-shadow">
                            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#FFA985] to-[#FFC67D] flex items-center justify-center mb-4">
                                <Icon
                                    name={benefit.icon}
                                    class="w-8 h-8 text-white"
                                />
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-[#333333]">
                                {benefit.title}
                            </h3>
                            <p class="text-gray-600">{benefit.description}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Service Areas -->
    <section class="py-20 px-6 bg-gray-50 content-visibility-auto">
        <div class="container mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    Maid Service <span class="gold-gradient">Areas</span>
                </h2>
                <div class="section-divider"></div>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                    Serving families across Alabama and Tennessee — from Huntsville to Nashville.
                </p>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-4xl mx-auto mb-8">
                {
                    serviceAreas.map((area) => (
                        <a
                            href={area.link}
                            class="bg-white rounded-xl p-4 shadow-md border border-gray-200 text-center hover:border-[#FFA985] hover:shadow-lg transition group"
                        >
                            <Icon name="map-marker-alt" class="w-5 h-5 text-[#FFA985] mb-2" />
                            <p class="font-semibold text-[#333333] group-hover:text-[#FFA985] transition">
                                {area.name}
                            </p>
                        </a>
                    ))
                }
            </div>

            <div class="text-center">
                <p class="text-gray-600">
                    <Icon name="phone" class="w-5 h-5 text-[#FFA985] mr-2" />
                    Don't see your area? Call <a href="tel:2568261100" class="text-[#FFA985] font-semibold hover:underline">256-826-1100</a>
                </p>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 px-6 content-visibility-auto">
        <div class="container mx-auto max-w-4xl">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#333333]">
                    Maid Service <span class="gold-gradient">FAQs</span>
                </h2>
                <div class="section-divider"></div>
            </div>

            <div class="space-y-4">
                {
                    faqs.map((faq) => (
                        <div
                            class="faq-item bg-white rounded-xl p-6 shadow-md border border-gray-200 cursor-pointer"
                            onclick="this.classList.toggle('active')"
                        >
                            <div class="flex justify-between items-center">
                                <h3 class="font-bold text-[#333333] pr-4">
                                    {faq.question}
                                </h3>
                                <Icon
                                    name="chevron-down"
                                    class="w-5 h-5 text-[#FFA985] faq-icon flex-shrink-0"
                                />
                            </div>
                            <div class="faq-answer">
                                <p class="text-gray-600 mt-4">{faq.answer}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="py-20 px-6 bg-gradient-to-br from-[#FFA985]/10 to-gray-100">
        <div class="container mx-auto max-w-4xl text-center">
            <h2 class="text-4xl md:text-5xl font-bold mb-6 text-[#333333]">
                Ready to Hire a <span class="gold-gradient"
                    >Professional Maid</span
                >?
            </h2>
            <p class="text-xl text-gray-600 mb-8">
                Get an instant quote and let us take the stress of cleaning off
                your shoulders.
            </p>
            <div
                class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-6"
            >
                <a
                    href="tel:2568261100"
                    class="btn-primary px-12 py-5 rounded-full text-xl font-semibold inline-block shadow-lg"
                >
                    <Icon name="phone" class="w-5 h-5 mr-2" />Call 256-826-1100
                </a>
                <a
                    href="/#quote-form"
                    class="btn-secondary px-8 py-5 rounded-full text-xl font-semibold"
                >
                    Get Free Quote
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
