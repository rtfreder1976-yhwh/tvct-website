---
import { 
  cityConfigs, 
  petSafeServiceCatalog, 
  cityReviewTemplates, 
  cityFAQs,
  type CityConfig 
} from "../constants/schemaData";

interface Props {
  type?: "organization" | "local" | "service" | "article";
  city?: string;
  state?: string;
  neighborhoods?: string[];
  serviceName?: string;
  servicePrice?: string;
  serviceDescription?: string;
  // Article/BlogPosting props
  title?: string;
  description?: string;
  publishDate?: string;
  modifiedDate?: string;
  author?: string;
  image?: string;
  // HowTo schema props (for step-by-step blog posts)
  howToSteps?: Array<{ name: string; text: string; image?: string }>;
  totalTime?: string; // ISO 8601 duration e.g., "PT30M" for 30 minutes
  faqs?: Array<{ question: string; answer: string } | { q: string; a: string }>;
}

const {
  type = "organization",
  city,
  state,
  neighborhoods = [],
  serviceName,
  servicePrice,
  serviceDescription,
  title,
  description,
  publishDate,
  modifiedDate,
  author = "The Valley Clean Team",
  image,
  howToSteps,
  totalTime,
  faqs: faqsProp,
} = Astro.props;

// Get current page URL for article schema
const canonicalURL = Astro.url.href;

// Generate department schemas for all cities
// Using LocalBusiness type (which Organization expects for department property)
const departmentSchemas = Object.entries(cityConfigs).map(
  ([cityName, config]) => ({
    "@type": "LocalBusiness",
    "@id": `https://thevalleycleanteam.com/locations/${cityName.toLowerCase().replace(/\s+/g, "-")}/#localbusiness`,
    name: `The Valley Clean Team - ${cityName}`,
    telephone: config.phone,
    areaServed: [
      {
        "@type": "City",
        name: cityName,
        sameAs: `https://en.wikipedia.org/wiki/${cityName.replace(/\s+/g, "_")},_${config.state}`,
      },
      { "@type": "AdministrativeArea", name: `ZIP ${config.zips}` },
      {
        "@type": "GeoCircle",
        geoMidpoint: {
          "@type": "GeoCoordinates",
          latitude: Number(config.lat),
          longitude: Number(config.lng),
        },
        geoRadius: Number(config.radius),
      },
    ],
    address: {
      "@type": "PostalAddress",
      addressLocality: cityName,
      addressRegion: config.stateAbbr,
      addressCountry: "US",
    },
  }),
);

// Main organization schema with departments
const getOrganizationSchema = (includeDepartments = true) => ({
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://thevalleycleanteam.com/#organization",
  name: "The Valley Clean Team",
  alternateName: ["TVCT", "Valley Clean Team"],
  description:
    "Pet-safe residential and commercial cleaning services across Huntsville, Nashville, Florence, and Decatur since 2022. Non-toxic products safe for pets and children.",
  url: "https://thevalleycleanteam.com",
  telephone: "+1-256-826-1100",
  email: "hello@thevalleycleanteam.com",
  logo: {
    "@type": "ImageObject",
    url: "https://res.cloudinary.com/dfjneoiaq/image/upload/v1765045347/Logo_for_a_cleaning_gjyiyb.png",
    width: 512,
    height: 512,
  },
  image: [
    "https://res.cloudinary.com/dfjneoiaq/image/upload/v1765045347/Logo_for_a_cleaning_gjyiyb.png",
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Pet-Safe Cleaning Services",
    itemListElement: petSafeServiceCatalog,
  },
  knowsAbout: [
    "Pet-Safe Cleaning",
    "Non-Toxic House Cleaning",
    "Allergy-Free Cleaning",
    "Deep Cleaning",
    "Move Out Cleaning",
    "Move In Cleaning",
    "Office Cleaning",
    "Commercial Cleaning",
    "Airbnb Cleaning",
    "Vacation Rental Cleaning",
    "Post Construction Cleaning",
    "Flexible Scheduling",
  ],
  slogan: "Pet-Safe Cleaning You Can Trust",
  foundingDate: "2022",
  numberOfEmployees: {
    "@type": "QuantitativeValue",
    minValue: 10,
    maxValue: 25,
  },
  isicV4: "9601",
  naics: "561720",
  sameAs: [
    "https://www.facebook.com/thevalleycleanteam/",
    "https://www.instagram.com/thevalleycleanteamal/",
    "https://www.linkedin.com/company/thevalleycleanteam",
    "https://www.google.com/maps?cid=2354162289321042477",
    "https://www.yelp.com/biz/the-valley-clean-team-huntsville",
    "https://www.pinterest.com/thevalleycleanteam/",
    "https://nextdoor.com/pages/the-valley-clean-team-huntsville-al/",
    "https://www.thumbtack.com/al/huntsville/house-cleaning/the-valley-clean-team/",
    "https://www.bbb.org/us/al/huntsville/profile/cleaning-services/the-valley-clean-team-0463-90145678",
  ],
  ...(includeDepartments ? { department: departmentSchemas } : {}),
  potentialAction: [
    {
      "@type": "ReserveAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: "https://thevalleycleanteam.com/contact",
        actionPlatform: [
          "https://schema.org/DesktopWebPlatform",
          "https://schema.org/MobileWebPlatform",
        ],
      },
      result: {
        "@type": "Reservation",
        name: "Cleaning Service Booking",
      },
    },
    {
      "@type": "CommunicateAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: "tel:+1-256-826-1100",
        actionPlatform: "https://schema.org/MobileWebPlatform",
      },
    },
  ],
});

const organizationSchema = getOrganizationSchema(true);
const parentOrgSchema = getOrganizationSchema(false);

// Get city config for location pages
const getCityConfig = (cityName: string) => {
  return cityConfigs[cityName] || cityConfigs["Huntsville"];
};

// Local business schema for city-specific pages (CleaningService type)
const localSchema = city
  ? (() => {
      const config = getCityConfig(city);
      const stateAbbr = state === "Alabama" ? "AL" : "TN";
      const citySlug = city.toLowerCase().replace(/\s+/g, "-");
      const reviewText =
        cityReviewTemplates[city] ||
        `Best ${config.reviewFocus} in ${city}—professional and thorough!`;

      return {
        "@context": "https://schema.org",
        "@type": "HomeAndConstructionBusiness",
        "@id": `https://thevalleycleanteam.com/locations/${citySlug}/#localbusiness`,
        name: `The Valley Clean Team - ${city}`,
        description: `${config.focusService} in ${city}, ${state}. Non-toxic products safe for pets and children. Same-day service available. 4.9★ rated with 130+ reviews.`,
        url: `https://thevalleycleanteam.com/locations/${citySlug}`,
        telephone: config.phone,
        email: "hello@thevalleycleanteam.com",
        image:
          "https://res.cloudinary.com/dfjneoiaq/image/upload/v1765045347/Logo_for_a_cleaning_gjyiyb.png",
        priceRange: "$$",
        areaServed: [
          {
            "@type": "City",
            name: city,
            sameAs: `https://en.wikipedia.org/wiki/${city.replace(/\s+/g, "_")},_${state}`,
          },
          { "@type": "AdministrativeArea", name: `ZIP ${config.zips}` },
          {
            "@type": "GeoCircle",
            geoMidpoint: {
              "@type": "GeoCoordinates",
              latitude: config.lat,
              longitude: config.lng,
            },
            geoRadius: Number(config.radius),
          },
          ...neighborhoods.map((neighborhood) => ({
            "@type": "Place",
            name: neighborhood,
            containedInPlace: { "@type": "City", name: city },
          })),
        ],
        address: {
          "@type": "PostalAddress",
          addressLocality: city,
          addressRegion: stateAbbr,
          addressCountry: "US",
        },
        parentOrganization: {
          "@type": "Organization",
          name: "The Valley Clean Team",
          url: "https://thevalleycleanteam.com",
        },
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: 4.9,
          reviewCount: 130,
          bestRating: 5,
          worstRating: 1,
        },
        review: [
          {
            "@type": "Review",
            author: { "@type": "Person", name: `${city} Homeowner` },
            reviewRating: { "@type": "Rating", ratingValue: 5 },
            reviewBody: reviewText,
          },
        ],
        openingHoursSpecification: [
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            opens: "07:00",
            closes: "19:00",
          },
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: "Saturday",
            opens: "08:00",
            closes: "17:00",
          },
        ],
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: `${config.focusService} in ${city}`,
          itemListElement: [
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: `${config.focusService} ${city} ${stateAbbr}`,
                description: `${config.focusService} with non-toxic, pet-safe products.`,
              },
              priceSpecification: {
                "@type": "PriceSpecification",
                price: 99.00,
                priceCurrency: "USD",
                description: "Starting at $99",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: `Pet-Safe Cleaning ${city} ${stateAbbr}`,
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: `Pet-Safe Move-Out Cleaning ${city} ${stateAbbr}`,
              },
            },
          ],
        },
      };
    })()
  : null;

// Areas served for service pages (fallback when no city specified)
const areasServed = Object.entries(cityConfigs).map(([cityName, config]) => ({
  "@type": "City",
  name: cityName,
  containedInPlace: { "@type": "State", name: config.state },
}));

// Service schema for specific service pages (city + service combo pages)
const serviceSchema = serviceName
  ? (() => {
      const cityConfig = city ? getCityConfig(city) : null;
      const stateAbbr =
        state === "Alabama" ? "AL" : state === "Tennessee" ? "TN" : "AL";
      const citySlug = city ? city.toLowerCase().replace(/\s+/g, "-") : "";
      const servicePrice_ = servicePrice?.replace(/[^0-9.]/g, "") || "149.00";

      // For city+service pages, reference local business; for service-only pages, reference org
      const providerId = city
        ? `https://thevalleycleanteam.com/locations/${citySlug}/#localbusiness`
        : "https://thevalleycleanteam.com/#organization";

      return {
        "@context": "https://schema.org",
        "@type": "Service",
        serviceType: `Pet-Safe ${serviceName}`,
        provider: { "@id": providerId },
        areaServed: city
          ? {
              "@type": "AdministrativeArea",
              name: `${city} ${stateAbbr} ZIP ${cityConfig?.zips?.split("-")[0] || "35801"}`,
            }
          : areasServed,
        offers: {
          "@type": "Offer",
          priceCurrency: "USD",
          price: servicePrice_,
          description: city
            ? `Pet-safe ${serviceName.toLowerCase()} for ${city} homes—non-toxic products included`
            : `Pet-safe ${serviceName.toLowerCase()}—non-toxic products included`,
        },
        mainEntityOfPage: {
          "@type": "WebPage",
          headline: city
            ? `Pet Safe ${serviceName} ${city} ${stateAbbr}: Professional Service`
            : `Pet Safe ${serviceName}: Professional Service`,
        },
      };
    })()
  : null;

// Article/BlogPosting schema for blog posts
const articleSchema =
  type === "article" && title
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description: description,
        image:
          image ||
          "https://res.cloudinary.com/dfjneoiaq/image/upload/v1765045347/Logo_for_a_cleaning_gjyiyb.png",
        datePublished: publishDate
          ? new Date(publishDate).toISOString()
          : new Date().toISOString(),
        dateModified: modifiedDate
          ? new Date(modifiedDate).toISOString()
          : publishDate
            ? new Date(publishDate).toISOString()
            : new Date().toISOString(),
        author: {
          "@type": "Organization",
          name: author,
          "@id": "https://thevalleycleanteam.com/#organization",
        },
        publisher: {
          "@type": "Organization",
          name: "The Valley Clean Team",
          "@id": "https://thevalleycleanteam.com/#organization",
          logo: {
            "@type": "ImageObject",
            url: "https://res.cloudinary.com/dfjneoiaq/image/upload/v1765045347/Logo_for_a_cleaning_gjyiyb.png",
          },
        },
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonicalURL,
        },
        articleSection: "Cleaning Tips",
        inLanguage: "en-US",
      }
    : null;

// HowTo schema for step-by-step blog posts (boosts E-A-T)
const howToSchema =
  type === "article" && howToSteps && howToSteps.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "HowTo",
        name: title,
        description: description,
        image:
          image ||
          "https://res.cloudinary.com/dfjneoiaq/image/upload/v1765045347/Logo_for_a_cleaning_gjyiyb.png",
        totalTime: totalTime || "PT30M",
        estimatedCost: {
          "@type": "MonetaryAmount",
          currency: "USD",
          value: 0,
        },
        supply: [
          { "@type": "HowToSupply", name: "Pet-safe cleaning products" },
          { "@type": "HowToSupply", name: "Microfiber cloths" },
          { "@type": "HowToSupply", name: "Vacuum with HEPA filter" },
        ],
        tool: [
          { "@type": "HowToTool", name: "Spray bottle" },
          { "@type": "HowToTool", name: "Mop or steam cleaner" },
        ],
        step: howToSteps.map((step, index) => ({
          "@type": "HowToStep",
          position: index + 1,
          name: step.name,
          text: step.text,
          image: step.image || image,
        })),
        author: {
          "@type": "Organization",
          name: "The Valley Clean Team",
          "@id": "https://thevalleycleanteam.com/#organization",
        },
      }
    : null;

// FAQPage schema is handled by individual pages (inline faqSchema)
// to avoid duplicate FAQPage errors in Google Search Console.
const faqSchema = null;

// BreadcrumbList schema for location pages (improves crawl efficiency)
const breadcrumbSchema =
  type === "local" && city
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: "https://thevalleycleanteam.com",
          },
          {
            "@type": "ListItem",
            position: 2,
            name: "Locations",
            item: "https://thevalleycleanteam.com/locations",
          },
          {
            "@type": "ListItem",
            position: 3,
            name: `${city} Cleaning`,
            item: `https://thevalleycleanteam.com/locations/${city.toLowerCase().replace(/\s+/g, "-")}`,
          },
        ],
      }
    : null;

// Event schema for recurring local events (improves local relevance)
const eventSchemas =
  type === "local" && city === "Tuscumbia"
    ? [
        {
          "@context": "https://schema.org",
          "@type": "Event",
          name: "Helen Keller Festival 2026",
          description:
            "Annual celebration honoring Helen Keller's legacy in her hometown of Tuscumbia, Alabama. The Valley Clean Team offers pre-event home cleaning for hosts and vacation rental turnovers.",
          startDate: "2026-06-26",
          endDate: "2026-06-28",
          eventStatus: "https://schema.org/EventScheduled",
          eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
          location: {
            "@type": "Place",
            name: "Downtown Tuscumbia & Spring Park",
            address: {
              "@type": "PostalAddress",
              addressLocality: "Tuscumbia",
              addressRegion: "AL",
              addressCountry: "US",
            },
          },
          organizer: {
            "@type": "Organization",
            name: "Helen Keller Birthplace Foundation",
            url: "https://www.helenkellerbirthplace.org",
          },
          offers: {
            "@type": "Offer",
            name: "Pre-Festival Home Cleaning",
            description:
              "Get your home guest-ready before Helen Keller Festival",
            url: "https://thevalleycleanteam.com/locations/tuscumbia",
            priceCurrency: "USD",
            price: 149,
            availability: "https://schema.org/InStock",
            seller: {
              "@type": "Organization",
              name: "The Valley Clean Team",
            },
          },
        },
        {
          "@context": "https://schema.org",
          "@type": "Event",
          name: "The Miracle Worker Performance 2026",
          description:
            "Outdoor production of 'The Miracle Worker' at Ivy Green, Helen Keller's birthplace. Book cleaning services for guest arrivals.",
          startDate: "2026-06-01",
          endDate: "2026-07-15",
          eventStatus: "https://schema.org/EventScheduled",
          eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
          location: {
            "@type": "Place",
            name: "Ivy Green - Helen Keller Birthplace",
            address: {
              "@type": "PostalAddress",
              streetAddress: "300 W North Commons",
              addressLocality: "Tuscumbia",
              addressRegion: "AL",
              postalCode: "35674",
              addressCountry: "US",
            },
          },
        },
      ]
    : null;

// VideoObject schema for testimonial/how-to content (when video URL provided)
const videoSchema = null; 

// Service-specific schemas for enhanced service page SEO
const airbnbCleaningSchema =
  serviceName && serviceName.toLowerCase().includes("airbnb")
    ? {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id":
          "https://thevalleycleanteam.com/services/airbnb-cleaning/#service",
        serviceType: "Vacation Rental Cleaning",
        name: "Airbnb & Vacation Rental Cleaning",
        description:
          "Professional turnover cleaning for Airbnb hosts and vacation rental owners. Reliable turnovers, restocking, and guest-ready presentation. Serving Huntsville, Nashville, and the Shoals.",
        provider: {
          "@type": "Organization",
          "@id": "https://thevalleycleanteam.com/#organization",
        },
        areaServed: [
          {
            "@type": "City",
            name: "Huntsville",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
          {
            "@type": "City",
            name: "Nashville",
            containedInPlace: { "@type": "State", name: "Tennessee" },
          },
          {
            "@type": "City",
            name: "Florence",
            containedInPlace: { "@type": "State", name: "Alabama" },
          },
        ],
        offers: {
          "@type": "Offer",
          priceSpecification: {
            "@type": "PriceSpecification",
            price: 99,
            priceCurrency: "USD",
            description: "Starting price for standard turnover",
          },
        },
        termsOfService: "https://thevalleycleanteam.com/terms",
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: "Airbnb Cleaning Options",
          itemListElement: [
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Standard Turnover Cleaning",
                description:
                  "Full cleaning between guests including linens, trash removal, and guest-ready presentation",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Deep Cleaning + Turnover",
                description:
                  "Comprehensive deep clean plus turnover service for extended stays or maintenance cleans",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Restocking Service",
                description:
                  "Restock toiletries, kitchen essentials, and welcome amenities",
              },
            },
          ],
        },
      }
    : null;

const moveOutCleaningSchema =
  serviceName && serviceName.toLowerCase().includes("move")
    ? {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id":
          "https://thevalleycleanteam.com/services/move-in-out-cleaning/#service",
        serviceType: "Move-Out Cleaning",
        name: "Move-Out & Move-In Cleaning",
        description:
          "Thorough move-out cleaning to help you get your full security deposit back. Deep cleaning for new homes before you move in. Pet-safe products included.",
        provider: {
          "@type": "Organization",
          "@id": "https://thevalleycleanteam.com/#organization",
        },
        offers: {
          "@type": "Offer",
          priceSpecification: {
            "@type": "PriceSpecification",
            price: 199,
            priceCurrency: "USD",
            description: "Starting price for move-out cleaning",
          },
        },
      }
    : null;

// Determine which schema to output
const schemaToUse =
  type === "local" && city
    ? localSchema
    : type === "article"
      ? null
      : organizationSchema;
---

{
  type === "article" && articleSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(articleSchema)}
    />
  )
}
{
  type !== "article" && (
    <script type="application/ld+json" set:html={JSON.stringify(schemaToUse)} />
  )
}
{
  serviceSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(serviceSchema)}
    />
  )
}
{
  faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )
}
{
  breadcrumbSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  )
}
{
  howToSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  )
}
{
  eventSchemas &&
    eventSchemas.map((event) => (
      <script type="application/ld+json" set:html={JSON.stringify(event)} />
    ))
}
{
  airbnbCleaningSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(airbnbCleaningSchema)}
    />
  )
}
{
  moveOutCleaningSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(moveOutCleaningSchema)}
    />
  )
}
