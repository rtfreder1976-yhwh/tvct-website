---
// ComparisonTable Component - Show competitive advantages vs other cleaning services
import Icon from "./Icon.astro";

interface ComparisonRow {
  feature: string;
  us: boolean | string;
  them: boolean | string;
  highlight?: boolean;
}

interface Props {
  title?: string;
  subtitle?: string;
  competitorName?: string;
  features?: ComparisonRow[];
}

const {
  title = "See Why Smart Homeowners Choose Us",
  subtitle = "Don't settle for less when you can have the best",
  competitorName = "Other Companies",
  features = [
    { feature: "Transparent Upfront Pricing", us: true, them: false, highlight: true },
    { feature: "Same-Day Service Available", us: true, them: false },
    { feature: "100% Satisfaction Guarantee", us: true, them: "Limited" },
    { feature: "Veteran & Women Owned", us: true, them: false, highlight: true },
    { feature: "$2 Million Insurance", us: true, them: "$1M or less" },
    { feature: "49-Point Cleaning Checklist", us: true, them: "Basic only" },
    { feature: "Eco-Friendly Products", us: true, them: "Extra charge" },
    { feature: "Background Checked Staff", us: true, them: true },
    { feature: "Post-Clean Photo Proof", us: true, them: false, highlight: true },
    { feature: "No Contracts Required", us: true, them: false },
    { feature: "Reply Within 2 Hours", us: "< 15 min", them: "1-2 days" },
    { feature: "Weekend Availability", us: true, them: "Limited" },
    { feature: "Pet-Safe Products", us: true, them: "Ask first" },
    { feature: "Free Re-Clean if Needed", us: true, them: false, highlight: true },
  ],
} = Astro.props;

// Calculate savings
const avgCompetitorPrice = 225;
const ourPrice = 175;
const monthlySavings = (avgCompetitorPrice - ourPrice) * 2; // bi-weekly cleaning
const yearlySavings = monthlySavings * 12;
---

<div class="comparison-section">
  <div class="comparison-header">
    <h2 class="comparison-title">{title}</h2>
    <p class="comparison-subtitle">{subtitle}</p>
    <div class="savings-badge">
      💰 Save ${yearlySavings}/year by switching to us
    </div>
  </div>

  <div class="comparison-table-wrapper">
    <table class="comparison-table">
      <thead>
        <tr>
          <th class="feature-col">What You Get</th>
          <th class="us-col">
            <span class="company-badge our-company">
              <Icon name="star" class="w-4 h-4" />
              Valley Clean Team
            </span>
          </th>
          <th class="them-col">
            <span class="company-badge other-company">
              {competitorName}
            </span>
          </th>
        </tr>
      </thead>
      <tbody>
        {features.map((row) => (
          <tr class={row.highlight ? "highlight-row" : ""}>
            <td class="feature-cell">
              {row.highlight && <span class="hot-badge">HOT</span>}
              {row.feature}
            </td>
            <td class="us-cell">
              {typeof row.us === "boolean" ? (
                row.us ? (
                  <Icon name="check-circle" class="w-5 h-5 text-green-500" />
                ) : (
                  <Icon name="times-circle" class="w-5 h-5 text-gray-300" />
                )
              ) : (
                <span class="custom-value positive">{row.us}</span>
              )}
            </td>
            <td class="them-cell">
              {typeof row.them === "boolean" ? (
                row.them ? (
                  <Icon name="check-circle" class="w-5 h-5 text-green-500" />
                ) : (
                  <Icon name="times-circle" class="w-5 h-5 text-red-400" />
                )
              ) : (
                <span class="custom-value negative">{row.them}</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Mobile View -->
  <div class="comparison-mobile">
    {features.map((row) => (
      <div class={`mobile-row ${row.highlight ? "mobile-highlight" : ""}`}>
        <div class="mobile-feature">
          {row.highlight && <span class="hot-badge">HOT</span>}
          {row.feature}
        </div>
        <div class="mobile-compare">
          <div class="mobile-us">
            <span class="mobile-label">Us:</span>
            {typeof row.us === "boolean" ? (
              row.us ? (
                <Icon name="check-circle" class="w-5 h-5 text-green-500 inline" />
              ) : (
                <Icon name="times-circle" class="w-5 h-5 text-gray-300 inline" />
              )
            ) : (
              <span class="positive">{row.us}</span>
            )}
          </div>
          <div class="mobile-them">
            <span class="mobile-label">Them:</span>
            {typeof row.them === "boolean" ? (
              row.them ? (
                <Icon name="check-circle" class="w-5 h-5 text-green-500 inline" />
              ) : (
                <Icon name="times-circle" class="w-5 h-5 text-red-400 inline" />
              )
            ) : (
              <span class="negative">{row.them}</span>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- CTA Section -->
  <div class="comparison-cta">
    <div class="cta-content">
      <h3 class="cta-heading">Ready to Experience the Difference?</h3>
      <p class="cta-subheading">
        Join 423+ homeowners who switched this month and never looked back
      </p>
      <div class="cta-buttons">
        <a href="/booking" class="cta-primary">
          <Icon name="calendar-check" class="w-5 h-5" />
          Get Your Better Price Now
        </a>
        <a href="tel:2568261100" class="cta-secondary">
          <Icon name="phone" class="w-5 h-5" />
          Call 256-826-1100
        </a>
      </div>
      <p class="cta-guarantee">
        <Icon name="shield-alt" class="w-4 h-4 text-green-500 inline" />
        30-Day Money-Back Guarantee • Cancel Anytime
      </p>
    </div>
  </div>
</div>

<style>
  .comparison-section {
    padding: 40px 0;
  }

  .comparison-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .comparison-title {
    font-size: 32px;
    font-weight: bold;
    color: #1f2937;
    margin-bottom: 8px;
  }

  .comparison-subtitle {
    font-size: 16px;
    color: #6b7280;
    margin-bottom: 16px;
  }

  .savings-badge {
    display: inline-block;
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border: 2px solid #fbbf24;
    padding: 8px 20px;
    border-radius: 24px;
    font-weight: bold;
    color: #92400e;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  /* Desktop Table */
  .comparison-table-wrapper {
    overflow-x: auto;
    margin-bottom: 32px;
    display: block;
  }

  .comparison-table {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
  }

  .comparison-table thead tr {
    background: linear-gradient(135deg, #f9fafb 0%, #f3f4f6 100%);
  }

  .comparison-table th {
    padding: 20px 16px;
    font-weight: 600;
    text-align: center;
    border-bottom: 2px solid #e5e7eb;
  }

  .feature-col {
    text-align: left !important;
    width: 50%;
  }

  .company-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
  }

  .our-company {
    background: linear-gradient(135deg, #FFA985 0%, #FFC67D 100%);
    color: white;
  }

  .other-company {
    background: #e5e7eb;
    color: #6b7280;
  }

  .comparison-table tbody tr {
    border-bottom: 1px solid #f3f4f6;
    transition: background 0.2s ease;
  }

  .comparison-table tbody tr:hover {
    background: #fef3c7;
  }

  .highlight-row {
    background: #fef3c7 !important;
    position: relative;
  }

  .comparison-table td {
    padding: 16px;
    text-align: center;
  }

  .feature-cell {
    text-align: left;
    font-size: 14px;
    color: #374151;
    position: relative;
  }

  .hot-badge {
    position: absolute;
    left: -8px;
    top: 50%;
    transform: translateY(-50%);
    background: #ef4444;
    color: white;
    font-size: 9px;
    font-weight: bold;
    padding: 2px 6px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .custom-value {
    font-weight: 600;
    font-size: 14px;
  }

  .custom-value.positive {
    color: #059669;
  }

  .custom-value.negative {
    color: #dc2626;
  }

  /* Mobile View */
  .comparison-mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .comparison-table-wrapper {
      display: none;
    }

    .comparison-mobile {
      display: block;
      space-y: 12px;
    }

    .mobile-row {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 12px;
      margin-bottom: 12px;
    }

    .mobile-highlight {
      background: #fef3c7;
      border-color: #fbbf24;
    }

    .mobile-feature {
      font-weight: 600;
      font-size: 14px;
      color: #1f2937;
      margin-bottom: 8px;
      position: relative;
      padding-left: 12px;
    }

    .mobile-compare {
      display: flex;
      justify-content: space-around;
      gap: 16px;
    }

    .mobile-us,
    .mobile-them {
      flex: 1;
      text-align: center;
    }

    .mobile-label {
      display: block;
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 4px;
    }
  }

  /* CTA Section */
  .comparison-cta {
    background: linear-gradient(135deg, #065f46 0%, #047857 100%);
    border-radius: 20px;
    padding: 32px;
    text-align: center;
    color: white;
    position: relative;
    overflow: hidden;
  }

  .comparison-cta::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    animation: rotate 30s linear infinite;
  }

  @keyframes rotate {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  .cta-heading {
    font-size: 28px;
    font-weight: bold;
    margin-bottom: 8px;
  }

  .cta-subheading {
    font-size: 16px;
    opacity: 0.9;
    margin-bottom: 24px;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 10px;
    font-weight: bold;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cta-primary {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    color: #1f2937;
    box-shadow: 0 4px 15px rgba(251, 191, 36, 0.3);
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(251, 191, 36, 0.4);
  }

  .cta-secondary {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 2px solid white;
  }

  .cta-secondary:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .cta-guarantee {
    font-size: 14px;
    opacity: 0.9;
  }
</style>