---
import Icon from "./Icon.astro";

interface Props {
  city?: string;
  state?: string;
  serviceName?: string;
  variant?: "card" | "embedded" | "compact";
  heading?: string;
  subheading?: string;
}

const {
  city = "",
  state = "AL",
  serviceName = "",
  variant = "embedded",
  heading,
  subheading,
} = Astro.props;

const displayCity = city || "Your Area";
const displayService = serviceName || "Cleaning Service";

const defaultHeading = heading
  ? heading
  : city
    ? `See Your Exact ${city} Price`
    : "See Your Exact Price Instantly";

const defaultSubheading = subheading
  ? subheading
  : serviceName && city
    ? `${displayService} in ${displayCity} — takes 60 seconds, zero obligation`
    : city
      ? `Serving all ${displayCity} neighborhoods`
      : "Takes 60 seconds. Zero obligation. No credit card required.";
---

<div
  class:list={[
    "booking-cta-component",
    variant === "card"
      ? "bg-white rounded-2xl shadow-xl border border-gray-100/50 p-6 md:p-8"
      : variant === "compact"
        ? "text-center"
        : "rounded-xl",
  ]}
>
  <!-- Header -->
  <div class="text-center mb-6">
    <h3 class="text-2xl font-bold text-[#333333] mb-2">{defaultHeading}</h3>
    <p class="text-gray-500 text-sm">{defaultSubheading}</p>
  </div>

  <!-- Trust Signals Row -->
  <div class="flex flex-wrap justify-center gap-3 mb-6 text-xs text-gray-600">
    <span class="flex items-center gap-1">
      <Icon name="shield-alt" class="w-3.5 h-3.5 text-green-500" />
      Insured &amp; Bonded
    </span>
    <span class="flex items-center gap-1">
      <Icon name="star" class="w-3.5 h-3.5 text-[#FFA985]" fill="currentColor" />
      130+ 5-Star Reviews
    </span>
    <span class="flex items-center gap-1">
      <Icon name="clock" class="w-3.5 h-3.5 text-blue-500" />
      Reply within 2 hours
    </span>
  </div>

  <!-- Primary CTA Button -->
  <a
    href="/booking"
    class="block w-full py-4 px-6 rounded-xl bg-gradient-to-r from-[#FFA985] to-[#FFC67D] text-[#333333] font-bold text-center text-lg shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 group"
    onclick="if(typeof gtag==='function'){gtag('event','cta_click',{event_category:'CTA',event_label:'BookingCTA - Show Me My Price',page_location:window.location.href});}"
  >
    <Icon name="calendar-check" class="w-5 h-5 inline mr-2 group-hover:scale-110 transition-transform" />
    Show Me My Price
  </a>

  <!-- Secondary: Phone -->
  <div class="mt-4 text-center">
    <p class="text-xs text-gray-400 mb-2">Prefer to talk? Call us directly:</p>
    <div class="flex flex-col sm:flex-row justify-center gap-2">
      <a
        href="tel:+12568261100"
        class="inline-flex items-center justify-center text-sm font-semibold text-gray-700 hover:text-[#FFA985] transition"
      >
        <Icon name="phone" class="w-4 h-4 mr-1 text-[#FFA985]" />
        AL: 256-826-1100
      </a>
      <span class="hidden sm:inline text-gray-300">|</span>
      <a
        href="tel:+16155101427"
        class="inline-flex items-center justify-center text-sm font-semibold text-gray-700 hover:text-[#FFA985] transition"
      >
        <Icon name="phone" class="w-4 h-4 mr-1 text-[#FFA985]" />
        TN: 615-510-1427
      </a>
    </div>
  </div>
</div>
