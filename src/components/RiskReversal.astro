---
// RiskReversal Component - Strong guarantee messaging to remove purchase friction
import Icon from "./Icon.astro";

interface Props {
  variant?: "banner" | "card" | "inline" | "hero";
  heading?: string;
  subheading?: string;
  guarantees?: string[];
}

const {
  variant = "banner",
  heading = "100% Risk-Free Guarantee",
  subheading = "We're so confident you'll love our service, we put our money where our mouth is",
  guarantees = [
    "Not satisfied? We'll re-clean for FREE within 24 hours",
    "Still not happy? Get a FULL refund - no questions asked",
    "ZERO risk to try us - Cancel anytime, no contracts ever",
    "$2 Million insurance protects your home and belongings",
  ],
} = Astro.props;
---

{variant === "banner" && (
  <div class="risk-reversal-banner">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="shield-icon">
            <Icon name="shield-alt" class="w-8 h-8 text-white" />
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-800">{heading}</h3>
            <p class="text-sm text-gray-600">{subheading}</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="guarantee-badge">
            <Icon name="check-circle" class="w-4 h-4" />
            Money-Back Guarantee
          </span>
          <span class="guarantee-badge">
            <Icon name="clock" class="w-4 h-4" />
            24-Hour Promise
          </span>
        </div>
      </div>
    </div>
  </div>
)}

{variant === "card" && (
  <div class="risk-reversal-card">
    <div class="card-header">
      <Icon name="shield-alt" class="w-12 h-12 text-green-500 mx-auto mb-4" />
      <h3 class="text-2xl font-bold text-gray-800 text-center mb-2">{heading}</h3>
      <p class="text-gray-600 text-center mb-6">{subheading}</p>
    </div>
    <div class="guarantees-list">
      {guarantees.map((guarantee, index) => (
        <div class="guarantee-item">
          <span class="guarantee-number">{index + 1}</span>
          <p class="guarantee-text">{guarantee}</p>
        </div>
      ))}
    </div>
    <div class="card-footer">
      <p class="text-center text-sm text-gray-500">
        <strong>Bottom Line:</strong> You have nothing to lose and a spotless home to gain
      </p>
    </div>
  </div>
)}

{variant === "inline" && (
  <div class="risk-reversal-inline">
    <Icon name="shield-alt" class="w-5 h-5 text-green-500" />
    <span class="font-semibold text-green-700">100% Satisfaction Guarantee:</span>
    <span class="text-gray-600">Not happy? We'll re-clean FREE or refund 100%</span>
  </div>
)}

{variant === "hero" && (
  <div class="risk-reversal-hero">
    <div class="hero-content">
      <div class="hero-badge">
        <Icon name="award" class="w-6 h-6" />
        <span>ZERO RISK PROMISE</span>
      </div>
      <h2 class="hero-heading">
        Try Us Risk-Free for 30 Days
        <span class="hero-subheading">Cancel anytime. No contracts. No hassles.</span>
      </h2>
      <div class="hero-guarantees">
        {guarantees.slice(0, 3).map((guarantee) => (
          <div class="hero-guarantee-item">
            <Icon name="check-circle" class="w-5 h-5 text-green-500" />
            <span>{guarantee}</span>
          </div>
        ))}
      </div>
      <div class="hero-cta">
        <a href="/booking" class="hero-button">
          Claim Your Risk-Free Clean Now →
        </a>
        <p class="hero-disclaimer">No credit card required to see pricing</p>
      </div>
    </div>
  </div>
)}

<style>
  /* Banner Variant */
  .risk-reversal-banner {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border-top: 3px solid #22c55e;
    border-bottom: 3px solid #22c55e;
    padding: 20px 0;
    margin: 40px 0;
  }

  .shield-icon {
    background: #22c55e;
    border-radius: 50%;
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .guarantee-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: white;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    color: #059669;
    border: 2px solid #22c55e;
  }

  /* Card Variant */
  .risk-reversal-card {
    background: white;
    border: 3px solid #22c55e;
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 10px 25px rgba(34, 197, 94, 0.1);
    position: relative;
    overflow: hidden;
  }

  .risk-reversal-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
    background: linear-gradient(90deg, #22c55e, #16a34a, #22c55e);
    background-size: 200% 100%;
    animation: shimmer 3s linear infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }

  .guarantees-list {
    space-y: 16px;
    margin-bottom: 24px;
  }

  .guarantee-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .guarantee-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: #22c55e;
    color: white;
    border-radius: 50%;
    font-weight: bold;
    font-size: 14px;
    flex-shrink: 0;
  }

  .guarantee-text {
    flex: 1;
    font-size: 15px;
    color: #374151;
    line-height: 1.5;
  }

  /* Inline Variant */
  .risk-reversal-inline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f0fdf4;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid #bbf7d0;
    font-size: 14px;
  }

  /* Hero Variant */
  .risk-reversal-hero {
    background: linear-gradient(135deg, #065f46 0%, #047857 100%);
    color: white;
    padding: 48px 24px;
    border-radius: 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .risk-reversal-hero::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    animation: rotate 30s linear infinite;
  }

  @keyframes rotate {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.2);
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
  }

  .hero-heading {
    font-size: 36px;
    font-weight: bold;
    margin-bottom: 24px;
    line-height: 1.2;
  }

  .hero-subheading {
    display: block;
    font-size: 18px;
    font-weight: normal;
    margin-top: 8px;
    opacity: 0.9;
  }

  .hero-guarantees {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .hero-guarantee-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 16px;
  }

  .hero-button {
    display: inline-block;
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    color: #1f2937;
    padding: 16px 32px;
    border-radius: 12px;
    font-size: 18px;
    font-weight: bold;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(251, 191, 36, 0.3);
  }

  .hero-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(251, 191, 36, 0.4);
  }

  .hero-disclaimer {
    margin-top: 12px;
    font-size: 14px;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .risk-reversal-banner .flex {
      flex-direction: column;
      text-align: center;
    }

    .hero-heading {
      font-size: 28px;
    }
  }
</style>