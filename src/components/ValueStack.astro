---
// ValueStack Component - Shows the value proposition with pricing breakdown
import Icon from "./Icon.astro";

interface ValueItem {
  feature: string;
  value: string;
  highlight?: boolean;
}

interface Props {
  title?: string;
  items?: ValueItem[];
  totalValue?: string;
  yourPrice?: string;
  savings?: string;
  variant?: "default" | "compact" | "detailed";
}

const {
  title = "Here's Everything You Get:",
  items = [
    { feature: "Professional 49-Point Deep Clean", value: "$276" },
    { feature: "All Supplies & Equipment Included", value: "$50" },
    { feature: "Eco-Friendly Premium Products", value: "$35" },
    { feature: "Post-Clean Photo Documentation", value: "$25" },
    { feature: "100% Satisfaction Guarantee", value: "Priceless", highlight: true },
    { feature: "Same-Day Service Available", value: "$75" },
    { feature: "$2M Insurance Coverage", value: "Included", highlight: true },
  ],
  totalValue = "$461+",
  yourPrice = "Starting at $99",
  savings = "Save $362",
  variant = "default",
} = Astro.props;

const currentMonth = new Date().toLocaleDateString('en-US', { month: 'long' });
---

<div class={`value-stack ${variant}`}>
  {variant === "detailed" && (
    <div class="value-stack-header">
      <h3 class="text-xl font-bold text-gray-800 mb-2">{title}</h3>
      <p class="text-sm text-gray-600 mb-4">
        Limited-Time {currentMonth} Pricing (Normally {totalValue} Value)
      </p>
    </div>
  )}

  <div class={`value-stack-content ${variant === "compact" ? "space-y-2" : "space-y-3"}`}>
    {items.map((item) => (
      <div class="value-item flex items-center justify-between">
        <div class="flex items-center gap-2">
          <Icon
            name="check-circle"
            class={`w-5 h-5 ${item.highlight ? "text-green-500" : "text-[#FFA985]"}`}
          />
          <span class={`text-sm ${item.highlight ? "font-semibold" : ""}`}>
            {item.feature}
          </span>
        </div>
        <span class={`text-sm ${item.highlight ? "text-green-600 font-bold" : "text-gray-500 line-through"}`}>
          {item.value}
        </span>
      </div>
    ))}
  </div>

  {variant !== "compact" && (
    <>
      <div class="border-t-2 border-dashed border-gray-300 my-4"></div>

      <div class="value-stack-total">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm text-gray-600">Total Value:</span>
          <span class="text-lg line-through text-gray-400">{totalValue}</span>
        </div>
        <div class="flex items-center justify-between mb-2">
          <span class="text-lg font-bold text-gray-800">Your Price Today:</span>
          <span class="text-2xl font-bold text-[#FFA985]">{yourPrice}</span>
        </div>
        <div class="text-center bg-green-50 rounded-lg py-2 px-4">
          <span class="text-green-700 font-bold text-lg">
            💰 {savings} ({Math.round((362/461)*100)}% OFF)
          </span>
        </div>
      </div>

      {/* Urgency Element */}
      <div class="mt-4 text-center">
        <p class="text-xs text-red-600 font-semibold animate-pulse">
          ⏰ This pricing expires at midnight tonight
        </p>
      </div>
    </>
  )}

  {/* Social Proof */}
  <div class="mt-4 flex items-center justify-center gap-4 text-xs text-gray-600">
    <span class="flex items-center gap-1">
      <Icon name="users" class="w-4 h-4" />
      423 customers this month
    </span>
    <span class="flex items-center gap-1">
      <Icon name="trending-up" class="w-4 h-4" />
      92% choose recurring service
    </span>
  </div>
</div>

<style>
  .value-stack {
    background: linear-gradient(135deg, #fff 0%, #fafafa 100%);
    border: 2px solid #f3f4f6;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .value-stack.compact {
    padding: 16px;
    background: white;
  }

  .value-stack.detailed {
    background: white;
    border: 3px solid #FFA985;
    position: relative;
    overflow: hidden;
  }

  .value-stack.detailed::before {
    content: "BEST VALUE";
    position: absolute;
    top: 10px;
    right: -30px;
    background: #FFA985;
    color: white;
    font-size: 11px;
    font-weight: bold;
    padding: 4px 40px;
    transform: rotate(45deg);
  }

  .value-item {
    transition: all 0.2s ease;
  }

  .value-item:hover {
    transform: translateX(4px);
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>